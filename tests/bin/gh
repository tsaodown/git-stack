#!/usr/bin/env bash
# gh stub for git-stack tests. Logs every invocation, returns canned data,
# and persists PR state in $GH_STUB_DIR so re-running within one test sees
# previously-created PRs. Requires `jq` on PATH for --jq queries.
#
# Recognized invocations:
#   gh auth status [-h github.com]            -> exit 0
#   gh repo view --json nameWithOwner [-q ...] -> echo "${GH_STUB_REPO:-test/repo}"
#   gh pr list --repo R --head H --state open --limit N --json ... [--jq EXPR]
#                                             -> emits JSON array (0 or 1 PR)
#   gh pr create --repo R --head H --base B --title T [--draft] --body-file FILE
#                                             -> emits PR URL ending in /pull/<n>;
#                                                persists PR by branch+num
#   gh pr edit <num> [--title T] [--body-file FILE] [--base B]
#                                             -> updates persisted PR (exit 0)
#   gh pr view <num> --json FIELDS [--jq EXPR]
#                                             -> emits {number,state,title} for
#                                                the PR (by-num seed, then
#                                                persisted JSON, then defaults)
#
# Env vars:
#   GH_STUB_LOG          path to log file; "argv\t<stdin-b64>" per invocation
#   GH_STUB_DIR          dir for stub state (PR counter, persisted PRs)
#   GH_STUB_REPO         fake nameWithOwner returned by `gh repo view`
#   GH_STUB_FAIL_CREATE  if non-empty and equals --head value, `pr create` exits 1
#   GH_PR_<safe>__NUM    seed: existing PR number for branch (safe = / -> _)
#   GH_PR_<safe>__TITLE  seed: existing PR title
#   GH_PR_<safe>__BODY   seed: existing PR body (multi-line allowed)
#   GH_PR_NUM_<n>__STATE seed: state for `pr view <n>` (OPEN|MERGED|CLOSED)
#   GH_PR_NUM_<n>__TITLE seed: title for `pr view <n>` (e.g. a merged predecessor)
#
# Env-var seeds override persisted state. When a seed is set and `pr create`
# is called for that branch, gh-stub emits an "already exists" error so the
# production code's re-query path is exercised.

set -u

_stub_log="${GH_STUB_LOG:-/dev/null}"
_stub_dir="${GH_STUB_DIR:-/tmp/gh-stub-$$}"
mkdir -p "$_stub_dir/by-branch" "$_stub_dir/by-num" 2>/dev/null || true

# Capture stdin (may be empty / tty).
_stdin=""
if [ ! -t 0 ]; then
  _stdin=$(cat 2>/dev/null || true)
fi

# Log invocation: full argv (shell-quoted) then TAB then base64-encoded stdin.
{
  printf 'gh'
  for _a in "$@"; do printf ' %q' "$_a"; done
  printf '\t'
  printf '%s' "$_stdin" | base64 | tr -d '\n'
  printf '\n'
} >> "$_stub_log" 2>/dev/null || true

# Helper: read a flag's value from $@. Doesn't consume.
_flagval() {
  local needle="$1"; shift
  while (( $# > 0 )); do
    if [ "$1" = "$needle" ]; then
      printf '%s' "${2-}"; return 0
    fi
    shift
  done
  return 1
}

# Sanitize a branch name into an env-var- and filename-safe token.
_safe() {
  printf '%s' "$1" | tr '/' '_' | tr -c 'A-Za-z0-9_' '_'
}

# Indirect env var read (bash 3.2-compatible).
_envget() {
  eval "printf '%s' \"\${$1-}\""
}

# Build a single-PR JSON object with all fields needed by both `pr sync`
# and `pr list`. Uses jq for safe quoting. The extra args (state, draft,
# base, review, comments-count) are optional and have sensible defaults.
# Usage: _emit_pr_json <num> <title> <body> [<state>] [<draft:0|1>] [<base>] [<review>] [<comments_n>]
_emit_pr_json() {
  local num="$1" title="$2" body="$3"
  local state="${4:-OPEN}"
  local draft="${5:-1}"     # default to draft — that's what `pr create --draft` sets
  local base="${6:-main}"
  local review="${7-}"      # empty by default (REVIEW_REQUIRED / null)
  local n_comments="${8:-0}"
  local is_draft_json
  if [ "$draft" = "1" ] || [ "$draft" = "true" ]; then
    is_draft_json="true"
  else
    is_draft_json="false"
  fi
  jq -n \
    --argjson n "$num" \
    --arg t "$title" \
    --arg b "$body" \
    --arg state "$state" \
    --argjson is_draft "$is_draft_json" \
    --arg base "$base" \
    --arg review "$review" \
    --argjson nc "$n_comments" \
    '{
       number: $n,
       title: $t,
       body: $b,
       state: $state,
       isDraft: $is_draft,
       baseRefName: $base,
       reviewDecision: $review,
       comments: (if $nc > 0 then [range(0; $nc) | {id: ., body: "stub"}] else [] end)
     }'
}

# Look up a PR's JSON (single object) for <branch>. Empty if none.
# Order: env-var seeds first, then persisted state from `pr create`.
# Persisted state is filled in with default field values for new fields
# (state, isDraft, baseRefName, reviewDecision, comments) so callers see a
# consistent schema regardless of how the PR was created in the stub.
_lookup_pr() {
  local head="$1"
  local safe; safe=$(_safe "$head")
  local seed_num; seed_num=$(_envget "GH_PR_${safe}__NUM")
  if [ -n "$seed_num" ]; then
    local seed_title=$(_envget "GH_PR_${safe}__TITLE")
    local seed_body=$(_envget "GH_PR_${safe}__BODY")
    local seed_state=$(_envget "GH_PR_${safe}__STATE")
    local seed_draft=$(_envget "GH_PR_${safe}__DRAFT")
    local seed_base=$(_envget "GH_PR_${safe}__BASE")
    local seed_review=$(_envget "GH_PR_${safe}__REVIEW")
    local seed_comments=$(_envget "GH_PR_${safe}__COMMENTS")
    _emit_pr_json \
      "$seed_num" "$seed_title" "$seed_body" \
      "${seed_state:-OPEN}" "${seed_draft:-1}" "${seed_base:-main}" \
      "$seed_review" "${seed_comments:-0}"
    return 0
  fi
  local nf="$_stub_dir/by-branch/$safe.num"
  if [ -f "$nf" ]; then
    local n; n=$(cat "$nf")
    local jf="$_stub_dir/by-num/$n.json"
    if [ -f "$jf" ]; then
      # Fill in defaults for any fields not present in the stored JSON.
      jq '
        {state: "OPEN", isDraft: true, baseRefName: "main",
         reviewDecision: "", comments: []} * .
      ' "$jf"
      return 0
    fi
  fi
  return 1
}

_sub1="${1-}"
_sub2="${2-}"

case "$_sub1 $_sub2" in
  "auth status")
    exit 0
    ;;
  "repo view")
    printf '%s\n' "${GH_STUB_REPO:-test/repo}"
    exit 0
    ;;
  "pr list")
    _head=$(_flagval --head "$@" || true)
    _jq=$(_flagval --jq "$@" || true)
    if pr_obj=$(_lookup_pr "$_head"); then
      _json="[$pr_obj]"
    else
      _json='[]'
    fi
    if [ -n "$_jq" ]; then
      printf '%s' "$_json" | jq -r "$_jq"
    else
      printf '%s\n' "$_json"
    fi
    exit 0
    ;;
  "pr create")
    _head=$(_flagval --head "$@" || true)
    _title=$(_flagval --title "$@" || true)
    _base=$(_flagval --base "$@" || true)
    # Detect --draft (flag, no value).
    _draft=0
    for _a in "$@"; do
      if [ "$_a" = "--draft" ]; then _draft=1; break; fi
    done
    if [ -n "${GH_STUB_FAIL_CREATE:-}" ] && [ "$GH_STUB_FAIL_CREATE" = "$_head" ]; then
      printf 'gh-stub: simulated create failure for %s\n' "$_head" >&2
      exit 1
    fi
    if existing=$(_lookup_pr "$_head"); then
      _existing_num=$(printf '%s' "$existing" | jq -r '.number')
      printf 'a pull request for branch "%s" into branch "main" already exists: https://github.com/%s/pull/%s\n' \
        "$_head" "${GH_STUB_REPO:-test/repo}" "$_existing_num" >&2
      exit 1
    fi
    _counter="$_stub_dir/.pr-counter"
    _n=$(cat "$_counter" 2>/dev/null || echo 100)
    _n=$((_n + 1))
    printf '%d' "$_n" > "$_counter"
    _safe_h=$(_safe "$_head")
    _emit_pr_json "$_n" "$_title" "$_stdin" "OPEN" "$_draft" "${_base:-main}" "" 0 \
      > "$_stub_dir/by-num/$_n.json"
    printf '%d' "$_n" > "$_stub_dir/by-branch/$_safe_h.num"
    printf 'https://github.com/%s/pull/%d\n' "${GH_STUB_REPO:-test/repo}" "$_n"
    exit 0
    ;;
  "pr edit")
    _num="${3-}"
    if [ -z "$_num" ] || ! [[ "$_num" =~ ^[0-9]+$ ]]; then
      printf 'gh-stub: pr edit needs a numeric PR id (got %q)\n' "$_num" >&2
      exit 2
    fi
    _jf="$_stub_dir/by-num/$_num.json"
    _new_title=""
    _has_title=0
    _new_body=""
    _has_body=0
    _new_base=""
    _has_base=0
    # Look for --title / --body-file / --base in the remaining args.
    shift 3
    while (( $# > 0 )); do
      case "$1" in
        --title)      _new_title="${2-}"; _has_title=1; shift 2 ;;
        --body-file)  _new_body="$_stdin"; _has_body=1; shift 2 ;;
        --base)       _new_base="${2-}"; _has_base=1; shift 2 ;;
        *) shift ;;
      esac
    done
    if [ ! -f "$_jf" ]; then
      # No persisted state — assume seeded via env vars, can't update those.
      # Just succeed silently (the production code is recording state too).
      exit 0
    fi
    # Build a jq filter from whichever fields were set. jq is bash-3.2 safe
    # and faster than chained reads.
    _filter=""
    _args=()
    if (( _has_title )); then
      _filter="${_filter}${_filter:+ | }.title = \$t"
      _args+=( --arg t "$_new_title" )
    fi
    if (( _has_body )); then
      _filter="${_filter}${_filter:+ | }.body = \$b"
      _args+=( --arg b "$_new_body" )
    fi
    if (( _has_base )); then
      _filter="${_filter}${_filter:+ | }.baseRefName = \$base"
      _args+=( --arg base "$_new_base" )
    fi
    if [ -n "$_filter" ]; then
      jq "${_args[@]}" "$_filter" "$_jf" > "$_jf.tmp" && mv "$_jf.tmp" "$_jf"
    fi
    exit 0
    ;;
  "pr view")
    _num="${3-}"
    _jq=$(_flagval --jq "$@" || true)
    # Resolve the PR's fields. by-num env seeds first (for PRs not created in
    # this test, e.g. a merged predecessor referenced only by number), then the
    # persisted by-num JSON, then OPEN/empty defaults.
    _vseed_state=$(_envget "GH_PR_NUM_${_num}__STATE")
    _vseed_title=$(_envget "GH_PR_NUM_${_num}__TITLE")
    if [ -n "$_vseed_state" ] || [ -n "$_vseed_title" ]; then
      _vobj=$(jq -n --arg n "$_num" --arg s "${_vseed_state:-OPEN}" --arg t "$_vseed_title" \
        '{number: ($n|tonumber), state: $s, title: $t}')
    elif [ -f "$_stub_dir/by-num/$_num.json" ]; then
      _vobj=$(jq '{state: "OPEN", title: ""} * .' "$_stub_dir/by-num/$_num.json")
    else
      _vobj=$(jq -n --arg n "$_num" '{number: ($n|tonumber), state: "OPEN", title: ""}')
    fi
    if [ -n "$_jq" ]; then
      printf '%s' "$_vobj" | jq -r "$_jq"
    else
      printf '%s\n' "$_vobj"
    fi
    exit 0
    ;;
  "api -X")
    # Handle: gh api -X POST /repos/OWNER/REPO/branches/OLD/rename -f new_name=NEW
    _method="${3-}"
    _path=""
    _new_name=""
    if (( $# >= 3 )); then shift 3; else shift "$#"; fi  # consume 'api -X POST' (or as much as exists)
    while (( $# > 0 )); do
      case "$1" in
        -f)
          case "${2-}" in
            new_name=*) _new_name="${2#new_name=}" ;;
          esac
          shift 2
          ;;
        /*)
          _path="$1"; shift
          ;;
        *)
          shift
          ;;
      esac
    done
    if [ "$_method" = "POST" ] && [[ "$_path" == */branches/*/rename ]]; then
      _old="${_path#*/branches/}"
      _old="${_old%/rename}"
      _old="${_old//%2F//}"
      if [ -n "${GH_STUB_FAIL_RENAME:-}" ] && [ "$_old" = "$GH_STUB_FAIL_RENAME" ]; then
        echo "stub: simulated rename failure for $_old" >&2
        exit 1
      fi
      # Model the rename on the actual origin so tests exercise the real push
      # path (the branch lives under its new name on the remote afterward).
      _origin_url=$(git remote get-url origin 2>/dev/null || true)
      if [ -n "$_origin_url" ] \
         && git --git-dir="$_origin_url" rev-parse --verify --quiet "refs/heads/${_old}" >/dev/null 2>&1; then
        git --git-dir="$_origin_url" branch -m "${_old}" "${_new_name}" 2>/dev/null || true
      fi
      printf '{"name":"%s","protected":false}\n' "$_new_name"
      exit 0
    fi
    # Unrecognized api call — silently succeed (don't break tests using it).
    exit 0
    ;;
  "pr comment")
    # gh pr comment <num> --repo R --body B — invocation already logged above;
    # just succeed (the fold breadcrumb only needs a clean exit).
    exit 0
    ;;
  *)
    printf 'gh-stub: unrecognized command: %s %s\n' "$_sub1" "$_sub2" >&2
    exit 2
    ;;
esac
