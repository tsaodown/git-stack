#!/usr/bin/env bash
# git-stack — reflow a stack of branches sharing a numeric-leaf prefix.
# See `git stack help` for usage. Bash 3.2 compatible (parallel arrays).

set -euo pipefail

PROG="${0##*/}"
VERBOSE=0
QUIET=0
USE_COLOR_PREF="auto"   # auto | always | never; resolved by color_init.

OPT_PUSH=0
OPT_FORCE=0
OPT_NO_SYNC=0
OPT_NO_PUSH=0
OPT_FROM=""
OPT_ONTO=""
OPT_PREFIX=""
REMAINING_ARGS=()

# ---------- color ----------

# Color palette. Initialized empty; color_init populates if appropriate.
C_RESET=""; C_BOLD=""; C_DIM=""; C_UNDERLINE=""
C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_MAGENTA=""; C_CYAN=""

color_init() {
  local on=0
  case "$USE_COLOR_PREF" in
    always) on=1 ;;
    never)  on=0 ;;
    *)
      if [[ -n "${NO_COLOR-}" ]]; then on=0
      elif [[ -t 1 ]]; then on=1
      else on=0
      fi
      ;;
  esac
  if (( on )); then
    C_RESET=$'\033[0m'
    C_BOLD=$'\033[1m'
    C_DIM=$'\033[2m'
    C_RED=$'\033[31m'
    C_GREEN=$'\033[32m'
    C_YELLOW=$'\033[33m'
    C_BLUE=$'\033[34m'
    C_MAGENTA=$'\033[35m'
    C_CYAN=$'\033[36m'
    C_UNDERLINE=$'\033[4m'
  fi
}

# Stack state. Saved/loaded as bash-sourceable file. STACK_BRANCHES and
# STACK_ORIG_SHAS are parallel arrays (index N is the same branch in both).
#
# Globals contract — adding a field requires updating all three of:
#   (a) the declaration below
#   (b) save_engine_state's serialization block
#   (c) load_state's reset list (arrays only; scalars are overwritten by
#       sourcing the file, but reset arrays in case a stale process left
#       them populated and the file's assignment doesn't fully clear)
#
#   STACK_VERSION          schema version of the saved state
#   STACK_STARTED_AT       unix ts when the run began
#   STACK_STARTING_BRANCH  branch HEAD was on when the run began
#   STACK_PREFIX           stack prefix, including trailing /
#   STACK_PUSH             1 if --push, else 0
#   STACK_FORCE            1 if --force (allow multi-commit branches), else 0
#   STACK_SAFE_DROP        commit SHAs the engine may drop during a tip-only
#                          cherry-pick without --force — commits proven merged
#                          (clean populates from the gone branches it pruned)
#   STACK_FROM_IDX         index of the bottom branch we touch
#   STACK_ONTO             resolved SHA of --onto target (if any)
#   STACK_ONTO_REF         original --onto ref name (for display)
#   STACK_BRANCHES         full branch names in stack order
#   STACK_ORIG_SHAS        original tip SHAs at run start
#   STACK_PUSH_FAILURES    branches whose push failed during this run
#                          (transient — not historical)
#   STACK_OPT_NO_PUSH      persisted OPT_NO_PUSH (for the remote-sync phase)
#   STACK_OPT_NO_SYNC      persisted OPT_NO_SYNC (for the remote-sync phase)
STACK_VERSION=2
STACK_STARTED_AT=""
STACK_STARTING_BRANCH=""
STACK_PREFIX=""
STACK_PUSH=0
STACK_FORCE=0
STACK_SAFE_DROP=()
STACK_FROM_IDX=0
STACK_ONTO=""
STACK_ONTO_REF=""
STACK_BRANCHES=()
STACK_ORIG_SHAS=()
STACK_PUSH_FAILURES=()
STACK_OPT_NO_PUSH=0         # persisted for the remote-sync phase
STACK_OPT_NO_SYNC=0
# Reflow-engine state. The engine drives an ordered list of phases by a coarse
# (phase, unit) cursor; each phase recovers its own fine-grained in-flight
# state. See "# ---------- reflow engine ----------".
STACK_PHASES=()             # ordered phase types, e.g. (reflow-pick)
STACK_PHASE_IDX=0           # index into STACK_PHASES of the current phase
STACK_UNIT_IDX=0            # phase-relative index of the current unit
STACK_RENAME_PAIRS=()       # alternating old/new branch names for rename-batch
STACK_FOLD_VICTIM=""        # fold: remote branch to delete + breadcrumb in remote-sync
STACK_FOLD_SURVIVOR_NEW=""  # fold: survivor's (post-fold) name, for the breadcrumb target
_PHASE_OUTCOME=""           # set by a phase op: unit-done|phase-complete|paused

# Side channel: a caller (clean) sets this to the safe-to-drop SHA set before
# invoking cmd_restack, which transfers it into STACK_SAFE_DROP and clears it so
# it never leaks into an unrelated reflow.
REFLOW_SAFE_DROP=()

# ---------- helpers ----------

die()   { printf '%s%s: error:%s %s\n' "$C_RED" "$PROG" "$C_RESET" "$*" >&2; exit 1; }
warn()  { printf '%s%s: warn:%s %s\n' "$C_YELLOW" "$PROG" "$C_RESET" "$*" >&2; }
log()   { (( QUIET )) || echo "$@"; }
log_v() { (( VERBOSE )) && echo "$@" || :; }

require_in_repo() {
  git rev-parse --git-dir >/dev/null 2>&1 || die "not in a git repository"
}

require_clean_tree() {
  if [[ -n $(git status --porcelain --untracked-files=no) ]]; then
    die "working tree has uncommitted changes; commit or stash first"
  fi
}

# ---- transient handling of a dirty tree for branch-creating commands ----
#
# `add`/`create` build the new branch at <predecessor_sha> then check it out.
# When the tree is dirty we want the uncommitted work to land on the new
# branch instead of erroring. Two regimes:
#   * predecessor == HEAD  -> the checkout itself carries the changes (git
#     never touches the tree when the target commit == HEAD), staged-ness and
#     all. No stash needed.
#   * predecessor != HEAD  -> stash first, then pop after the checkout so the
#     diff is relocated onto the new branch. The pop may conflict.
# Untracked files are out of scope: they never tripped require_clean_tree
# (--untracked-files=no) and travel across checkout regardless.
#
# Plain `git stash pop` (no --index) is used, so in the relocate regime staged
# changes return unstaged (matches `rebase --autostash` and dodges a class of
# index-apply failures). In the at-HEAD regime staged-ness is preserved.

_CARRY_STASH=0  # 1 while a carry stash is outstanding

_tree_is_dirty() { [[ -n $(git status --porcelain --untracked-files=no) ]]; }

# _carry_begin <predecessor_sha> <stash-message>
# Sets _CARRY_STASH=1 only when it actually stashes (predecessor != HEAD).
_carry_begin() {
  local pred="$1" msg="$2"
  _CARRY_STASH=0
  _tree_is_dirty || return 0
  [[ "$pred" != "$(git rev-parse HEAD)" ]] || return 0
  git stash push --quiet --message "$msg" || die "failed to stash uncommitted changes"
  _CARRY_STASH=1
}

# Best-effort restore to the ORIGINAL branch after a failed create/checkout,
# before the caller dies (we never moved off the original branch yet).
_carry_unwind() {
  (( _CARRY_STASH )) || return 0
  _CARRY_STASH=0
  git stash pop --quiet 2>/dev/null || true
}

# Pop the stash onto the freshly checked-out NEW branch. On conflict git leaves
# markers AND retains the stash entry (non-zero exit) — warn, don't die.
_carry_finish() {
  (( _CARRY_STASH )) || return 0
  _CARRY_STASH=0
  git stash pop --quiet \
    || warn "carried changes applied with conflicts — resolve them in the working tree; your original snapshot is retained in 'git stash list'"
}

# create-only: show what's dirty and ask for a single keystroke. 0 = carry.
# No prefix in the message — this decision runs before the prefix is prompted.
_prompt_carry_into_stack() {
  printf '%suncommitted changes:%s\n' "$C_DIM" "$C_RESET" >&2
  git status --short --untracked-files=no >&2
  printf 'carry these into the new stack? %s[y/N]%s ' \
    "$C_DIM" "$C_RESET" >&2
  local ans=""
  read -r -n 1 ans < /dev/tty || { echo >&2; return 1; }
  echo >&2
  [[ "$ans" == y || "$ans" == Y ]]
}

require_no_op_in_progress() {
  local gitdir marker
  gitdir=$(git rev-parse --git-dir)
  for marker in CHERRY_PICK_HEAD MERGE_HEAD REVERT_HEAD rebase-merge rebase-apply; do
    if [[ -e "$gitdir/$marker" ]]; then
      die "another git operation is in progress ($marker); resolve it first"
    fi
  done
}

current_branch() {
  local b
  b=$(git symbolic-ref --short -q HEAD 2>/dev/null || true)
  [[ -n "$b" ]] || return 1
  printf '%s\n' "$b"
}

# Resolve the current branch or die. Use this from non-subshell call sites so
# the die actually terminates the script.
require_branch() {
  local b
  b=$(current_branch) || die "detached HEAD; checkout a stack branch first"
  printf '%s\n' "$b"
}

# Print current branch name or the literal "<detached>" sentinel; never
# errors. Display-only — use require_branch when detached HEAD should die.
_current_or_detached() {
  current_branch || echo "<detached>"
}

state_file() {
  printf '%s/stack-rebase-state\n' "$(git rev-parse --git-dir)"
}

# Resolve the stack prefix without dying.
# Order: explicit arg, git config stack.prefix, auto-derive from current branch.
# Exit codes: 0 success; 1 detached HEAD; 2 current branch has no numeric leaf.
_try_detect_prefix() {
  local override="${1-}"
  if [[ -n "$override" ]]; then
    printf '%s\n' "${override%/}/"
    return 0
  fi
  local cfg
  cfg=$(git config --get stack.prefix 2>/dev/null || true)
  if [[ -n "$cfg" ]]; then
    printf '%s\n' "${cfg%/}/"
    return 0
  fi
  local b leaf prefix
  b=$(current_branch) || return 1
  leaf="${b##*/}"
  [[ "$leaf" =~ ^[0-9]+- ]] || return 2
  if [[ "$b" == */* ]]; then
    prefix="${b%/*}/"
  else
    prefix=""
  fi
  printf '%s\n' "$prefix"
}

# Resolve the stack prefix or die with an explanation.
detect_prefix() {
  local p rc=0
  p=$(_try_detect_prefix "${1-}") || rc=$?
  case "$rc" in
    0) printf '%s\n' "$p" ;;
    1) die "detached HEAD; checkout a stack branch first or pass --prefix" ;;
    2) local b; b=$(current_branch || echo "?")
       die "current branch '$b' has no numeric leaf (e.g. 05-...); pass --prefix or set git config stack.prefix" ;;
    *) die "could not detect stack prefix" ;;
  esac
}

# Print branches under the prefix whose leaf matches ^[0-9]+-,
# sorted by sort -V on the numeric portion. One branch per line.
stack_branches() {
  local prefix="$1"
  local pattern="refs/heads/${prefix}*"
  git for-each-ref --format='%(refname:short)' "$pattern" \
    | awk -F/ '
        {
          leaf = $NF
          if (match(leaf, /^[0-9]+-/)) {
            key = substr(leaf, 1, RLENGTH - 1)
            print key "\t" $0
          }
        }
      ' \
    | sort -V \
    | cut -f2-
}

# Populate a named array with the stack branches under <prefix>.
# Dies with <error_msg> if the resulting list is empty (pass empty string
# or omit to skip the check).
# Usage: _load_stack_branches <prefix> <out_array_name> [<error_msg>]
_load_stack_branches() {
  local prefix="$1" out_name="$2" err="${3-}"
  local b list=()
  while IFS= read -r b; do
    [[ -n "$b" ]] && list+=("$b")
  done < <(stack_branches "$prefix")
  if [[ -n "$err" ]] && (( ${#list[@]} == 0 )); then
    die "$err"
  fi
  # bash 3.2 + set -u: cannot expand "${list[@]}" when empty. Init empty,
  # then append element-by-element. Mirrors the eval pattern in _emit_array.
  eval "$out_name=()"
  local i
  for ((i = 0; i < ${#list[@]}; i++)); do
    eval "$out_name+=($(printf '%q' "${list[$i]}"))"
  done
}

# Print distinct prefixes (each ending in "/", or "" for top-level) of every
# local branch whose leaf matches ^[0-9]+-. Used by interactive
# checkout to let the user pick a stack when current branch has no prefix.
stack_prefixes() {
  git for-each-ref --format='%(refname:short)' refs/heads/ \
    | awk -F/ '
        {
          leaf = $NF
          if (match(leaf, /^[0-9]+-/)) {
            n = length($0) - length(leaf)
            print substr($0, 1, n)
          }
        }
      ' \
    | sort -u
}

# branch_index <name> <branch...> — print 0-based index, or fail with exit 1.
branch_index() {
  local target="$1"; shift
  local i=0 b
  for b in "$@"; do
    if [[ "$b" == "$target" ]]; then
      printf '%d\n' "$i"
      return 0
    fi
    i=$((i + 1))
  done
  return 1
}

# _resolve_branch_ref <ref> <branch1> <branch2> ...
# Resolve a position-ref argument to a full branch name.
# Accepts:
#   - a numeric leaf (matches by integer-equal on the leading [0-9]+ of the
#     stack branch's leaf; e.g., "2" finds "02-foo")
#   - a full branch name (must equal exactly one stack branch)
# Prints the matched branch name to stdout, exits 0.
# On no match or multiple matches, exits non-zero (caller dies with context).
_resolve_branch_ref() {
  local ref="$1"; shift
  (( $# > 0 )) || return 1
  local b leaf num matches=()
  # Full-name match takes precedence.
  for b in "$@"; do
    if [[ "$b" == "$ref" ]]; then
      printf '%s\n' "$b"
      return 0
    fi
  done
  # Numeric-leaf match.
  if [[ "$ref" =~ ^[0-9]+$ ]]; then
    for b in "$@"; do
      leaf="${b##*/}"
      [[ "$leaf" =~ ^([0-9]+)- ]] || continue
      num="${BASH_REMATCH[1]}"
      if awk -v a="$ref" -v c="$num" 'BEGIN { exit !(a+0 == c+0) }'; then
        matches+=("$b")
      fi
    done
    case "${#matches[@]}" in
      1) printf '%s\n' "${matches[0]}"; return 0 ;;
      0) return 1 ;;
      *) return 2 ;;
    esac
  fi
  return 1
}

# Infer numeric-leaf width from a stack's existing leaves. Looks at the first
# (lowest-numbered) branch and counts the leading-digit run. Returns 3 if no
# branches were given (fresh-stack default — sparse 3-digit scheme).
# Existing 2-digit stacks keep their inferred width of 2 (legacy path).
# Usage: _leaf_width_for <branch1> <branch2> ...
_leaf_width_for() {
  if (( $# == 0 )); then
    printf '3\n'
    return 0
  fi
  local first="$1"
  local leaf="${first##*/}"
  if [[ "$leaf" =~ ^([0-9]+)- ]]; then
    printf '%d\n' "${#BASH_REMATCH[1]}"
  else
    printf '3\n'
  fi
}

# Format an integer as a zero-padded leaf number of the given width.
# Usage: _format_leaf <num> <width>
_format_leaf() {
  printf '%0*d\n' "$2" "$1"
}

# Refuse to operate on a stack whose first branch has leaf number 0. The
# `--first` insertion rule assumes a valid stack starts at leaf 1, so a leading
# 0 would alias the inserted leaf and corrupt ordering. Suggests `git stack
# doctor` for recovery.
# Usage: _require_valid_leaf_nums <branch1> <branch2> ...
_require_valid_leaf_nums() {
  local b leaf
  for b in "$@"; do
    leaf="${b##*/}"
    [[ "$leaf" =~ ^([0-9]+)- ]] || continue
    if (( 10#${BASH_REMATCH[1]} == 0 )); then
      die "stack contains invalid leaf '$b' (leaf number 0 is reserved); run 'git stack doctor' ${C_DIM}[gstkd]${C_RESET} to reflow"
    fi
  done
}

# orig_sha_for <branch> — print the saved original SHA for the branch.
orig_sha_for() {
  local target="$1"
  local i
  for ((i = 0; i < ${#STACK_BRANCHES[@]}; i++)); do
    if [[ "${STACK_BRANCHES[$i]}" == "$target" ]]; then
      printf '%s\n' "${STACK_ORIG_SHAS[$i]}"
      return 0
    fi
  done
  return 1
}

# Parse common flags into OPT_* and leave non-flag args in REMAINING_ARGS.
parse_common_flags() {
  OPT_PUSH=0
  OPT_FORCE=0
  OPT_NO_SYNC=0
  OPT_NO_PUSH=0
  OPT_FROM=""
  OPT_ONTO=""
  OPT_PREFIX=""
  REMAINING_ARGS=()
  while (( $# > 0 )); do
    case "$1" in
      --push)       OPT_PUSH=1; shift ;;
      --force)      OPT_FORCE=1; shift ;;
      --no-sync)    OPT_NO_SYNC=1; shift ;;
      --no-push)    OPT_NO_PUSH=1; shift ;;
      --from)       shift; [[ $# -gt 0 ]] || die "--from needs an argument"; OPT_FROM="$1"; shift ;;
      --onto)       shift; [[ $# -gt 0 ]] || die "--onto needs an argument"; OPT_ONTO="$1"; shift ;;
      --prefix)     shift; [[ $# -gt 0 ]] || die "--prefix needs an argument"; OPT_PREFIX="$1"; shift ;;
      --color)      USE_COLOR_PREF="always"; color_init; shift ;;
      --no-color)   USE_COLOR_PREF="never";  color_init; shift ;;
      -v|--verbose) VERBOSE=1; shift ;;
      -q|--quiet)   QUIET=1; shift ;;
      --) shift; REMAINING_ARGS=("$@"); return ;;
      -*) die "unknown flag: $1" ;;
      *)  REMAINING_ARGS+=("$1"); shift ;;
    esac
  done
}

# Consume one common flag from the start of "$@". Sets the matching global
# (OPT_PREFIX, USE_COLOR_PREF, VERBOSE, QUIET) and writes the consumed-arg
# count to $_FLAG_SHIFT. Returns 0 if a flag was consumed, 1 if not.
# Per-command parse loops call this first, then fall through to their own
# command-specific cases.
_FLAG_SHIFT=0
_consume_common_flag() {
  _FLAG_SHIFT=0
  case "$1" in
    --prefix)     [[ -n "${2-}" ]] || die "--prefix needs an argument"; OPT_PREFIX="$2"; _FLAG_SHIFT=2 ;;
    --color)      USE_COLOR_PREF="always"; color_init; _FLAG_SHIFT=1 ;;
    --no-color)   USE_COLOR_PREF="never";  color_init; _FLAG_SHIFT=1 ;;
    -v|--verbose) VERBOSE=1; _FLAG_SHIFT=1 ;;
    -q|--quiet)   QUIET=1; _FLAG_SHIFT=1 ;;
    --no-sync)    OPT_NO_SYNC=1; _FLAG_SHIFT=1 ;;
    --no-push)    OPT_NO_PUSH=1; _FLAG_SHIFT=1 ;;
    *) return 1 ;;
  esac
  return 0
}

# ---------- state file ----------

_emit_array() {
  # Print "name=( q1 q2 ... )" for an array passed by name. Empty-array safe
  # under bash 3.2 + set -u.
  local arr_name="$1" out_name="$2"
  printf '%s=(' "$out_name"
  local n
  eval "n=\${#${arr_name}[@]}"
  if (( n > 0 )); then
    local i v
    for ((i = 0; i < n; i++)); do
      eval "v=\${${arr_name}[$i]}"
      printf ' %q' "$v"
    done
  fi
  printf ' )\n'
}

load_state() {
  local f
  f=$(state_file)
  [[ -f "$f" ]] || die "no stack-rebase in progress (missing $f)"
  STACK_ONTO=""
  STACK_ONTO_REF=""
  STACK_BRANCHES=()
  STACK_ORIG_SHAS=()
  STACK_PUSH_FAILURES=()
  STACK_SAFE_DROP=()
  STACK_PHASES=()
  STACK_PHASE_IDX=0
  STACK_UNIT_IDX=0
  STACK_RENAME_PAIRS=()
  STACK_FOLD_VICTIM=""
  STACK_FOLD_SURVIVOR_NEW=""
  # shellcheck disable=SC1090
  source "$f"
  case "${STACK_VERSION-}" in
    2) ;;
    1) die "this stack operation was started by an older git-stack (state version 1); finish or 'git stack abort' it with that version first, or delete $f" ;;
    *) die "incompatible state file version: ${STACK_VERSION-?}" ;;
  esac
}

clear_state() {
  rm -f -- "$(state_file)"
}

require_no_state_file() {
  local f
  f=$(state_file)
  [[ -f "$f" ]] && die "stack-rebase in progress ($f); resume with 'git stack continue' ${C_DIM}[gstkcon]${C_RESET} or 'git stack abort' ${C_DIM}[gstkab]${C_RESET} first"
  return 0
}

# Refuse if branch is checked out in a worktree other than the current one.
require_branch_not_in_worktree() {
  local b="$1"
  local current_top in_path cur_branch
  current_top=$(git rev-parse --show-toplevel)
  in_path=""
  cur_branch=""
  while IFS= read -r line; do
    case "$line" in
      "worktree "*) in_path="${line#worktree }"; cur_branch="" ;;
      "branch "*)
        cur_branch="${line#branch }"
        if [[ "$cur_branch" == "refs/heads/$b" ]] && [[ "$in_path" != "$current_top" ]]; then
          die "branch '$b' is checked out in another worktree: $in_path"
        fi
        ;;
    esac
  done < <(git worktree list --porcelain)
}

# ---------- snapshot history ----------

# Write one ref per branch under refs/stack-backup/<prefix>/<unix-ts>-<action>-<pid>/<leaf>.
# Emits a single batch via `git update-ref --stdin` (atomic by default).
#
# Usage: snapshot_stack <action> <prefix> <branch>...
snapshot_stack() {
  # Consume the caller's per-op focus descriptor and clear the global at once, so
  # it never leaks to a later snapshot — even when this one is suppressed below.
  local focus="${_SNAPSHOT_FOCUS:-}"
  _SNAPSHOT_FOCUS=""
  # Callers that already took a covering up-front snapshot (e.g. clean, before it
  # prunes) suppress the redundant inner snapshot a nested reflow would take, so
  # a single `history restore` lands on the one pre-mutation anchor.
  [[ "${_SNAPSHOT_SUPPRESS:-0}" == 1 ]] && return 0
  local action="$1" prefix="$2"
  shift 2
  local prefix_path="${prefix%/}"
  [[ -n "$prefix_path" ]] || return 0
  (( $# > 0 )) || return 0
  local ts run_id stdin n=$#
  ts=$(date +%s)
  run_id="${ts}-${action}-$$"
  stdin=""
  local b sha leaf
  for b in "$@"; do
    sha=$(git rev-parse --verify --quiet "refs/heads/$b") || continue
    leaf="${b##*/}"
    stdin+="create refs/stack-backup/${prefix_path}/${run_id}/${leaf} ${sha}"$'\n'
  done
  [[ -n "$stdin" ]] || return 0
  # Focus metadata: a sibling @meta ref pointing at a blob of key=value lines
  # (a blob, not a ref-path, because a compound clean focus carries spaces/:/→
  # that are illegal in ref names). Same atomic batch as the branch refs, and
  # @meta is filtered everywhere a branch list is read (ADR 0011).
  if [[ -n "$focus" ]]; then
    local blob
    blob=$(printf '%s\n' "$focus" | git hash-object -w --stdin 2>/dev/null) || blob=""
    [[ -n "$blob" ]] && stdin+="create refs/stack-backup/${prefix_path}/${run_id}/@meta ${blob}"$'\n'
  fi
  if printf '%s' "$stdin" | git update-ref --stdin -m "git-stack ${action}" 2>/dev/null; then
    log_v "snapshot ${run_id} (${n} branches)"
  else
    warn "snapshot_stack: failed to write backup refs"
    return 0
  fi
  prune_old_snapshots "$prefix_path"
}

# Drop snapshots older than the most recent N for <prefix>. N comes from
# `git config stack.historyKeep` (default 100). Pass 0 to disable.
prune_old_snapshots() {
  local prefix_path="${1%/}"
  local keep
  keep=$(git config --get stack.historyKeep 2>/dev/null || echo "")
  [[ -z "$keep" ]] && keep=100
  [[ "$keep" =~ ^[0-9]+$ ]] || { warn "stack.historyKeep '$keep' is not a non-negative integer; skipping prune"; return 0; }
  (( keep > 0 )) || return 0

  local victims=() count=0
  while IFS=$'\t' read -r ts action run_id branch_count; do
    [[ -z "$run_id" ]] && continue
    if (( count >= keep )); then
      victims+=("$run_id")
    fi
    count=$((count + 1))
  done < <(list_snapshots "$prefix_path")
  (( ${#victims[@]} > 0 )) || return 0

  local v refname sha stdin=""
  for v in "${victims[@]}"; do
    while IFS=' ' read -r refname sha; do
      [[ -z "$refname" ]] && continue
      stdin+="delete ${refname} ${sha}"$'\n'
    done < <(git for-each-ref --format='%(refname) %(objectname)' "refs/stack-backup/${prefix_path}/${v}/")
  done
  [[ -n "$stdin" ]] || return 0
  if printf '%s' "$stdin" | git update-ref --stdin -m "git-stack auto-prune" 2>/dev/null; then
    log_v "auto-pruned ${#victims[@]} snapshot(s) beyond keep=${keep}"
  fi
}

# Print "ts<TAB>action<TAB>run-id<TAB>count" for each snapshot under <prefix>,
# newest first. Run-id is the segment between prefix and leaf.
list_snapshots() {
  local prefix_path="${1%/}"
  local strip="refs/stack-backup/${prefix_path}/"
  git for-each-ref --format='%(refname)' "$strip" 2>/dev/null \
    | awk -v strip="$strip" '
        {
          if (index($0, strip) == 1) {
            rest = substr($0, length(strip) + 1)
            n = split(rest, parts, "/")
            if (parts[2] == "@meta") next
            run_id = parts[1]
            count[run_id]++
          }
        }
        END {
          for (r in count) {
            split(r, p, "-")
            printf "%s\t%s\t%s\t%d\n", p[1], p[2], r, count[r]
          }
        }
      ' \
    | sort -rn
}

# Emit "leaf<TAB>sha" for each branch in <prefix>/<run-id> snapshot.
snapshot_branches_for() {
  local prefix_path="${1%/}"
  local run_id="$2"
  local strip="refs/stack-backup/${prefix_path}/${run_id}/"
  git for-each-ref --format='%(refname) %(objectname)' "$strip" 2>/dev/null \
    | awk -v strip="$strip" '
        {
          if (index($1, strip) == 1) {
            leaf = substr($1, length(strip) + 1)
            if (leaf == "@meta") next
            printf "%s\t%s\n", leaf, $2
          }
        }
      '
}

# Print the raw key=value focus descriptor stored for <run-id>, or nothing.
snapshot_focus_for() {
  local prefix_path="${1%/}" run_id="$2"
  local blob
  blob=$(git rev-parse --verify --quiet "refs/stack-backup/${prefix_path}/${run_id}/@meta" 2>/dev/null) \
    || return 0
  git cat-file blob "$blob" 2>/dev/null
}

# _kv_get <kv-text> <key> : first value for <key>, or empty.
_kv_get() {
  printf '%s\n' "$1" | sed -n "s/^${2}=//p" | head -1
}

# Render a one-line focus token from an action and its key=value descriptor.
# Empty when the descriptor is missing or an expected key is absent — callers
# substitute an em dash. Glyphs: + add, − drop, ← fold (result←victim),
# → move (leaf→pos). See ADR 0011 for the per-verb schema.
_render_focus() {
  local action="$1" kv="$2"
  [[ -n "$kv" ]] || return 0
  local leaf pos result victim pruned base from onto repaired segs
  case "$action" in
    amend|create)
      _kv_get "$kv" leaf ;;
    add)
      leaf=$(_kv_get "$kv" leaf); [[ -n "$leaf" ]] && printf '+%s' "$leaf" ;;
    drop)
      leaf=$(_kv_get "$kv" leaf); [[ -n "$leaf" ]] && printf '−%s' "$leaf" ;;
    move)
      leaf=$(_kv_get "$kv" leaf); pos=$(_kv_get "$kv" pos)
      if [[ -n "$leaf" && -n "$pos" ]]; then printf '%s→%s' "$leaf" "$pos"
      else printf '%s' "$leaf"; fi ;;
    fold)
      result=$(_kv_get "$kv" result); victim=$(_kv_get "$kv" victim)
      if [[ -n "$result" && -n "$victim" ]]; then printf '%s←%s' "$result" "$victim"
      else printf '%s' "$result"; fi ;;
    restack)
      onto=$(_kv_get "$kv" onto); from=$(_kv_get "$kv" from)
      if [[ -n "$onto" ]]; then printf 'onto:%s' "$onto"
      elif [[ -n "$from" ]]; then printf 'from:%s' "$from"; fi ;;
    clean)
      pruned=$(_kv_get "$kv" pruned); base=$(_kv_get "$kv" base); from=$(_kv_get "$kv" from)
      segs=""
      [[ -n "$pruned" ]] && segs="pruned:${pruned}"
      if [[ -n "$base" ]]; then segs="${segs:+$segs }base→${base}"
      elif [[ -n "$from" ]]; then segs="${segs:+$segs }from:${from}"; fi
      printf '%s' "$segs" ;;
    doctor|doctor-reflow)
      repaired=$(_kv_get "$kv" repaired); [[ -n "$repaired" ]] && printf 'repaired:%s' "$repaired" ;;
  esac
  # A missing/partial key leaves a branch's last command non-zero; never let that
  # abort the caller under `set -e` — an empty render falls back to an em dash.
  return 0
}

# Resolve user-supplied id (full, action-tagged, bare ts, or @N) to canonical
# run-id, or die if missing/ambiguous.
parse_run_id() {
  local prefix_path="${1%/}"
  local input="$2"
  local all=()
  while IFS=$'\t' read -r ts action run_id count; do
    [[ -n "$run_id" ]] && all+=("$run_id")
  done < <(list_snapshots "$prefix_path")

  if [[ "$input" =~ ^@([0-9]+)$ ]]; then
    local n="${BASH_REMATCH[1]}"
    (( n < ${#all[@]} )) || die "no snapshot @${n} (have ${#all[@]} snapshot(s))"
    printf '%s\n' "${all[$n]}"
    return 0
  fi

  local r matches=()
  for r in "${all[@]}"; do
    if [[ "$r" == "$input" ]] || [[ "$r" == "${input}-"* ]]; then
      matches+=("$r")
    fi
  done
  case "${#matches[@]}" in
    0) die "no snapshot matching '${input}' (try 'git stack history' ${C_DIM}[gstkh]${C_RESET})" ;;
    1) printf '%s\n' "${matches[0]}" ;;
    *) local m str="" ; for m in "${matches[@]}"; do str="${str:+${str}, }$m"; done
       die "ambiguous '${input}' matches: $str" ;;
  esac
}

# ---------- rename ----------

# Build an atomic `git update-ref --stdin` script that renames every
# refs/heads/<old>/<leaf> to refs/heads/<new>/<leaf>, optionally also moving
# refs/stack-backup/<old>/... to refs/stack-backup/<new>/.... Does NOT touch
# HEAD — caller updates HEAD's symref via `git symbolic-ref` before running
# this batch (so the to-be-deleted old branch is no longer HEAD's target).
emit_rename_batch() {
  local old_pfx="${1%/}"
  local new_pfx="${2%/}"
  local move_history="${3:-1}"

  local refname sha leaf
  while IFS=' ' read -r refname sha; do
    [[ -z "$refname" ]] && continue
    leaf="${refname#refs/heads/${old_pfx}/}"
    printf 'create refs/heads/%s/%s %s\n' "$new_pfx" "$leaf" "$sha"
    printf 'delete %s %s\n' "$refname" "$sha"
  done < <(git for-each-ref --format='%(refname) %(objectname)' "refs/heads/${old_pfx}/")

  if (( move_history )); then
    local rest
    while IFS=' ' read -r refname sha; do
      [[ -z "$refname" ]] && continue
      rest="${refname#refs/stack-backup/${old_pfx}/}"
      printf 'create refs/stack-backup/%s/%s %s\n' "$new_pfx" "$rest" "$sha"
      printf 'delete %s %s\n' "$refname" "$sha"
    done < <(git for-each-ref --format='%(refname) %(objectname)' "refs/stack-backup/${old_pfx}/")
  fi
}

# ---------- reflow engine ----------

# Pure position-advancement dispatch for the reflow engine. Given the plan's
# phase count, the current (phase, unit) position, and the outcome of advancing
# one unit, decide the next position and a directive. No git, no state file —
# the phase reports its own outcome; the engine only moves the cursor.
#
# Outcomes:  unit-done | phase-complete | paused
# Directives: advance (next unit, same phase) | next-phase | done | paused
# Usage: _engine_next <num_phases> <phase_idx> <unit_idx> <outcome>
# Prints: "<directive>\t<phase_idx>\t<unit_idx>"
_engine_next() {
  local num_phases="$1" phase_idx="$2" unit_idx="$3" outcome="$4"
  case "$outcome" in
    unit-done)
      printf '%s\t%d\t%d\n' advance "$phase_idx" "$((unit_idx + 1))" ;;
    phase-complete)
      if (( phase_idx + 1 < num_phases )); then
        printf '%s\t%d\t%d\n' next-phase "$((phase_idx + 1))" 0
      else
        printf '%s\t%d\t%d\n' done "$phase_idx" "$unit_idx"
      fi ;;
    paused)
      printf '%s\t%d\t%d\n' paused "$phase_idx" "$unit_idx" ;;
    *)
      return 2 ;;
  esac
}

# Persist engine state (STACK_VERSION=2): the phase list and the coarse
# (phase, unit) cursor. Written on every step boundary so continue/abort resume.
save_engine_state() {
  local out
  out=$(state_file)
  {
    echo "STACK_VERSION=2"
    printf 'STACK_STARTED_AT=%q\n'      "$STACK_STARTED_AT"
    printf 'STACK_STARTING_BRANCH=%q\n' "$STACK_STARTING_BRANCH"
    printf 'STACK_PREFIX=%q\n'          "$STACK_PREFIX"
    printf 'STACK_PUSH=%d\n'            "$STACK_PUSH"
    printf 'STACK_FORCE=%d\n'           "$STACK_FORCE"
    printf 'STACK_ONTO=%q\n'            "$STACK_ONTO"
    printf 'STACK_ONTO_REF=%q\n'        "$STACK_ONTO_REF"
    printf 'STACK_FROM_IDX=%d\n'        "$STACK_FROM_IDX"
    _emit_array STACK_PHASES STACK_PHASES
    printf 'STACK_PHASE_IDX=%d\n'       "$STACK_PHASE_IDX"
    printf 'STACK_UNIT_IDX=%d\n'        "$STACK_UNIT_IDX"
    printf 'STACK_OPT_NO_PUSH=%d\n'     "$STACK_OPT_NO_PUSH"
    printf 'STACK_OPT_NO_SYNC=%d\n'     "$STACK_OPT_NO_SYNC"
    printf 'STACK_FOLD_VICTIM=%q\n'        "$STACK_FOLD_VICTIM"
    printf 'STACK_FOLD_SURVIVOR_NEW=%q\n'  "$STACK_FOLD_SURVIVOR_NEW"
    _emit_array STACK_BRANCHES STACK_BRANCHES
    _emit_array STACK_ORIG_SHAS STACK_ORIG_SHAS
    _emit_array STACK_PUSH_FAILURES STACK_PUSH_FAILURES
    _emit_array STACK_RENAME_PAIRS STACK_RENAME_PAIRS
    _emit_array STACK_SAFE_DROP STACK_SAFE_DROP
  } > "$out"
}

# Print the cherry-pick conflict banner (branch + conflicted files + the
# continue/abort hint) to stderr. Used by the reflow-pick phase on conflict.
_print_conflict_banner() {
  local branch="$1"
  printf '\n%s%s: conflict%s on %s%s%s\n\n' \
    "$C_RED" "$PROG" "$C_RESET" \
    "$C_CYAN" "$branch" "$C_RESET" >&2
  local cf chunks s
  while IFS= read -r cf; do
    [[ -z "$cf" ]] && continue
    chunks=$(grep -c '^<<<<<<< ' "$cf" 2>/dev/null || echo "?")
    if [[ "$chunks" == "1" ]]; then s="chunk"; else s="chunks"; fi
    printf '  %s%s%s %s(%s %s)%s\n' \
      "$C_YELLOW" "$cf" "$C_RESET" \
      "$C_DIM" "$chunks" "$s" "$C_RESET" >&2
  done < <(git diff --name-only --diff-filter=U 2>/dev/null)
  printf '\n' >&2
  printf '  resolve + resume: %sgit stack continue%s %s[gstkcon]%s\n' "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET" >&2
  printf '  give up:          %sgit stack abort%s %s[gstkab]%s\n'    "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET" >&2
}

# ----- reflow-pick phase -----
# A unit is one branch. The absolute branch index is STACK_FROM_IDX + unit. The
# advance/resume ops wrap do_one_step (the cherry-pick is unchanged); abort
# restores original SHAs. Each op sets _PHASE_OUTCOME.

# Map a phase-relative unit index to its absolute STACK_BRANCHES index.
_reflow_pick_abs() { echo "$((STACK_FROM_IDX + $1))"; }

# Print the resume/abort footer after a push failure pauses the reflow.
# push_branch already printed the failure detail and the fetch/force hints.
_print_push_pause_banner() {
  local branch="$1"
  printf '\n%s%s: push paused%s on %s%s%s\n' \
    "$C_YELLOW" "$PROG" "$C_RESET" "$C_CYAN" "$branch" "$C_RESET" >&2
  printf '  fetch/rebase, then resume: %sgit stack continue%s %s[gstkcon]%s\n' "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET" >&2
  printf '  give up:                   %sgit stack abort%s %s[gstkab]%s\n'    "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET" >&2
}

# Finish a reflowed unit: push it (if --push) and set the outcome. A push
# failure pauses (resumable) rather than failing the whole run — the
# cherry-pick is already done, so 'continue' re-enters resume, skips the
# cherry-pick, and retries the push.
_reflow_pick_complete_unit() {
  local abs="$1"
  local last=$((${#STACK_BRANCHES[@]} - 1))
  if (( STACK_PUSH )); then
    if ! push_branch "${STACK_BRANCHES[$abs]}"; then
      _print_push_pause_banner "${STACK_BRANCHES[$abs]}"
      _PHASE_OUTCOME=paused
      return 0
    fi
  fi
  if (( abs >= last )); then
    _PHASE_OUTCOME=phase-complete
  else
    _PHASE_OUTCOME=unit-done
  fi
}

_phase_reflow_pick_advance() {
  local unit="$1"
  local abs rc=0
  abs=$(_reflow_pick_abs "$unit")
  do_one_step "$abs" || rc=$?
  if (( rc == 2 )); then
    _print_conflict_banner "${STACK_BRANCHES[$abs]}"
    _PHASE_OUTCOME=paused
    return 0
  fi
  _reflow_pick_complete_unit "$abs"
}

_phase_reflow_pick_resume() {
  local unit="$1"
  local abs
  abs=$(_reflow_pick_abs "$unit")

  local gitdir marker
  gitdir=$(git rev-parse --git-dir)
  for marker in MERGE_HEAD REVERT_HEAD rebase-merge rebase-apply; do
    if [[ -e "$gitdir/$marker" ]]; then
      die "another git operation is in progress ($marker); resolve it first"
    fi
  done
  if [[ -e "$gitdir/CHERRY_PICK_HEAD" ]]; then
    if [[ -n $(git ls-files --unmerged) ]]; then
      die "cherry-pick has unresolved conflicts; fix them and 'git add' the files, then re-run"
    fi
    log "${C_DIM}continue${C_RESET} finishing in-progress cherry-pick"
    GIT_EDITOR=true git cherry-pick --continue \
      || die "git cherry-pick --continue failed; resolve manually and re-run"
  fi
  _reflow_pick_complete_unit "$abs"
}

_phase_reflow_pick_abort() {
  local i b sha short
  for ((i = 0; i < ${#STACK_BRANCHES[@]}; i++)); do
    b="${STACK_BRANCHES[$i]}"
    sha="${STACK_ORIG_SHAS[$i]}"
    [[ -n "$sha" ]] || continue
    short="${sha:0:10}"
    log "  ${C_DIM}restore${C_RESET} ${C_CYAN}$b${C_RESET} ${C_DIM}-> $short${C_RESET}"
    git update-ref "refs/heads/$b" "$sha"
  done
  if [[ -e "$(git rev-parse --git-dir)/CHERRY_PICK_HEAD" ]]; then
    git cherry-pick --abort 2>/dev/null || true
  fi
  if (( STACK_PUSH )); then
    local pushed=() j
    for ((j = STACK_FROM_IDX; j < STACK_FROM_IDX + STACK_UNIT_IDX; j++)); do
      pushed+=("${STACK_BRANCHES[$j]}")
    done
    if (( ${#pushed[@]} > 0 )); then
      warn "the following branches were already force-pushed; remote not undone:"
      for b in "${pushed[@]}"; do warn "  $b"; done
    fi
  fi
}

# ----- rename-batch phase -----
# One atomic local ref rename of STACK_RENAME_PAIRS (old/new alternating).
# Reads each branch's current SHA at apply time (post-reflow), updates HEAD's
# symref off any to-be-deleted ref, and renames via an atomic update-ref batch.
# Atomic, so it never pauses; resume re-applies (idempotent at the ref level).

# Apply an atomic local rename batch. Args: <reflog-msg> <old1> <new1> ...
# Moves HEAD's symref if it points at a renamed branch (you cannot delete the
# ref HEAD targets). Dies (restoring HEAD) if the atomic batch fails.
_apply_local_rename_batch() {
  local msg="$1"; shift
  (( $# >= 2 )) || return 0
  local batch="" old new sha i
  local pairs=("$@")
  for ((i = 0; i < ${#pairs[@]}; i += 2)); do
    old="${pairs[$i]}"
    new="${pairs[$((i + 1))]}"
    sha=$(git rev-parse "refs/heads/$old")
    batch+="create refs/heads/${new} ${sha}"$'\n'
    batch+="delete refs/heads/${old} ${sha}"$'\n'
  done
  local head_before="" head_new=""
  if head_before=$(git symbolic-ref --quiet HEAD 2>/dev/null); then
    for ((i = 0; i < ${#pairs[@]}; i += 2)); do
      if [[ "$head_before" == "refs/heads/${pairs[$i]}" ]]; then
        head_new="refs/heads/${pairs[$((i + 1))]}"
        git symbolic-ref HEAD "$head_new"
        break
      fi
    done
  fi
  if ! printf '%s' "$batch" | git update-ref --stdin -m "$msg"; then
    [[ -n "$head_new" ]] && git symbolic-ref HEAD "$head_before" 2>/dev/null || true
    die "git update-ref batch failed; refs unchanged (atomic)"
  fi
}

_phase_rename_batch_advance() {
  local pairs=("${STACK_RENAME_PAIRS[@]+"${STACK_RENAME_PAIRS[@]}"}")
  if (( ${#pairs[@]} > 0 )); then
    _apply_local_rename_batch "git-stack move (post-rename)" "${pairs[@]}"
    log "${C_GREEN}done${C_RESET}    move complete (+$((${#pairs[@]} / 2)) renames)"
    # Track the user's branch across the rename so _engine_finalize returns to
    # it under its new name.
    local i
    for ((i = 0; i < ${#pairs[@]}; i += 2)); do
      if [[ "$STACK_STARTING_BRANCH" == "${pairs[$i]}" ]]; then
        STACK_STARTING_BRANCH="${pairs[$((i + 1))]}"
        break
      fi
    done
  fi
  _PHASE_OUTCOME=phase-complete
}

# Resume == advance: the rename is atomic, so on re-run it either was never
# applied (re-apply) or fully applied (the renamed refs already exist and the
# old names are gone, so a re-run would no-op/skip — but in practice a paused
# state is never persisted mid-rename, so resume just re-applies cleanly).
_phase_rename_batch_resume() { _phase_rename_batch_advance "$@"; }

# Reverse the local rename (new -> old). Reachable only via crash-recovery
# (the phase never pauses), so it is best-effort.
_phase_rename_batch_abort() {
  local pairs=("${STACK_RENAME_PAIRS[@]+"${STACK_RENAME_PAIRS[@]}"}")
  (( ${#pairs[@]} > 0 )) || return 0
  local rev=() i
  for ((i = 0; i < ${#pairs[@]}; i += 2)); do
    # Only reverse pairs whose "new" ref actually exists (rename did apply).
    if git rev-parse --verify --quiet "refs/heads/${pairs[$((i + 1))]}" >/dev/null; then
      rev+=("${pairs[$((i + 1))]}" "${pairs[$i]}")
    fi
  done
  (( ${#rev[@]} > 0 )) && _apply_local_rename_batch "git-stack abort (undo rename)" "${rev[@]}"
}

# ----- remote-sync phase -----
# Remote branch renames (for any pushed pairs) followed by PR sync. Idempotent;
# gated by --no-push (the phase is only added to the plan when push is enabled).
# Same code path #2's pr-sync apply and doctor's rename tail reuse.

_phase_remote_sync_advance() {
  OPT_NO_PUSH="$STACK_OPT_NO_PUSH"
  OPT_NO_SYNC="$STACK_OPT_NO_SYNC"
  local pairs=("${STACK_RENAME_PAIRS[@]+"${STACK_RENAME_PAIRS[@]}"}")
  if (( ! OPT_NO_PUSH )) && (( ${#pairs[@]} > 0 )); then
    _remote_rename_batch_or_skip "${pairs[@]}"
  fi
  # Fold: capture the victim's PR number, delete its remote branch (closing the
  # PR), then — after pr sync mints the superseding PR — leave a breadcrumb.
  local fold_pr=""
  if (( ! OPT_NO_PUSH )) && [[ -n "$STACK_FOLD_VICTIM" ]]; then
    fold_pr=$(_fold_remote_drop_victim "$STACK_FOLD_VICTIM")
  fi
  if (( ! OPT_NO_PUSH )); then
    _post_rename_sync "$STACK_PREFIX"
  fi
  if (( ! OPT_NO_PUSH )) && [[ -n "$STACK_FOLD_VICTIM" && -n "$fold_pr" ]]; then
    _fold_breadcrumb "$fold_pr" "$STACK_FOLD_SURVIVOR_NEW"
  fi
  _PHASE_OUTCOME=phase-complete
}

# Resume == advance: PR sync is idempotent.
_phase_remote_sync_resume() { _phase_remote_sync_advance "$@"; }

# Remote effects cannot be safely auto-undone; warn only.
_phase_remote_sync_abort() {
  warn "remote rename/PR sync already applied; not undone by abort. Reconcile with 'git stack pr sync' ${C_DIM}[gstkprs]${C_RESET}."
}

# ----- phase dispatch -----

_phase_advance() {
  case "$1" in
    reflow-pick)  _phase_reflow_pick_advance "$2" ;;
    rename-batch) _phase_rename_batch_advance "$2" ;;
    remote-sync)  _phase_remote_sync_advance "$2" ;;
    *) die "internal: unknown phase type '$1'" ;;
  esac
}

_phase_resume() {
  case "$1" in
    reflow-pick)  _phase_reflow_pick_resume "$2" ;;
    rename-batch) _phase_rename_batch_resume "$2" ;;
    remote-sync)  _phase_remote_sync_resume "$2" ;;
    *) die "internal: unknown phase type '$1'" ;;
  esac
}

_phase_abort() {
  case "$1" in
    reflow-pick)  _phase_reflow_pick_abort ;;
    rename-batch) _phase_rename_batch_abort ;;
    remote-sync)  _phase_remote_sync_abort ;;
    *) die "internal: unknown phase type '$1'" ;;
  esac
}

# ----- engine driver -----

# Drive the plan from the current (STACK_PHASE_IDX, STACK_UNIT_IDX) position to
# completion or pause, persisting after each step. Pass "resume" to finish an
# in-flight unit first (continue); the default advances a fresh unit (restack).
# Exits 2 on a paused conflict (state retained); calls _engine_finalize on done.
_engine_run() {
  local mode="${1:-advance}"
  local num_phases=${#STACK_PHASES[@]}
  local directive np nu
  while :; do
    if [[ "$mode" == resume ]]; then
      _phase_resume "${STACK_PHASES[$STACK_PHASE_IDX]}" "$STACK_UNIT_IDX"
      mode=advance
    else
      _phase_advance "${STACK_PHASES[$STACK_PHASE_IDX]}" "$STACK_UNIT_IDX"
    fi
    IFS=$'\t' read -r directive np nu \
      < <(_engine_next "$num_phases" "$STACK_PHASE_IDX" "$STACK_UNIT_IDX" "$_PHASE_OUTCOME")
    STACK_PHASE_IDX="$np"
    STACK_UNIT_IDX="$nu"
    case "$directive" in
      advance|next-phase) save_engine_state ;;
      paused)             save_engine_state; exit 2 ;;
      done)               _engine_finalize; return 0 ;;
    esac
  done
}

# Best-effort abort: undo executed phases in reverse order, return to the
# starting branch, and clear resume state.
_engine_abort() {
  log "${C_YELLOW}abort${C_RESET}   restoring branches to original SHAs"
  local p
  for ((p = STACK_PHASE_IDX; p >= 0; p--)); do
    _phase_abort "${STACK_PHASES[$p]}"
  done
  if [[ -n "${STACK_STARTING_BRANCH-}" ]] && \
     git rev-parse --verify --quiet "refs/heads/$STACK_STARTING_BRANCH" >/dev/null; then
    git checkout --quiet "$STACK_STARTING_BRANCH"
  fi
  clear_state
}

# Finish a fully-completed plan: return to the starting branch and clear resume
# state. A reflow push failure never reaches here — it pauses the plan instead
# (see _reflow_pick_complete_unit), so on completion every push has succeeded.
_engine_finalize() {
  if [[ -n "$STACK_STARTING_BRANCH" ]] && \
     git rev-parse --verify --quiet "refs/heads/$STACK_STARTING_BRANCH" >/dev/null; then
    git checkout --quiet "$STACK_STARTING_BRANCH"
  fi
  # Tailor the completion line to what the plan actually did: a reflow reports
  # the branch count; a remote-only plan (rename / doctor renumber tail) didn't
  # restack anything, so don't claim it did.
  local p saw_reflow=0
  for p in "${STACK_PHASES[@]+"${STACK_PHASES[@]}"}"; do
    [[ "$p" == reflow-pick ]] && { saw_reflow=1; break; }
  done
  if (( saw_reflow )); then
    local n_processed=$(( ${#STACK_BRANCHES[@]} - STACK_FROM_IDX ))
    log "${C_GREEN}done${C_RESET}    reflow complete (${C_BOLD}${n_processed}${C_RESET} branches restacked)"
  else
    log "${C_GREEN}done${C_RESET}    remote sync complete"
  fi
  clear_state
}

# ---------- core ----------

# Reflow the branch at index $1.
# Return 0 on success, 2 on cherry-pick conflict.
# Decide whether a tip-only cherry-pick of <head> drops only safe commits.
# <anchor> is <head>'s ORIGINAL predecessor tip (pre-reflow): everything between
# it and <head>, minus <head>'s own tip, is the work that would be dropped.
# `--not <safe-drop tips>` removes the commits the caller proved merged AND their
# ancestors — so a survivor that threads only just-pruned branches collapses to
# exactly its tip. Safe iff nothing but the tip remains. Anchoring on the
# *original* predecessor (not the restacked one) keeps this immune to patch
# changes from conflict resolution. With no safe-drop tips, any extra commit is
# unsafe (the empty set never auto-resolves). Returns 0 if safe, 1 otherwise.
_reflow_own_only() {
  local anchor="$1" head="$2"; shift 2
  local head_sha leftover
  head_sha=$(git rev-parse "$head" 2>/dev/null) || return 1
  if (( $# > 0 )); then
    leftover=$(git rev-list "${anchor}..${head}" --not "$@" 2>/dev/null)
  else
    leftover=$(git rev-list "${anchor}..${head}" 2>/dev/null)
  fi
  [[ "$leftover" == "$head_sha" ]]
}

do_one_step() {
  local cursor=$1
  local B="${STACK_BRANCHES[$cursor]}"
  local prev_new prev_label prev_ref B_orig
  # Default to empty: the --onto bottom branch has no in-stack predecessor, so
  # this stays unset. A bare `local prev_orig` would be empty under bash 3.2
  # (macOS) but truly unset under bash 4.4+ (Linux), tripping `set -u` at the
  # read below — hence the explicit "".
  local prev_orig=""
  if (( cursor == STACK_FROM_IDX )) && [[ -n "$STACK_ONTO" ]]; then
    prev_new="$STACK_ONTO"
    prev_label="${STACK_ONTO_REF:-$STACK_ONTO}"
    prev_ref="$STACK_ONTO"
  else
    local P="${STACK_BRANCHES[$((cursor - 1))]}"
    prev_new=$(git rev-parse "refs/heads/$P")
    prev_label="$P"
    prev_ref="refs/heads/$P"
    prev_orig="${STACK_ORIG_SHAS[$((cursor - 1))]}"
  fi
  B_orig=$(orig_sha_for "$B") || die "no orig SHA recorded for $B"

  # Empty-branch fast-path. A branch created on top of its predecessor with no
  # commit of its own shares the predecessor's tip, so at run start its original
  # SHA equals the predecessor's original SHA. Once the predecessor moves, the
  # cherry-pick below would replay the predecessor's *original* commit — already
  # contained in the new head — and stall on an empty pick (a spurious conflict).
  # Detect that here and just fast-forward the empty branch onto the predecessor's
  # new head. When the predecessor didn't move, B_orig == prev_new and the skip
  # further down handles it; the --onto bottom branch has no in-stack predecessor
  # so prev_orig is empty and we fall through. This must precede the multi-commit
  # guard, whose count diff can false-positive on an empty branch when the
  # predecessor is rebased onto a shorter base.
  if [[ -n "$prev_orig" && "$B_orig" == "$prev_orig" ]]; then
    log "${C_GREEN}restack${C_RESET} ${C_CYAN}$B${C_RESET} ${C_DIM}onto${C_RESET} ${C_CYAN}$prev_label${C_RESET} ${C_DIM}(empty branch)${C_RESET}"
    git checkout --quiet "$B"
    git reset --hard --quiet "$prev_new"
    return 0
  fi

  # Multi-commit guard. The cherry-pick below replays only B_orig (the tip),
  # so a branch with multiple commits relative to its predecessor would
  # silently lose all but the tip. We compare reachable-commit counts (not
  # `prev..B`) because plain two-dot ranges inflate when the predecessor
  # has been amended — old commits still in B's history but no longer in
  # the predecessor's would falsely register as "extra B commits". The
  # count-diff is correct for the standard linear-stack shape; multi-DAG
  # histories can yield surprising diffs but are out of scope for this
  # tool's single-commit-per-branch model. Refuse unless --force.
  local count_prev count_b n_commits
  count_prev=$(git rev-list --count "$prev_ref" 2>/dev/null || echo 0)
  count_b=$(git rev-list --count "$B_orig" 2>/dev/null || echo 0)
  n_commits=$((count_b - count_prev))
  if (( n_commits > 1 )) && (( ! STACK_FORCE )); then
    # Auto-resolve the proven-merged case before refusing. B's "own" commits are
    # those above its ORIGINAL predecessor (prev_orig in-stack, or the fork point
    # with the onto-base); everything else it threads is predecessor territory
    # the reflow supersedes. If, after excluding the just-pruned merged branches
    # (STACK_SAFE_DROP), B has only its tip left, tip-only is safe.
    local own_base
    if [[ -n "$prev_orig" ]]; then
      own_base="$prev_orig"
    else
      own_base=$(git merge-base "$B_orig" "$prev_new" 2>/dev/null || echo "")
    fi
    if [[ -n "$own_base" ]] && _reflow_own_only "$own_base" "$B_orig" ${STACK_SAFE_DROP[@]+"${STACK_SAFE_DROP[@]}"}; then
      log "${C_YELLOW}absorb${C_RESET}  ${C_CYAN}$B${C_RESET} ${C_DIM}tip-only restack, dropping $((n_commits - 1)) superseded commit(s)${C_RESET}"
    else
      die "branch '$B' has $n_commits commit(s) beyond its predecessor; restack would drop all but the tip. Squash/rebase '$B' to a single commit and retry, or pass --force to cherry-pick the tip and deliberately drop them."
    fi
  fi

  # Skip when B's tip already equals the new predecessor head — nothing to
  # cherry-pick. Sound under the single-commit assumption enforced above
  # (or knowingly waived via --force).
  if [[ "$B_orig" == "$prev_new" ]]; then
    log "${C_DIM}skip${C_RESET} ${C_CYAN}$B${C_RESET} (already equals ${C_CYAN}$prev_label${C_RESET})"
    return 0
  fi

  # Refuse merge commits explicitly. The single-commit-per-branch model assumes
  # B_orig is a regular commit cherry-pickable onto the new predecessor; merge
  # commits aren't, and `git cherry-pick` fails with a cryptic "is a merge but
  # no -m option was given" message. We don't auto-pick `-m 1` because the
  # correct mainline is ambiguous and silent wrongness is worse than a refusal.
  # The multi-commit count guard catches most of these earlier, but --force
  # bypasses it — this check stays sound under --force.
  if git rev-parse --verify --quiet "${B_orig}^2" >/dev/null 2>&1; then
    die "branch '$B' tip ($(git rev-parse --short "$B_orig")) is a merge commit; restack expects single-commit branches. Squash or rebase the merge into a linear commit, then retry. Use 'git stack abort' ${C_DIM}[gstkab]${C_RESET} to roll back this in-flight restack."
  fi

  log "${C_GREEN}restack${C_RESET} ${C_CYAN}$B${C_RESET} ${C_DIM}onto${C_RESET} ${C_CYAN}$prev_label${C_RESET}"
  git checkout --quiet "$B"
  git reset --hard --quiet "$prev_new"
  local cp_out cp_rc=0
  cp_out=$(git cherry-pick "$B_orig" 2>&1) || cp_rc=$?
  if (( cp_rc != 0 )); then
    # Empty-pick self-heal. The pick can come up empty when B_orig's patch is
    # already contained in the new predecessor — e.g. a message-only amend of
    # the predecessor (the upfront empty-branch check can't see this: cmd_amend
    # rewrites the predecessor before run-start, so the recorded orig SHAs no
    # longer match), or a commit that already landed upstream. git then pauses
    # mid-pick with a clean tree. That's a no-op, not a conflict: HEAD already
    # sits at prev_new, the desired result — so skip it and resume the reflow.
    # The guards below exclude every kind of real conflict: a content conflict
    # dirties the worktree; a staged-but-uncommitted state (hook/sign failure)
    # fails the cached check; a delete/modify or mode conflict leaves unmerged
    # entries. Only a genuinely empty pick satisfies all four.
    if git rev-parse -q --verify CHERRY_PICK_HEAD >/dev/null 2>&1 \
       && git diff --quiet 2>/dev/null \
       && git diff --cached --quiet 2>/dev/null \
       && [[ -z "$(git ls-files --unmerged)" ]]; then
      git cherry-pick --skip >/dev/null 2>&1 || git cherry-pick --quit >/dev/null 2>&1 || true
      log "${C_DIM}skip${C_RESET} ${C_CYAN}$B${C_RESET} ${C_DIM}(no change after restack onto ${C_CYAN}$prev_label${C_RESET}${C_DIM})${C_RESET}"
      return 0
    fi
    if [[ -n "$cp_out" ]]; then
      if [[ -n "$C_DIM" ]]; then
        printf '%s%s%s\n' "$C_DIM" "$cp_out" "$C_RESET" >&2
      else
        printf '%s\n' "$cp_out" >&2
      fi
    fi
    return 2
  fi
  return 0
}

push_branch() {
  local b="$1" sha short rt err
  sha=$(git rev-parse --verify --quiet "refs/heads/$b" 2>/dev/null) || return 0
  short=$(git rev-parse --short "refs/heads/$b")
  local remote_sha
  remote_sha=$(git rev-parse --verify --quiet "refs/remotes/origin/$b" 2>/dev/null || true)
  if [[ -n "$remote_sha" && "$remote_sha" == "$sha" ]]; then
    log "${C_DIM}skip${C_RESET}    ${C_CYAN}$b${C_RESET} ${C_DIM}(already synced)${C_RESET}"
    return 0
  fi
  log "${C_BLUE}push${C_RESET}    ${C_CYAN}$b${C_RESET} ${C_DIM}($short, --force-with-lease)${C_RESET}"
  err=$(git push --force-with-lease -u origin "refs/heads/$b:refs/heads/$b" 2>&1) && {
    log_v "$err"
    return 0
  }
  printf '%s' "$err" >&2
  warn "push failed for $b"
  rt=$(git rev-parse --short --quiet "refs/remotes/origin/$b" 2>/dev/null || echo "<not tracked>")
  printf '          %slocal:%s           %s\n'        "$C_DIM" "$C_RESET" "$short" >&2
  printf '          %sremote-tracking:%s %s%s\n'      "$C_DIM" "$C_RESET" "$rt" \
    "$([ "$rt" = "<not tracked>" ] && echo " (run 'git fetch origin $b')" || echo "")" >&2
  printf '          %shint:%s            git fetch origin %s   # refresh, then retry\n' \
    "$C_DIM" "$C_RESET" "$b" >&2
  printf '          %s                 %s git push --force origin %s   # bypass lease\n' \
    "$C_DIM" "$C_RESET" "$b" >&2
  STACK_PUSH_FAILURES+=("$b")
  return 1
}

# ---------- PR sync helpers ----------

# Verify gh CLI is installed, authenticated for github.com, and a GitHub
# remote exists. On success, GH_REPO is set to "<owner>/<repo>" for use by
# all subsequent gh invocations as --repo "$GH_REPO".
GH_REPO=""
_gh_preflight() {
  command -v gh >/dev/null 2>&1 \
    || die "gh not found; install from https://cli.github.com/"
  gh auth status -h github.com >/dev/null 2>&1 \
    || die "gh not authenticated for github.com (run: gh auth login)"
  GH_REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) \
    || die "no GitHub remote detected (run from a repo with a github.com remote)"
  [[ -n "$GH_REPO" ]] || die "gh repo view returned empty nameWithOwner"
}

# Rename a single remote branch via gh's branches/rename endpoint. PRs that
# point at <old> are automatically retargeted by GitHub to <new>.
# Args: <old-branch-name> <new-branch-name>
# Caller must have already invoked _gh_preflight (so GH_REPO is set).
# Returns 0 on success; non-zero on API failure (caller dies).
_remote_rename_one() {
  local old="$1" new="$2"
  # URL-encode the branch name's slashes (the only special character in our
  # naming convention).
  local old_enc="${old//\//%2F}"
  local out rc
  out=$(gh api -X POST "/repos/${GH_REPO}/branches/${old_enc}/rename" \
          -f "new_name=${new}" 2>&1) || rc=$?
  if (( ${rc:-0} != 0 )); then
    printf '%s\n' "$out" >&2
    return 1
  fi
  log_v "remote rename: $old -> $new"
}

# Rename remote refs for each (old, new) pair where origin/<old> exists.
# If gh isn't available or the remote isn't GitHub, silently skip the whole
# batch with a single warning. On per-call failure, hard-errors (caller's
# trap restores nothing — the local rename has already happened).
# Args: <old1> <new1> <old2> <new2> ...
_remote_rename_batch_or_skip() {
  (( $# % 2 == 0 )) || die "internal: _remote_rename_batch_or_skip got odd argc"
  (( $# == 0 )) && return 0
  if ! command -v gh >/dev/null 2>&1; then
    warn "gh not installed; skipping remote rename. PRs may orphan if branches were pushed."
    return 0
  fi
  if ! gh auth status -h github.com >/dev/null 2>&1; then
    warn "gh not authenticated for github.com; skipping remote rename."
    return 0
  fi
  if ! GH_REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null); then
    warn "no GitHub remote detected; skipping remote rename."
    return 0
  fi
  local old new news=()
  while (( $# >= 2 )); do
    old="$1"; new="$2"; shift 2
    # Skip branches that aren't pushed.
    if ! git rev-parse --verify --quiet "refs/remotes/origin/$old" >/dev/null; then
      log_v "skip remote rename (not pushed): $old"
      continue
    fi
    if ! _remote_rename_one "$old" "$new"; then
      die "gh api branches/${old}/rename failed; local renames already applied. Resolve on GitHub (UI or 'gh api ... /rename') then 'git fetch --prune' and re-run 'git stack pr sync' ${C_DIM}[gstkprs]${C_RESET}."
    fi
    news+=("$new")
  done
  # The branches now live under their new names on the remote, but our
  # remote-tracking refs still point at the old names. Refresh origin/<new> for
  # each so the follow-up `--force-with-lease` push has a valid lease — without
  # this it rejects as "stale info" (no tracking ref for the new name).
  if (( ${#news[@]} > 0 )); then
    local refspecs=() n
    for n in "${news[@]}"; do refspecs+=("+refs/heads/${n}:refs/remotes/origin/${n}"); done
    git fetch --quiet origin "${refspecs[@]}" 2>/dev/null || true
  fi
}

# Invoke pr sync unless --no-sync was given. Idempotent; safe to call after
# any local+remote rename. Silently no-op if gh isn't available (cmd_pr_sync
# handles its own preflight).
_post_rename_sync() {
  # Optional first arg: explicit prefix to pass to cmd_pr_sync (needed when
  # HEAD is not on a stack branch after the rename, e.g. cmd_rename with HEAD
  # on main).
  local _pfx="${1-}"
  (( OPT_NO_SYNC )) && return 0
  if ! command -v gh >/dev/null 2>&1; then
    return 0
  fi
  if ! gh auth status -h github.com >/dev/null 2>&1; then
    return 0
  fi
  log "${C_DIM}post-rename:${C_RESET} pr sync"
  if [[ -n "$_pfx" ]]; then
    cmd_pr_sync --prefix "$_pfx" || warn "pr sync returned non-zero; re-run 'gstkprs' manually"
  else
    cmd_pr_sync || warn "pr sync returned non-zero; re-run 'gstkprs' manually"
  fi
}

# The branch's last commit subject — the content portion of a PR title, before
# the [N/M] position prefix is applied. pr sync re-derives the title from this on
# every run, so a title tracks its branch's latest commit subject.
_pr_branch_title() {
  local branch="$1"
  git log -1 --format='%s' "refs/heads/$branch" 2>/dev/null
}

# Compose a PR title with a [N/M] position prefix from the given content.
# Args: <pos> <total> <content>
#   - If <content> already carries a "[\d+/\d+] " prefix, that prefix is
#     replaced (so a content string that itself starts with a position bracket
#     doesn't end up double-prefixed).
#   - Otherwise "[N/M] " is prepended to <content>.
_pr_title_with_pos() {
  local pos="$1" total="$2" content="${3-}"
  if [[ "$content" =~ ^\[[0-9]+/[0-9]+\][[:space:]](.*)$ ]]; then
    content="${BASH_REMATCH[1]}"
  fi
  printf '[%d/%d] %s' "$pos" "$total" "$content"
}

# Print the repo's PR template body to stdout (empty if none found).
# Lookup order:
#   1. .github/PULL_REQUEST_TEMPLATE/default.md (multi-template repo default)
#   2. case-insensitive search for pull_request_template.md in .github/, docs/, repo root
#   3. if multi-template dir exists with no default and no single-file match:
#      warn (caller falls back to empty body)
_pr_template_body() {
  local toplevel
  toplevel=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  local dir_path="${toplevel}/.github/PULL_REQUEST_TEMPLATE"
  if [[ -d "$dir_path" && -f "$dir_path/default.md" ]]; then
    cat "$dir_path/default.md"
    return 0
  fi
  local dir cand
  for dir in ".github" "docs" "."; do
    [[ -d "$toplevel/$dir" ]] || continue
    cand=$(find "$toplevel/$dir" -maxdepth 1 -iname "pull_request_template.md" -type f 2>/dev/null | head -1)
    if [[ -n "$cand" ]]; then
      cat "$cand"
      return 0
    fi
  done
  if [[ -d "$dir_path" ]]; then
    warn "multi-template dir $dir_path/ has no default.md; using empty body"
  fi
  return 0
}

# Filter stdin -> stdout, normalizing a PR body for round-trip-tolerant
# comparison: strip CR (CRLF -> LF) and drop trailing blank/whitespace-only
# lines. Used comparison-only in the reconciler — GitHub may re-emit a stored
# body with CRLF or an extra trailing newline, which would otherwise look like a
# body change on the next sync. Internal whitespace is preserved (never sent to
# gh; the canonical desired body is what we write).
_pr_body_normalize() {
  tr -d '\r' | awk '
    { lines[NR]=$0; last=NR }
    END {
      end=last
      while (end > 0 && lines[end] ~ /^[[:space:]]*$/) end--
      for (i=1; i<=end; i++) print lines[i]
    }
  '
}

# Filter stdin -> stdout, removing the fenced nav-footer block (inclusive of
# both fence comments) plus any trailing blank lines. Idempotent.
_pr_strip_nav_footer() {
  awk '
    /<!-- git-stack:nav-start -->/ { skip=1 }
    !skip { print }
    /<!-- git-stack:nav-end -->/ { skip=0; next }
  ' | awk '
    { lines[NR]=$0; last=NR }
    END {
      end=last
      while (end > 0 && lines[end] ~ /^[[:space:]]*$/) end--
      for (i=1; i<=end; i++) print lines[i]
    }
  '
}

# Extract PR numbers referenced inside the nav footer block in stdin.
# Outputs one number per line. Handles both active (#N) and merged (~~#N~~)
# entries — each entry's number is the FIRST "#N" on its line. Only that first
# match is emitted: a later "#N" on the same line is title text, not a stack
# member (e.g. a Revert/Reapply title embeds the original "(#1234)"). Harvesting
# those would re-seed bogus merged-predecessor entries on every `pr sync`.
_pr_extract_nav_pr_nums() {
  local in_block=0 line
  while IFS= read -r line; do
    [[ "$line" == *'<!-- git-stack:nav-start -->'* ]] && in_block=1 && continue
    [[ "$line" == *'<!-- git-stack:nav-end -->'* ]] && in_block=0 && continue
    (( in_block )) || continue
    if [[ "$line" =~ \#([0-9]+) ]]; then
      printf '%s\n' "${BASH_REMATCH[1]}"
    fi
  done
}

# Pure lineage guard for merged-predecessor weaving. From an old nav-footer's
# PR numbers, return those no longer in the active stack that are candidates
# for "merged predecessor" rendering — but only when the old footer belongs to
# this stack's lineage. Two sufficient signals: (a) another non-self old-footer
# PR is still active (partial merge), or (b) self appears in the old footer
# (proof a prior pr sync on this PR wrote it). Without a signal, the old footer
# is unrelated and nothing is mined. No gh — the caller checks merged-status of
# the returned candidates.
# Usage: _merged_predecessor_candidates <self_num> <active_nums_csv> <old_num>...
# Prints candidate PR numbers, one per line, in input order.
_merged_predecessor_candidates() {
  local self="$1" active_csv="$2"; shift 2
  local n guard=0
  for n in "$@"; do
    [[ -z "$n" ]] && continue
    if [[ "$n" == "$self" ]]; then guard=1; continue; fi
    case ",$active_csv," in *",$n,"*) guard=1 ;; esac
  done
  (( guard )) || return 0
  # Emit each candidate at most once. The extractor already anchors to one
  # number per entry, but a footer that picked up duplicate entries (e.g. from
  # the pre-fix re-seeding bug) must still collapse to a single mining — never
  # multiply across syncs.
  local seen=","
  for n in "$@"; do
    [[ -z "$n" ]] && continue
    [[ "$n" == "$self" ]] && continue
    case ",$active_csv," in *",$n,"*) continue ;; esac
    case "$seen" in *",$n,"*) continue ;; esac
    seen="$seen$n,"
    printf '%s\n' "$n"
  done
}

# Effectful gather step for merged-predecessor weaving. The pure lineage guard
# (_merged_predecessor_candidates) selects which old-footer numbers are worth
# checking; gh then confirms merged-status and fetches each title. Emits one
# "num<TAB>title" line per confirmed merged predecessor (none -> no output), in
# candidate order. This is the only gh touch the reconciler needs — its output
# feeds the pure _pr_weave_footer_triples.
#
# Two short-circuits keep the gh round trips minimal:
#   1. <self_body> already records the candidate as a struck-through merged
#      entry — a merge is terminal, so reuse the recorded title (no gh).
#   2. otherwise, the merged-state + title are resolved through the per-run
#      cache (_gh_merged_resolve), so a predecessor shared by several PRs in
#      the same stack is queried at most once.
# Usage: _pr_gather_merged_preds <self_num> <active_csv> <self_body> <old_num>...
_pr_gather_merged_preds() {
  local self="$1" active_csv="$2" body="$3"; shift 3
  local cand mt
  while IFS= read -r cand; do
    [[ -z "$cand" ]] && continue
    # (1) Trust the existing footer.
    if mt=$(_pr_footer_merged_title "$cand" "$body"); then
      printf '%s\t%s\n' "$cand" "$mt"
      continue
    fi
    # (2) Resolve via the per-run cache — prints the title iff merged.
    if mt=$(_gh_merged_resolve "$cand"); then
      printf '%s\t%s\n' "$cand" "$mt"
    fi
  done < <(_merged_predecessor_candidates "$self" "$active_csv" "$@")
}

# Pure: if <body>'s nav footer renders PR <num> as a struck-through merged
# predecessor — "- ~~#<num> <title>~~ (merged)" — print <title> and return 0;
# return 1 otherwise. Lets pr sync reuse an already-recorded merge instead of
# re-querying GitHub for a state that can no longer change.
_pr_footer_merged_title() {
  local num="$1" body="$2" line
  while IFS= read -r line; do
    if [[ "$line" =~ ^[[:space:]]*-[[:space:]]*~~#${num}[[:space:]]+(.*)~~[[:space:]]*\(merged\)[[:space:]]*$ ]]; then
      printf '%s' "${BASH_REMATCH[1]}"
      return 0
    fi
  done <<< "$body"
  return 1
}

# Pure: assemble a PR nav-footer's body triples, encoding merged-predecessor
# prepend + strikethrough-on-position-change. No gh, no git. The reconciler's
# core presentation rule, extracted from cmd_pr_sync pass 2 so it's unit-tested
# in isolation. Output: one TAB-separated triple per line
# "<branch>\t<num>\t<display_title>" (the arg vector _pr_render_nav_footer wants
# after the leading <self>). An empty branch field marks a merged predecessor
# (rendered struck-through). Active entries get a "[pos/N]" prefix; the old
# bracketed position is struck through as "~~[old]~~ [new]" ONLY when the entry's
# number is in <old_nums_csv> (this PR's prior footer, exact-match) AND its
# position actually moved — so a fresh entry, or an unchanged position, stays plain.
# Usage: _pr_weave_footer_triples <old_nums_csv> [<m_num> <m_title>]... -- <a_branch> <a_num> <a_title>...
_pr_weave_footer_triples() {
  local old_csv="$1"; shift
  # Merged predecessors first, up to the "--" separator.
  while (( $# > 0 )) && [[ "$1" != "--" ]]; do
    printf '\t%s\t%s\n' "$1" "${2-}"
    shift 2
  done
  [[ "${1-}" == "--" ]] && shift
  # Active entries: position is the 1-based ordinal among the remaining triples.
  local n_active=$(( $# / 3 )) pos=0
  while (( $# >= 3 )); do
    local a_branch="$1" a_num="$2" a_title="$3"; shift 3
    pos=$(( pos + 1 ))
    local new_pos="[$pos/$n_active]" old_pos="" bare="$a_title"
    if [[ "$a_title" =~ ^\[([0-9]+/[0-9]+)\][[:space:]](.*)$ ]]; then
      old_pos="[${BASH_REMATCH[1]}]"
      bare="${BASH_REMATCH[2]}"
    fi
    local in_old=0
    case ",$old_csv," in *",$a_num,"*) in_old=1 ;; esac
    if (( in_old )) && [[ -n "$old_pos" && "$old_pos" != "$new_pos" ]]; then
      printf '%s\t%s\t~~%s~~ %s %s\n' "$a_branch" "$a_num" "$old_pos" "$new_pos" "$bare"
    else
      printf '%s\t%s\t%s %s\n' "$a_branch" "$a_num" "$new_pos" "$bare"
    fi
  done
}

# Rewrite every "#<digits>" PR reference in <text> to an explicit markdown link
# [#N](https://github.com/<repo>/pull/N). A bare "#N" renders as a js-issue-link
# that GitHub resolves to the PR title client-side — so a nav block full of them
# (and of the "(#N)" refs embedded in revert/reapply titles) expands into an
# unreadable wall of nested titles. An explicit link keeps the literal "#N" text
# AND stays clickable, and is not expanded. A "#" not followed by a digit is left
# untouched; an empty <repo> passes the text through unchanged (degrade to bare
# "#N" rather than emit a broken URL).
_md_link_pr_refs() {
  local repo="$1" s="$2"
  [[ -z "$repo" ]] && { printf '%s' "$s"; return 0; }
  local out="" i ch j num
  for (( i = 0; i < ${#s}; i++ )); do
    ch="${s:i:1}"
    if [[ "$ch" == "#" && "${s:i+1:1}" == [0-9] ]]; then
      num=""
      j=$(( i + 1 ))
      while (( j < ${#s} )) && [[ "${s:j:1}" == [0-9] ]]; do
        num+="${s:j:1}"
        j=$(( j + 1 ))
      done
      out+="[#${num}](https://github.com/${repo}/pull/${num})"
      i=$(( j - 1 ))
    else
      out+="$ch"
    fi
  done
  printf '%s' "$out"
}

# Emit the fenced stack-nav footer to stdout.
# Args: <repo> <self_branch> then repeating triples of (branch, pr_num, title).
# A branch value of "" marks a merged predecessor — rendered as strikethrough.
# <repo> ("owner/name") is needed to linkify each "#N" (see _md_link_pr_refs);
# refs embedded in the title are linkified in place too.
_pr_render_nav_footer() {
  local repo="$1" self="$2"; shift 2
  printf '<!-- git-stack:nav-start -->\n'
  printf '## Stack\n\n'
  local b n t link disp
  while (( $# >= 3 )); do
    b="$1"; n="$2"; t="$3"
    link=$(_md_link_pr_refs "$repo" "#$n")
    disp=$(_md_link_pr_refs "$repo" "$t")
    if [[ -z "$b" ]]; then
      printf -- '- ~~%s %s~~ (merged)\n' "$link" "$disp"
    elif [[ "$b" == "$self" ]]; then
      printf -- '- %s %s ← this PR\n' "$link" "$disp"
    else
      printf -- '- %s %s\n' "$link" "$disp"
    fi
    shift 3
  done
  printf '\n<!-- git-stack:nav-end -->\n'
}

# Return 0 if <branch> needs to be (re-)pushed to origin: either the
# remote-tracking ref is missing, or local and remote tips differ.
_pr_needs_push() {
  local b="$1"
  local local_sha remote_sha
  local_sha=$(git rev-parse --verify --quiet "refs/heads/$b" 2>/dev/null) || return 0
  remote_sha=$(git rev-parse --verify --quiet "refs/remotes/origin/$b" 2>/dev/null) || return 0
  [[ "$local_sha" != "$remote_sha" ]]
}

# Return 0 (true) if <branch>'s tip SHA equals <parent>'s tip SHA — i.e. the
# branch has no commits ahead of its in-stack parent. gh pr create would
# fail with "No commits between base and head" for these, so we filter them
# out of the active set.
_pr_is_empty_diff() {
  local b="$1" parent="$2"
  local p_sha b_sha
  p_sha=$(git rev-parse --verify --quiet "refs/heads/$parent" 2>/dev/null || true)
  b_sha=$(git rev-parse --verify --quiet "refs/heads/$b" 2>/dev/null || true)
  [[ -n "$p_sha" && "$p_sha" == "$b_sha" ]]
}

# Populate the named array with branches that have at least one commit ahead
# of their in-stack predecessor. Empty-diff branches are silently filtered.
# The caller can re-iterate the input and call _pr_is_empty_diff to log a
# message for each skipped branch.
# Usage: _pr_active_branches <base0> <out_array_name> <branches...>
_pr_active_branches() {
  local base0="$1" out_name="$2"
  shift 2
  local in=("$@")
  eval "$out_name=()"
  local i parent
  for ((i = 0; i < ${#in[@]}; i++)); do
    if (( i == 0 )); then
      parent="$base0"
    else
      parent="${in[i-1]}"
    fi
    if _pr_is_empty_diff "${in[i]}" "$parent"; then
      continue
    fi
    eval "$out_name+=( $(printf '%q' "${in[i]}") )"
  done
}

# Look up an open PR for <branch>. On success, print
#   "<num><US><title><US><baseRef><US><body>"
# where <US> is ASCII unit separator (\x1f) and <body> may contain newlines.
# Empty stdout if no PR found.
_gh_pr_find() {
  local b="$1"
  gh pr list --repo "$GH_REPO" --head "$b" --state open --limit 1 \
    --json number,title,baseRefName,body \
    --jq '.[] | "\(.number)\(.title // "")\(.baseRefName // "")\(.body // "")"' \
    2>/dev/null
}

# Bulk open-PR index for `pr sync` discovery: one round trip fetches every open
# PR, replacing the per-branch `_gh_pr_find` loop (N queries -> 1). Records are
# RS (\x1e) separated; fields US (\x1f) separated, leading with the head branch
# so a lookup is a string match. _GH_OPEN_INDEX_OK distinguishes a successful
# (possibly empty) load from a gh failure: on a clean load a lookup miss means
# "no open PR for this branch" and discovery trusts it; on failure the caller
# falls back to a live per-branch `_gh_pr_find`.
_GH_OPEN_INDEX=""
_GH_OPEN_INDEX_OK=0
_gh_load_open_index() {
  _GH_OPEN_INDEX=""
  _GH_OPEN_INDEX_OK=0
  local out
  out=$(gh pr list --repo "$GH_REPO" --state open --limit 1000 \
    --json number,title,baseRefName,headRefName,body \
    --jq '.[] | "\(.headRefName)\(.number)\(.title // "")\(.baseRefName // "")\(.body // "")"' \
    2>/dev/null) || return 1
  _GH_OPEN_INDEX="$out"
  _GH_OPEN_INDEX_OK=1
}

# Look up <branch> in the loaded open-PR index. On hit, prints the same
# "<num><US><title><US><baseRef><US><body>" record _gh_pr_find returns; returns
# 1 on miss. Pure (no gh) — the index must already be loaded.
_gh_open_index_find() {
  local b="$1" rec h
  while IFS= read -r -d $'\x1e' rec; do
    # gh's --jq prints a newline after each record, so every record past the
    # first arrives with a leading newline — strip it before matching.
    rec="${rec#$'\n'}"
    [[ -z "$rec" ]] && continue
    h="${rec%%$'\x1f'*}"
    if [[ "$h" == "$b" ]]; then
      printf '%s' "${rec#*$'\x1f'}"
      return 0
    fi
  done <<< "$_GH_OPEN_INDEX"
  return 1
}

# Return 0 (true) if ANY of the given branches has an open head PR on origin.
# On true, sets _ORPHAN_PR_BRANCH and _ORPHAN_PR_NUM (globals) for the caller's
# error message. On false (no open PRs found), returns 1 with empty globals.
# Skips gracefully (returns 1) when gh isn't available or auth fails — same
# preflight pattern as _post_rename_sync. GH_REPO must be set if gh is usable.
# Usage: _check_no_open_prs <branch1> <branch2> ...
_check_no_open_prs() {
  _ORPHAN_PR_BRANCH=""
  _ORPHAN_PR_NUM=""
  command -v gh >/dev/null 2>&1 || return 1
  gh auth status -h github.com >/dev/null 2>&1 || return 1
  if [[ -z "${GH_REPO:-}" ]]; then
    GH_REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) || return 1
  fi
  local b found
  for b in "$@"; do
    found=$(_gh_pr_find "$b")
    if [[ -n "$found" ]]; then
      _ORPHAN_PR_BRANCH="$b"
      _ORPHAN_PR_NUM="${found%%$'\x1f'*}"
      return 0
    fi
  done
  return 1
}

# Fold remote tail, step 1: capture the victim's open PR number (best-effort),
# then delete its remote branch — which closes that PR on GitHub. Prints the
# captured PR number (empty if none / gh unavailable) so the caller can
# breadcrumb it once pr sync has minted the superseding PR.
# Usage: _fold_remote_drop_victim <victim_branch>
_fold_remote_drop_victim() {
  local victim="$1" pr="" found
  if command -v gh >/dev/null 2>&1 && gh auth status -h github.com >/dev/null 2>&1; then
    if [[ -z "${GH_REPO:-}" ]]; then
      GH_REPO=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) || GH_REPO=""
    fi
    if [[ -n "${GH_REPO:-}" ]]; then
      found=$(_gh_pr_find "$victim")
      [[ -n "$found" ]] && pr="${found%%$'\x1f'*}"
    fi
  fi
  if git remote get-url origin >/dev/null 2>&1 \
     && git ls-remote --exit-code --heads origin "$victim" >/dev/null 2>&1; then
    git push --quiet origin --delete "$victim" 2>/dev/null \
      || warn "fold: could not delete remote branch '$victim'"
  fi
  printf '%s' "$pr"
}

# Fold remote tail, step 2: leave a breadcrumb on the (now-closed) victim PR
# pointing at the PR that supersedes it. Best-effort; runs after pr sync so the
# superseding PR exists. Usage: _fold_breadcrumb <victim_pr> <survivor_branch>
_fold_breadcrumb() {
  local victim_pr="$1" survivor="$2" found sup=""
  [[ -n "${GH_REPO:-}" ]] || return 0
  found=$(_gh_pr_find "$survivor")
  [[ -n "$found" ]] && sup="${found%%$'\x1f'*}"
  [[ -n "$sup" ]] || return 0
  local body="Folded into #${sup} via \`git stack fold\`; this branch no longer exists."
  gh pr comment "$victim_pr" --repo "$GH_REPO" --body "$body" >/dev/null 2>&1 \
    || warn "fold: could not comment on PR #${victim_pr} (referencing #${sup})"
}

# Resolve PR <num>'s merged-state + title in a single round trip: on merged,
# print the title and return 0; on any other state (or query failure) return 1.
# Combines what used to be two `gh pr view` calls (state, then title) into one,
# and is the only live gh touch left in the merged-predecessor gather. Results
# are memoised per run in _GH_MERGED_CACHE, so a predecessor referenced by
# several PRs in one stack costs a single query. (cmd_pr_sync's pre-pass primes
# this cache from the parent shell, since the gather runs in a subshell.)
_GH_MERGED_CACHE=""   # "<num><US><title-or-empty><RS>" records; title empty == not merged
_gh_merged_resolve() {
  local num="$1" rec hit out state title
  # Cache hit?
  while IFS= read -r -d $'\x1e' rec; do
    rec="${rec#$'\n'}"
    [[ -z "$rec" ]] && continue
    if [[ "${rec%%$'\x1f'*}" == "$num" ]]; then
      hit="${rec#*$'\x1f'}"
      [[ -n "$hit" ]] || return 1   # cached as not-merged
      printf '%s' "$hit"
      return 0
    fi
  done <<< "$_GH_MERGED_CACHE"
  # Miss — one combined query, then memoise the answer (merged or not).
  out=$(gh pr view "$num" --repo "$GH_REPO" --json state,title \
    --jq '"\(.state)\(.title // "")"' 2>/dev/null) || out=""
  state="${out%%$'\x1f'*}"
  title="${out#*$'\x1f'}"
  if [[ "$state" == "MERGED" ]]; then
    _GH_MERGED_CACHE+="${num}"$'\x1f'"${title}"$'\x1e'
    printf '%s' "$title"
    return 0
  fi
  _GH_MERGED_CACHE+="${num}"$'\x1f'$'\x1e'   # remember "not merged"
  return 1
}

# Create a draft PR (or non-draft if draft=0) for <branch>.
# Args: <branch> <parent> <title> <draft:0|1> <body>
# Prints the new PR number on stdout. On "already exists" error, re-queries
# and returns the existing PR's number (handles interrupted prior runs).
# Returns 1 on hard failure (caller adds to PR_FAILURES).
_gh_pr_create() {
  local b="$1" parent="$2" title="$3" draft="$4" body="$5"
  local args=( --repo "$GH_REPO" --head "$b" --base "$parent" --title "$title" --body-file - )
  if (( draft )); then
    args+=( --draft )
  fi
  local out url num
  if out=$(printf '%s' "$body" | gh pr create "${args[@]}" 2>&1); then
    url=$(printf '%s' "$out" | tail -1)
    num="${url##*/}"
    if [[ "$num" =~ ^[0-9]+$ ]]; then
      printf '%s' "$num"
      return 0
    fi
    printf '%s\n' "$out" >&2
    return 1
  fi
  if [[ "$out" == *"already exists"* ]]; then
    log_v "gh pr create: $out"
    local lookup
    lookup=$(_gh_pr_find "$b")
    if [[ -n "$lookup" ]]; then
      printf '%s' "${lookup%%$'\x1f'*}"
      return 0
    fi
  fi
  printf '%s\n' "$out" >&2
  return 1
}

# Update an existing PR's title, body, and/or base branch. Pass empty string
# for any field to skip it. Returns 1 on failure (output captured + printed
# to stderr).
_gh_pr_edit() {
  local num="$1" new_title="$2" new_body="$3" new_base="${4-}"
  local args=( "$num" --repo "$GH_REPO" )
  if [[ -n "$new_title" ]]; then
    args+=( --title "$new_title" )
  fi
  if [[ -n "$new_base" ]]; then
    args+=( --base "$new_base" )
  fi
  local stdin_needed=0
  if [[ -n "$new_body" ]]; then
    args+=( --body-file - )
    stdin_needed=1
  fi
  # Nothing to update (just <num> --repo <repo>). Caller should guard; this
  # is defensive.
  (( ${#args[@]} > 3 )) || return 0
  local out
  if (( stdin_needed )); then
    out=$(printf '%s' "$new_body" | gh pr edit "${args[@]}" 2>&1) || {
      printf '%s\n' "$out" >&2
      return 1
    }
  else
    out=$(gh pr edit "${args[@]}" 2>&1) || {
      printf '%s\n' "$out" >&2
      return 1
    }
  fi
}

# Close an open PR without merging. Args: <num>. Returns 1 on failure (output
# captured + echoed to stderr). Does not touch the branch — the --delete-remote
# path in cmd_pr_desync handles remote deletion separately.
_gh_pr_close() {
  local num="$1" out
  out=$(gh pr close "$num" --repo "$GH_REPO" 2>&1) || {
    printf '%s\n' "$out" >&2
    return 1
  }
}

# Emit an OSC 8 hyperlink escape sequence wrapping <text> with <url>, when
# colors are on. Falls back to plain <text> when --no-color / non-TTY (i.e.
# whenever color_init left $C_RESET empty). Same gate as ANSI colors.
_osc8_link() {
  local url="$1" text="$2"
  if [[ -n "$C_RESET" ]]; then
    printf '\033]8;;%s\007%s\033]8;;\007' "$url" "$text"
  else
    printf '%s' "$text"
  fi
}

_pr_link() {
  local n="$1"
  _osc8_link "https://github.com/${GH_REPO}/pull/${n}" "#${n}"
}

# Convert a GitHub ISO 8601 timestamp (e.g. "2026-05-27T10:00:00Z") to a
# human-readable relative time ("2h ago", "3d ago", etc.). Prints nothing on
# parse failure so callers can treat empty output as "unknown".
_relative_time() {
  local ts="$1"
  [[ -z "$ts" ]] && return 0
  local epoch_ts epoch_now diff
  epoch_ts=$(date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null \
    || date -d "$ts" +%s 2>/dev/null) || return 0
  epoch_now=$(date +%s)
  diff=$(( epoch_now - epoch_ts ))
  if (( diff < 3600 )); then
    printf '%dm ago' $(( diff / 60 ))
  elif (( diff < 86400 )); then
    printf '%dh ago' $(( diff / 3600 ))
  elif (( diff < 604800 )); then
    printf '%dd ago' $(( diff / 86400 ))
  elif (( diff < 2592000 )); then
    printf '%dw ago' $(( diff / 604800 ))
  else
    printf '%dmo ago' $(( diff / 2592000 ))
  fi
}

# Inspect a PR for <branch> across all states (open/closed/merged). Emits one
# line (\x1f-separated) on success:
#   num<US>title<US>state<US>isDraft<US>baseRefName<US>reviewDecision<US>commentsCount
# Empty stdout if no PR exists for the branch. Unlike _gh_pr_find, no
# `--state open` filter — `pr list` should surface closed/merged PRs too.
_gh_pr_inspect() {
  local b="$1"
  gh pr list --repo "$GH_REPO" --head "$b" --state all --limit 1 \
    --json number,title,state,isDraft,baseRefName,reviewDecision,comments,latestReviews,reviewRequests,statusCheckRollup,mergedAt,mergedBy \
    --jq '.[] | ((.latestReviews // []) | map(select(.state == "APPROVED")) | map(.author.login) | join(",")) as $appr | ((.latestReviews // []) | map(select(.state == "CHANGES_REQUESTED")) | map(.author.login) | join(",")) as $chg | ((.latestReviews // []) | map(select(.state == "COMMENTED")) | map(.author.login) | join(",")) as $cmt | ((.reviewRequests // []) | map(if .__typename == "Team" then .name else .login end) | join(",")) as $req_rev | ((.statusCheckRollup // []) | map(if .__typename == "CheckRun" then (if .status != "COMPLETED" then "PENDING" elif (.conclusion == "SUCCESS" or .conclusion == "NEUTRAL" or .conclusion == "SKIPPED") then "PASS" else "FAIL" end) else (if .state == "SUCCESS" then "PASS" elif .state == "PENDING" then "PENDING" else "FAIL" end) end)) as $cs | "\($cs | map(select(. == "PASS")) | length),\($cs | map(select(. == "FAIL")) | length),\($cs | map(select(. == "PENDING")) | length)" as $checks | "\(.number)\(.title // "")\(.state // "")\(if .isDraft then "1" else "0" end)\(.baseRefName // "")\(.reviewDecision // "")\(.comments | length)\($appr)\($chg)\($req_rev)\($checks)\u001f\(.mergedAt // "")\u001f\(.mergedBy.login // "")\u001f\($cmt)"' \
    2>/dev/null
}

# ---------- subcommands ----------

cmd_help() {
  # Aliases for brevity in the heredoc.
  local b="$C_BOLD" d="$C_DIM" cy="$C_CYAN" r="$C_RESET"
  local sub="${b}${cy}"   # subcommand keyword: bold cyan
  local fl="${cy}"        # flag name: cyan
  cat <<EOF
${b}usage:${r} git stack <subcommand> [options]

${b}Stack-level subcommands:${r}
  ${sub}list${r}                              Overview of *all* stacks in the repo: branch
                                    count, tip leaf, a \`*\` on the current
                                    stack, and the base ref with
                                    \`[+ahead/-behind]\`. Local only — never
                                    fetches or calls \`gh\`.
  ${sub}view${r} [<stack>] [${fl}--no-fetch${r}]         One stack's contents (no checkout): parent
                                    header, each branch with tip SHA, subject,
                                    and upstream sync state (\`[synced]\`,
                                    \`[+ahead/-behind]\`, \`[gone]\`,
                                    \`[unpushed]\`), the last snapshot, and a
                                    paused-op banner if a reflow is mid-flight.
                                    Defaults to the current stack; pass a name
                                    (trailing \`/\` optional) or pick one from
                                    outside. Runs \`git fetch --all --prune\` by
                                    default; ${fl}--no-fetch${r} skips it.
  ${sub}pick${r}                              Choose a stack from the all-stacks selector
                                    and check out its tip (highest-leaf
                                    branch) — a fast hop, even from inside
                                    another stack.
  ${sub}create${r} [<prefix>] [<slug>] [${fl}--onto${r} <ref>] [${fl}--stash${r}]
                                    Start a brand-new stack: first branch
                                    (leaf \`010\`) off the resolved base
                                    (${fl}stack.base${r} → origin/<default> → local
                                    default), or ${fl}--onto${r} <ref>. Errors if the
                                    prefix already has branches (use ${sub}add${r}).
                                    Checks out the new branch. On a TTY, a
                                    missing <prefix> or <slug> is prompted for
                                    (re-prompts on invalid input, keeping what
                                    you typed); off a TTY it's a usage error.
                                    A dirty tree prompts to carry the
                                    uncommitted work into the new stack; ${fl}--stash${r}
                                    carries it without prompting (required to
                                    carry non-interactively).
  ${sub}sync${r}                              Push the whole stack to the remote, additive
                                    only (force-with-lease on every branch; no
                                    deletes, no PR work). Remote cleanup is
                                    ${sub}clean${r}'s job; PR chains are ${sub}pr sync${r}'s.
  ${sub}clean${r} [${fl}--dry-run${r}] [${fl}--keep-history${r}]
                                    Tidy a stack: prune local branches whose
                                    upstream is \`[gone]\` (+ their snapshot
                                    leaves), delete remote branches under the
                                    prefix with no local counterpart
                                    (confirm-gated — declining skips only that
                                    step), then reflow the survivors onto
                                    origin/<default> (skipped when nothing was
                                    pruned and the base hasn't moved). Can pause
                                    on conflict (resolve + ${sub}continue${r}). ${fl}--keep-history${r}
                                    preserves backup refs; ${fl}--dry-run${r} previews.

${b}Branch-level subcommands:${r}
  ${sub}add${r} <slug> [${fl}--last${r}|${fl}--before${r} <ref>|${fl}--after${r} <ref>|${fl}--at${r} <num>] [${fl}--prefix${r} <p>]
                                    Add an empty branch to the *current* stack
                                    at the chosen position. Local-only — never
                                    renames or touches existing branches, never
                                    calls GitHub. <ref> is a numeric leaf or
                                    full branch name; <num> is a leaf to place
                                    at exactly. With no position flag, opens an
                                    interactive picker; its leaf step accepts a
                                    suggested number or any leaf you type in the
                                    gap. New stacks get sparse
                                    3-digit leaves stepping by 10; insert flags
                                    pick the midpoint of the gap (refuses, no
                                    cascade, if exhausted). Errors outside a
                                    stack — use ${sub}create${r} or ${sub}pick${r}.
                                    A dirty tree is carried onto the new branch
                                    automatically (stashed + reapplied when the
                                    insert lands off your current commit).
  ${sub}checkout${r} [<number>]               Check out the stack branch whose leaf starts
                                    with that number (numeric match, so \`5\`
                                    finds \`05-foo\`).
                                    With no <number>, opens an interactive
                                    picker (fzf if available, else numbered
                                    prompt). From outside a stack, picks the
                                    stack first (shared with ${sub}list${r}/${sub}pick${r}),
                                    then a specific branch.
  ${sub}restack${r} [${fl}--from${r} <branch>] [${fl}--onto${r} <ref>] [${fl}--push${r}] [${fl}--force${r}]
                                    Reset+cherry-pick ${fl}--from${r} (default: current
                                    branch's child) and each branch above it onto
                                    its predecessor's new HEAD. With ${fl}--onto${r} <ref>,
                                    rebase ${fl}--from${r} (default: bottom of stack)
                                    onto <ref> first, then propagate up. With
                                    ${fl}--push${r}, force-with-lease push each branch
                                    as it finishes. Refuses if any branch has
                                    more than one commit since its predecessor;
                                    pass ${fl}--force${r} to cherry-pick the tip
                                    only (intermediate commits are dropped).
  ${sub}amend${r} [${fl}-m${r} <msg>] [${fl}--push${r}] [${fl}--force${r}] [${d}--${r} <pathspec>...]
                                    git add <pathspec>, git commit --amend
                                    [--no-edit|-m <msg>], then \`restack\`.
                                    ${fl}--force${r} is plumbed through to ${sub}restack${r}.
  ${sub}continue${r}                          After resolving a cherry-pick conflict
                                    (\`git add\` the fixed files), finish the
                                    cherry-pick and resume the reflow loop.
  ${sub}abort${r}                             Restore every branch in the run to its
                                    saved original SHA. Warns about already-
                                    pushed branches; does not undo remote.
  ${sub}pr sync${r} [${fl}--no-push${r}] [${fl}--ready${r}] [${fl}--dry-run${r}] [${fl}--no-template${r}]
                                    Sync the GitHub PR chain to the local
                                    stack. Pushes any unpushed branches,
                                    opens a draft PR for each (base = previous
                                    branch, or ${fl}stack.base${r} for the bottom),
                                    titled \`[N/M] <last commit subject>\`, with
                                    the repo's PR template as the body. On
                                    existing PRs, keeps the [N/M] prefix and
                                    a fenced stack-nav footer up to date.
                                    Re-run after any stack change. Requires
                                    \`gh\` authenticated for github.com.
  ${sub}pr list${r} [${fl}--no-fetch${r}]              List the stack's PRs one per line: branch,
                                    PR number (clickable link in modern
                                    terminals), status badges (\`[synced]\`,
                                    \`[draft]\`, \`[base: X]\`, \`[approved]\`,
                                    \`[closed]\`/\`[merged]\`), title, and
                                    comment count. Runs \`git fetch --all
                                    --prune\` by default; pass ${fl}--no-fetch${r}
                                    to skip. Requires \`gh\`.
  ${sub}pr desync${r} [${fl}--delete-remote${r}] [${fl}--yes${r}] [${fl}--dry-run${r}]
                                    Tear down the stack's PR chain (inverse of
                                    ${sub}pr sync${r}) so branches can be reordered and
                                    re-synced clean: closes each branch's open
                                    PR. Skips merged and already-closed PRs. An
                                    open PR with human activity (a non-bot
                                    comment, an approval, or a changes-requested
                                    review) prompts ${fl}y/N${r} per PR on a TTY —
                                    skipped non-interactively unless ${fl}--yes${r}.
                                    ${fl}--delete-remote${r} also deletes the remote
                                    branch of each PR closed (but never one
                                    still serving as the base of a PR you kept
                                    open). ${fl}--dry-run${r} previews. Requires \`gh\`.
  ${sub}history${r}                           List snapshots taken before each restack/
                                    amend. Subcommands: \`history show <id>\`,
                                    \`history restore <id> [--yes]\`. Run-id may
                                    be full, action-tagged, bare timestamp, or
                                    \`@N\` (relative; @0 = newest).
  ${sub}move${r} [<branch>] [${fl}--last${r}|${fl}--before${r} <ref>|${fl}--after${r} <ref>|${fl}--at${r} <num>] [${fl}--force${r}]
                                    Relocate <branch> (default: current branch)
                                    in the current stack to
                                    the chosen position. Cherry-picks affected
                                    branches onto their new predecessors using
                                    the existing reflow state machine — on
                                    conflict, resolve + \`git stack continue\`.
                                    ${b}Fully local${r}: touches only local refs — no
                                    push, no PR sync. To reorder a published
                                    stack cleanly, run ${sub}pr desync${r} first, reorder,
                                    then ${sub}pr sync${r}. Refuses if any affected branch
                                    has an open PR (it would desync from GitHub),
                                    pointing you at that workflow. ${fl}--first${r}
                                    removed; use ${fl}--before${r} instead.
                                    When the chosen position is the branch's
                                    current slot (e.g. ${fl}--before${r} the branch it
                                    already sits below, or ${fl}--at${r} a free leaf in
                                    the same gap), it ${b}renumbers in place${r}: a
                                    pure rename of the leaf, no reflow. With a
                                    TTY and no ${fl}--at${r}, a leaf picker offers the
                                    free numbers in the gap.
  ${sub}rename${r} <new-prefix> [${fl}--dry-run${r}] [${fl}--no-history${r}] [${fl}--allow-pr-rebuild${r}]
                                    Atomically rename every branch in the stack
                                    from <old>/<leaf> to <new>/<leaf>, carrying
                                    backup refs along by default. Refuses if
                                    state file exists, branch checked out
                                    elsewhere, or any target name collides.
                                    Also refuses if any branch has an open
                                    head PR (renaming a branch closes its head
                                    PR on GitHub, with no reattach); pass
                                    ${fl}--allow-pr-rebuild${r} to proceed and rebuild
                                    them, or run ${sub}pr desync${r} first to re-publish
                                    cleanly.
  ${sub}fold${r} [<branch>] [${fl}--up${r}|${fl}--down${r}] [${fl}--slug${r} <s>] [${fl}--at${r} <num>]
       [${fl}--allow-pr-rebuild${r}] [${fl}--dry-run${r}] [${fl}--yes${r}] [${fl}--no-push${r}]
                                    Merge a branch away by squashing it into an
                                    adjacent neighbor (default: ${fl}--down${r} into the
                                    predecessor), preserving the combined diff as
                                    one commit, then reflowing the children. The
                                    result keeps the survivor's leaf but takes the
                                    folded branch's slug by default (the branch you
                                    ran ${sub}fold${r} on names the result); ${fl}--slug${r}
                                    overrides the slug, ${fl}--at${r} the leaf (to a
                                    free leaf below the children). Squashes the
                                    whole victim/survivor range, so multi-commit/
                                    merge-tip branches fold fine (note: reflowed
                                    *children* are still cherry-picked tip-only).
                                    Errors at the stack boundaries (bottom ${fl}--down${r},
                                    tip ${fl}--up${r}, lone branch — use ${sub}clean${r}).
                                    Destructive: snapshots first (undo via
                                    ${sub}history restore${r}, which warns about any
                                    duplicate-leaf leftovers a rename leaves),
                                    refuses a dirty tree, needs ${fl}--yes${r} off a TTY.
                                    Deleting the victim (and renaming the survivor
                                    under ${fl}--slug${r}) closes their head PRs: refuses
                                    unless ${fl}--allow-pr-rebuild${r} (or ${fl}--no-push${r}),
                                    then deletes the remote victim, re-syncs PRs,
                                    and breadcrumbs the closed PR to the
                                    superseding one. ${fl}--dry-run${r} previews.
  ${sub}drop${r} [<branch>] [${fl}--force${r}] [${fl}--dry-run${r}] [${fl}--yes${r}]
                                    Discard a branch and reflow its children onto
                                    its predecessor — the destructive sibling of
                                    ${sub}fold${r} (fold keeps the diff; ${sub}drop${r} throws it
                                    away). Defaults to the current branch. Degrades
                                    at every position: middle → children onto the
                                    predecessor; bottom → onto base; tip → pure
                                    delete; lone → delete + land on base. Children
                                    are cherry-picked tip-only, so one that built
                                    on the dropped work surfaces a normal conflict
                                    to resolve and ${sub}continue${r}; ${fl}--force${r} waives the
                                    multi-commit guard. Fully local (no push/
                                    rename/${sub}pr sync${r}). Destructive: snapshots first
                                    (undo via ${sub}history restore${r}), refuses a dirty
                                    tree, needs ${fl}--yes${r} off a TTY. Refuses only when
                                    the victim has an open PR (run ${sub}pr desync${r}
                                    first). ${fl}--dry-run${r} previews.
  ${sub}doctor${r} [${fl}--yes${r}] [${fl}--dry-run${r}] [${fl}--no-squash${r}]
          [${fl}--no-rename${r}] [${fl}--no-push${r}] [${fl}--no-sync${r}]
                                    Detect and offer to fix problems in the
                                    current stack. Three issue types are checked:
                                      • leaf numbers out of order (renamed to
                                        cascade in place, preserving gaps)
                                      • duplicate leaf numbers — two or more
                                        branches share the same leaf. Interactive
                                        prompt lets you pick which branch keeps
                                        the number; the rest cascade upward and
                                        upper branches are re-threaded onto the
                                        chosen predecessor.
                                      • branches that violate the single-
                                        commit-per-branch invariant — multi-
                                        commit branches and merge-commit tips
                                        (squashed into one commit on top of
                                        their predecessor, then upper branches
                                        are re-threaded via ${sub}restack${r})
                                    Per-issue interactive prompts on a tty:
                                    ${fl}y${r}=apply, ${fl}e${r}=apply with \$EDITOR for the
                                    squash message, ${fl}N${r}=skip, ${fl}a${r}=apply all,
                                    ${fl}q${r}=quit. Duplicate prompts take a
                                    space- or comma-separated permutation of
                                    1..N (RET to keep current order, ${fl}q${r} to
                                    quit). Pass ${fl}--yes${r} to auto-apply every
                                    fix using sort-V order for duplicates
                                    (required for non-tty / scripts).
                                    ${fl}--dry-run${r} previews the issue list and
                                    proposed fixes without applying. ${fl}--no-squash${r}
                                    skips the squash checks (rename-only mode);
                                    ${fl}--no-rename${r} skips the leaf-rename pass
                                    (which also skips duplicate detection).
                                    Empty squashes (branch tree == predecessor
                                    tree) offer to delete the absorbed branch.
                                    Same atomic rename + remote-rename + pr
                                    sync flow as ${sub}rename${r} (skip with
                                    --no-push / --no-sync).
  ${sub}prefix${r}                            Print auto-detected stack prefix (debug).
  ${sub}default-branch${r}                    Print the resolved default branch name
                                    (stack.base → init.defaultBranch → main →
                                    master, falling back to literal \`main\`).
                                    Used internally by ${sub}clean${r} and
                                    ${sub}restack --onto${r}.
  ${sub}init${r} <bash|zsh|fish>              Emit shell-integration snippet defining
                                    \`gstk*\` aliases/abbreviations. Add to your
                                    rc: \`eval "\$(git stack init bash)"\` (bash/
                                    zsh) or \`git stack init fish | source\`
                                    (fish).

${b}Common flags:${r}
  ${fl}--prefix${r} <p>                      Override the stack prefix (else
                                    git config stack.prefix, else auto-detect).
  ${fl}--no-push${r}                         (move/rename/fold/doctor) skip remote rename + pr sync.
  ${fl}--no-sync${r}                         (move/rename/fold/doctor) skip pr sync only.
  ${fl}--color${r} | ${fl}--no-color${r}              Force color on/off (default: auto-detect
                                    TTY; honors ${fl}NO_COLOR${r} env var).
  ${fl}-v${r}, ${fl}--verbose${r}                     More output.
  ${fl}-q${r}, ${fl}--quiet${r}                       Less output.

${b}Stack ordering:${r}
  Branches whose final path segment matches  ${d}^[0-9]+-${r}  are sorted by
  \`sort -V\` on that numeric portion. Examples (in order):
    ${cy}<prefix>/05-foo${r}
    ${cy}<prefix>/06-bar${r}
    ${cy}<prefix>/07-qux${r}

${b}Single-commit assumption:${r}
  Each branch is treated as one commit on top of its predecessor, mirroring the
  manual \`git reset --hard <prev> && git cherry-pick <branch-tip>\` flow. For
  multi-commit branches, prefer \`git stack amend\` so the tool can capture the
  pre-amend SHA up front.

${b}Configuration:${r}
  git config stack.prefix <prefix>/
  git config stack.base <branch>     ${d}# parent branch for \`list\` (default:
                                       init.defaultBranch, then main, then master)${r}
  git config stack.historyKeep 100   ${d}# auto-prune older snapshots; 0 disables${r}
EOF
}

cmd_prefix() {
  detect_prefix
}

# Resolve the parent (base) branch name. Order:
#   1. git config stack.base (e.g. "main", "develop")
#   2. git config init.defaultBranch  (if such a local branch exists)
#   3. local "main", then local "master"
# Prints the bare branch name (no "origin/" prefix), or returns 1.
_resolve_parent_name() {
  local cfg
  cfg=$(git config --get stack.base 2>/dev/null || true)
  if [[ -n "$cfg" ]]; then
    printf '%s\n' "${cfg#origin/}"
    return 0
  fi
  cfg=$(git config --get init.defaultBranch 2>/dev/null || true)
  if [[ -n "$cfg" ]] && git show-ref -q --verify "refs/heads/$cfg"; then
    printf '%s\n' "$cfg"
    return 0
  fi
  local cand
  for cand in main master; do
    if git show-ref -q --verify "refs/heads/$cand"; then
      printf '%s\n' "$cand"
      return 0
    fi
  done
  return 1
}

# Resolve the actual ref to compare against, preferring the remote tracking
# branch (which `git fetch` updates) over the local branch.
# $1 = parent branch name (e.g. "main"). Prints the resolved ref, returns 1.
_resolve_parent_ref() {
  local name="$1"
  if git rev-parse --verify --quiet "refs/remotes/origin/$name" >/dev/null 2>&1; then
    printf '%s\n' "origin/$name"
    return 0
  fi
  if git rev-parse --verify --quiet "refs/heads/$name" >/dev/null 2>&1; then
    printf '%s\n' "$name"
    return 0
  fi
  return 1
}

# Print a compact "[N behind]" / "[up to date]" / "[no parent ref]" indicator
# for the stack-vs-parent state. $1 = bottom branch, $2 = parent ref.
_parent_state() {
  local bottom="$1" parent="$2"
  if ! git rev-parse --verify --quiet "$parent" >/dev/null 2>&1; then
    printf '%s[no parent ref]%s' "$C_DIM" "$C_RESET"
    return
  fi
  local behind
  behind=$(git rev-list --count "${bottom}..${parent}" 2>/dev/null || echo "?")
  if [[ "$behind" == "0" ]]; then
    printf '%s[up to date]%s' "$C_DIM" "$C_RESET"
  else
    printf '%s[%s behind]%s' "$C_YELLOW" "$behind" "$C_RESET"
  fi
}

# Print a compact upstream-sync indicator for <branch>:
#   [synced]          local sha == upstream sha
#   [+ahead/-behind]  diverged (yellow)
#   [gone]            upstream configured but its tracking ref is missing
#                     (e.g. remote branch deleted, then `fetch --prune`)
#   [unpushed]        no upstream configured (never pushed)
_upstream_status() {
  local b="$1"
  local local_full upstream upstream_full
  local_full=$(git rev-parse --verify --quiet "refs/heads/$b" 2>/dev/null) || {
    printf '%s[?]%s' "$C_DIM" "$C_RESET"
    return
  }
  upstream=$(git for-each-ref --format='%(upstream:short)' "refs/heads/$b" 2>/dev/null)
  if [[ -z "$upstream" ]]; then
    printf '%s[unpushed]%s' "$C_DIM" "$C_RESET"
    return
  fi
  if upstream_full=$(git rev-parse --verify --quiet "refs/remotes/$upstream" 2>/dev/null); then
    if [[ "$upstream_full" == "$local_full" ]]; then
      printf '%s[synced]%s' "$C_DIM" "$C_RESET"
    else
      local ahead behind
      ahead=$(git rev-list --count "refs/remotes/$upstream..refs/heads/$b" 2>/dev/null || echo "?")
      behind=$(git rev-list --count "refs/heads/$b..refs/remotes/$upstream" 2>/dev/null || echo "?")
      printf '%s[+%s/-%s]%s' "$C_YELLOW" "$ahead" "$behind" "$C_RESET"
    fi
  else
    printf '%s[gone]%s' "$C_YELLOW" "$C_RESET"
  fi
}

# Compute overview fields for one stack <prefix>, given the <current> branch.
# Echoes TAB-separated: marker<TAB>count<TAB>tip<TAB>base<TAB>ahead<TAB>behind
#   marker  "*" if the current HEAD is in this stack, else " "
#   count   number of stack branches
#   tip     highest-leaf branch (full name)
#   base    resolved base ref (e.g. "main" / "origin/main"), or "" if unresolved
#   ahead   commits on tip not in base ("?" if uncomputable, "" if no base)
#   behind  commits on base not in the stack's bottom branch
# Returns 1 with no output when the prefix has no stack branches.
_stack_overview_fields() {
  local prefix="$1" current="$2"
  local branches=()
  _load_stack_branches "$prefix" branches
  local count=${#branches[@]}
  (( count > 0 )) || return 1
  local tip="${branches[$((count - 1))]}" bottom="${branches[0]}"
  local marker=" " b
  for b in "${branches[@]}"; do
    [[ -n "$current" && "$b" == "$current" ]] && { marker="*"; break; }
  done
  local base="" ahead="" behind="" base_name base_ref
  if base_name=$(_resolve_parent_name) && base_ref=$(_resolve_parent_ref "$base_name"); then
    base="$base_ref"
    if git rev-parse --verify --quiet "$base_ref" >/dev/null 2>&1; then
      ahead=$(git rev-list --count "${base_ref}..refs/heads/${tip}" 2>/dev/null || echo "?")
      behind=$(git rev-list --count "refs/heads/${bottom}..${base_ref}" 2>/dev/null || echo "?")
    else
      ahead="?"; behind="?"
    fi
  fi
  printf '%s\t%d\t%s\t%s\t%s\t%s\n' "$marker" "$count" "$tip" "$base" "$ahead" "$behind"
}

# Build a plain (uncolored) one-line label for a stack, used as a picker row.
_stack_overview_label() {
  local prefix="$1" current="$2"
  local fields marker count tip base ahead behind
  fields=$(_stack_overview_fields "$prefix" "$current") || return 1
  IFS=$'\t' read -r marker count tip base ahead behind <<< "$fields"
  local noun="branches"; [[ "$count" == "1" ]] && noun="branch"
  local ab=""
  [[ -n "$base" ]] && ab="  ${base} [+${ahead}/-${behind}]"
  printf '%s %s  (%d %s)  tip %s%s' \
    "$marker" "${prefix%/}" "$count" "$noun" "${tip##*/}" "$ab"
}

# Present an all-stacks selector and echo the chosen prefix (ending in "/").
# With a single stack, returns it without prompting. Returns 1 on no stacks or
# abort. $1 = picker header.
_select_stack() {
  local header="$1"
  local current; current=$(current_branch 2>/dev/null) || current=""
  local prefixes=() p
  while IFS= read -r p; do [[ -n "$p" ]] && prefixes+=("$p"); done < <(stack_prefixes)
  (( ${#prefixes[@]} > 0 )) || return 1
  if (( ${#prefixes[@]} == 1 )); then
    printf '%s\n' "${prefixes[0]}"
    return 0
  fi
  local labels=()
  for p in "${prefixes[@]}"; do labels+=("$(_stack_overview_label "$p" "$current")"); done
  local picked
  picked=$(_pick_one "$header" "${labels[@]}") || return 1
  local i
  for ((i = 0; i < ${#labels[@]}; i++)); do
    [[ "${labels[$i]}" == "$picked" ]] && { printf '%s\n' "${prefixes[$i]}"; return 0; }
  done
  return 1
}

# Overview of *all* stacks in the repo: branch count, tip, current marker, and
# base + ahead/behind. Local only — reads existing remote-tracking refs, never
# fetches or calls `gh`. For one stack's contents use `view`.
cmd_list() {
  OPT_PREFIX=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      -*) die "unknown list flag: $1" ;;
      *)  die "list: unexpected arg '$1'" ;;
    esac
  done
  require_in_repo

  local current; current=$(current_branch 2>/dev/null) || current=""
  local prefixes=() p
  while IFS= read -r p; do [[ -n "$p" ]] && prefixes+=("$p"); done < <(stack_prefixes)
  (( ${#prefixes[@]} > 0 )) \
    || die "no stacks found; create one with 'git stack create <prefix> <slug>' ${C_DIM}[gstkcr]${C_RESET}"

  local fields marker count tip base ahead behind
  local mark_disp branch_color noun ab ab_color
  for p in "${prefixes[@]}"; do
    fields=$(_stack_overview_fields "$p" "$current") || continue
    IFS=$'\t' read -r marker count tip base ahead behind <<< "$fields"
    if [[ "$marker" == "*" ]]; then
      mark_disp="${C_GREEN}*${C_RESET}"; branch_color="${C_BOLD}${C_CYAN}"
    else
      mark_disp=" "; branch_color="${C_CYAN}"
    fi
    noun="branches"; [[ "$count" == "1" ]] && noun="branch"
    ab=""
    if [[ -n "$base" ]]; then
      ab_color="$C_DIM"; [[ "$behind" != "0" ]] && ab_color="$C_YELLOW"
      ab="  ${C_DIM}${base}${C_RESET} ${ab_color}[+${ahead}/-${behind}]${C_RESET}"
    fi
    printf '%s %s%s%s\n' "$mark_disp" "$branch_color" "${p%/}" "$C_RESET"
    printf '    %s%d %s · tip %s%s%s%s%s\n' \
      "$C_DIM" "$count" "$noun" "$C_RESET" \
      "$C_CYAN" "${tip##*/}" "$C_RESET" "$ab"
  done
}

# One stack's contents (no checkout): the current stack, or a named one
# (trailing "/" optional; picker on an unknown/ambiguous name, or no arg when
# outside a stack). Shows the parent header, each branch with its upstream sync
# state, the last snapshot, and a one-line paused-op banner if a reflow is
# mid-flight. Runs `git fetch --all --prune` by default (pass --no-fetch to
# skip). Supersedes the old `status`.
cmd_view() {
  OPT_PREFIX=""
  local OPT_FETCH=1 arg=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --no-fetch) OPT_FETCH=0; shift ;;
      -*) die "unknown view flag: $1" ;;
      *)  [[ -z "$arg" ]] || die "view: extra arg '$1'"; arg="$1"; shift ;;
    esac
  done
  require_in_repo

  local prefix=""
  if [[ -n "$OPT_PREFIX" ]]; then
    prefix="${OPT_PREFIX%/}/"
  elif [[ -n "$arg" ]]; then
    # Named stack (trailing "/" optional). Accept a known prefix; else pick.
    local want="${arg%/}/" pfx found=""
    while IFS= read -r pfx; do
      [[ "$pfx" == "$want" ]] && found="$pfx"
    done < <(stack_prefixes)
    if [[ -n "$found" ]]; then
      prefix="$found"
    else
      prefix=$(_select_stack "stack") || die "view: no stack selected (unknown stack '$arg')"
    fi
  else
    # No arg: current stack, else pick from outside.
    prefix=$(_try_detect_prefix "" 2>/dev/null) || prefix=""
    if [[ -z "$prefix" ]]; then
      prefix=$(_select_stack "stack") || die "view: no stack selected"
    fi
  fi

  local current
  current=$(require_branch)
  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches found for prefix '$prefix'"

  if (( OPT_FETCH )); then
    log "${C_DIM}fetching all remotes...${C_RESET}"
    local fetch_out fetch_rc=0
    fetch_out=$(git fetch --all --prune 2>&1) || fetch_rc=$?
    if (( fetch_rc != 0 )); then
      printf '%s\n' "$fetch_out" >&2
      warn "git fetch failed; counts may be stale"
    elif (( ! QUIET )); then
      # Bucket each ref-change line by its leading flag char:
      #   "   " (3 spaces) = fast-forward update
      #   " * " = new ref       " - " = pruned/deleted
      #   " + " = forced update " t " = tag update  " ! " = rejected
      local updated=0 new=0 deleted=0 rejected=0 line
      while IFS= read -r line; do
        case "$line" in
          "   "*|" + "*|" t "*) updated=$((updated + 1)) ;;
          " * "*)               new=$((new + 1)) ;;
          " - "*)               deleted=$((deleted + 1)) ;;
          " ! "*)               rejected=$((rejected + 1)) ;;
        esac
      done < <(printf '%s\n' "$fetch_out" | grep '^[[:space:]]' || true)
      local total=$((updated + new + deleted + rejected))
      if (( total == 0 )); then
        printf '%s  (no remote changes)%s\n' "$C_DIM" "$C_RESET"
      else
        local parts="" sep=""
        (( updated  > 0 )) && parts="${parts}${sep}${updated} updated"   && sep=", "
        (( new      > 0 )) && parts="${parts}${sep}${new} new"           && sep=", "
        (( deleted  > 0 )) && parts="${parts}${sep}${deleted} deleted"   && sep=", "
        (( rejected > 0 )) && parts="${parts}${sep}${rejected} rejected" && sep=", "
        printf '%s  fetched: %s%s\n' "$C_DIM" "$parts" "$C_RESET"
      fi
    fi
  fi

  local parent_name parent_ref parent_state
  if parent_name=$(_resolve_parent_name); then
    if parent_ref=$(_resolve_parent_ref "$parent_name"); then
      parent_state=$(_parent_state "${branches[0]}" "$parent_ref")
      printf '%sparent:%s %s%s%s  %s\n\n' \
        "$C_BOLD" "$C_RESET" "$C_CYAN" "$parent_ref" "$C_RESET" "$parent_state"
    fi
  fi

  local b sha subj branch_color marker status
  for b in "${branches[@]}"; do
    sha=$(git rev-parse --short "$b")
    subj=$(git log -1 --format='%s' "$b")
    status=$(_upstream_status "$b")
    if [[ "$b" == "$current" ]]; then
      marker="${C_GREEN}*${C_RESET}"
      branch_color="${C_BOLD}${C_CYAN}"
    else
      marker=" "
      branch_color="${C_CYAN}"
    fi
    printf '%s %s%s%s  %s\n'  "$marker"  "$branch_color" "$b"   "$C_RESET" "$status"
    printf '    %s%s%s  %s\n' "$C_DIM"   "$sha"          "$C_RESET" "$subj"
  done

  local last_snap last_ts last_action last_run last_count last_age
  last_snap=$(list_snapshots "${prefix%/}" | head -1)
  if [[ -n "$last_snap" ]]; then
    IFS=$'\t' read -r last_ts last_action last_run last_count <<< "$last_snap"
    last_age=$(_human_age $(($(date +%s) - last_ts)))
    printf '\n%slast snapshot:%s %s ago (%s, %s%s%s, %d branches)\n' \
      "$C_BOLD" "$C_RESET" "$last_age" "$last_action" "$C_CYAN" "$last_run" "$C_RESET" "$last_count"
  fi

  # Paused-op banner: a one-liner if a reflow is mid-flight (state file present)
  # or a git operation is in progress. Resume/abort guidance, not a state dump.
  local sf; sf=$(state_file)
  if [[ -f "$sf" ]]; then
    load_state
    local cur_phase=""
    (( ${#STACK_PHASES[@]} > 0 )) && cur_phase="${STACK_PHASES[$STACK_PHASE_IDX]}"
    printf '\n%spaused:%s %s reflow at %s%s%s — resume with %sgit stack continue%s %s[gstkcon]%s or %sgit stack abort%s %s[gstkab]%s\n' \
      "$C_YELLOW" "$C_RESET" "${cur_phase:-?}" "$C_CYAN" "${STACK_PREFIX:-$prefix}" "$C_RESET" \
      "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET" "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET"
  else
    local gitdir op=""
    gitdir=$(git rev-parse --git-dir)
    local m
    for m in CHERRY_PICK_HEAD MERGE_HEAD REVERT_HEAD rebase-merge rebase-apply; do
      [[ -e "$gitdir/$m" ]] && { op="$m"; break; }
    done
    if [[ -n "$op" ]]; then
      printf '\n%sin progress:%s %s%s%s (git operation, not a stack reflow)\n' \
        "$C_YELLOW" "$C_RESET" "$C_RED" "$op" "$C_RESET"
    fi
  fi
}

# Choose a stack from the all-stacks selector and check out its tip (the
# highest-leaf branch) — a fast hop, even from inside another stack. Use
# `checkout` to land on a specific branch instead.
cmd_pick() {
  OPT_PREFIX=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      -*) die "unknown pick flag: $1" ;;
      *)  die "pick: unexpected arg '$1' (pick takes no arguments)" ;;
    esac
  done
  require_in_repo

  local prefix
  prefix=$(_select_stack "pick stack") \
    || die "no stacks found; create one with 'git stack create <prefix> <slug>' ${C_DIM}[gstkcr]${C_RESET}"
  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under '$prefix'"
  local tip="${branches[$(( ${#branches[@]} - 1 ))]}"
  git checkout "$tip"
}

# Render seconds as "Ns", "Nm", "Nh", "Nd". Approximate; for human display only.
_human_age() {
  local s=$1
  if   (( s < 60 ));    then printf '%ds' "$s"
  elif (( s < 3600 ));  then printf '%dm' "$((s / 60))"
  elif (( s < 86400 )); then printf '%dh' "$((s / 3600))"
  else                       printf '%dd' "$((s / 86400))"
  fi
}

cmd_history() {
  # Sub-dispatch: 'history', 'history show <id>', 'history restore <id>'.
  OPT_PREFIX=""
  local sub="" id="" yes=0
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --yes|-y)     yes=1; shift ;;
      -*) die "unknown history flag: $1" ;;
      *)
        if [[ -z "$sub" ]]; then sub="$1"
        elif [[ -z "$id" ]]; then id="$1"
        else die "history: extra arg '$1'"
        fi
        shift
        ;;
    esac
  done
  require_in_repo
  local prefix prefix_path
  prefix=$(detect_prefix "$OPT_PREFIX")
  prefix_path="${prefix%/}"

  case "${sub:-list}" in
    list)    cmd_history_list "$prefix_path" ;;
    show)    [[ -n "$id" ]] || die "history show: missing <run-id>"
             cmd_history_show "$prefix_path" "$id" ;;
    restore) [[ -n "$id" ]] || die "history restore: missing <run-id>"
             cmd_history_restore "$prefix_path" "$id" "$yes" ;;
    *) die "unknown history subcommand: $sub (try 'list', 'show', or 'restore')" ;;
  esac
}

cmd_history_list() {
  local prefix_path="$1"
  local snaps now idx ts action run_id count age focus
  snaps=$(list_snapshots "$prefix_path")
  if [[ -z "$snaps" ]]; then
    log "${C_DIM}(no snapshots for ${prefix_path}/)${C_RESET}"
    return 0
  fi
  now=$(date +%s)
  printf '%sprefix:%s %s/\n\n' "$C_DIM" "$C_RESET" "$prefix_path"
  # focus is the last column (variable-width, may carry multi-byte glyphs), so it
  # needs no padding and never shifts the columns before it.
  printf '  %s%-4s  %-7s  %-8s  %-32s  %s%s\n' \
    "$C_BOLD" "ref" "age" "action" "run-id" "focus" "$C_RESET"
  idx=0
  while IFS=$'\t' read -r ts action run_id count; do
    [[ -z "$run_id" ]] && continue
    age=$(_human_age $((now - ts)))
    focus=$(_render_focus "$action" "$(snapshot_focus_for "$prefix_path" "$run_id")")
    [[ -n "$focus" ]] || focus="—"
    printf '  %s@%-3d%s %-7s  %-8s  %s%-32s%s  %s\n' \
      "$C_GREEN" "$idx" "$C_RESET" \
      "$age" "$action" "$C_CYAN" "$run_id" "$C_RESET" "$focus"
    idx=$((idx + 1))
  done <<< "$snaps"
}

cmd_history_show() {
  local prefix_path="$1" input="$2"
  local run_id leaf saved_sha cur_sha branch
  run_id=$(parse_run_id "$prefix_path" "$input")
  printf '%srun-id:%s %s\n%sprefix:%s %s/\n\n' \
    "$C_DIM" "$C_RESET" "$run_id" "$C_DIM" "$C_RESET" "$prefix_path"
  while IFS=$'\t' read -r leaf saved_sha; do
    [[ -z "$leaf" ]] && continue
    branch="${prefix_path}/${leaf}"
    cur_sha=$(git rev-parse --verify --quiet "refs/heads/$branch" 2>/dev/null || echo "")
    local subj
    subj=$(git log -1 --format='%s' "$saved_sha" 2>/dev/null || echo "?")
    printf '  %s%s%s\n' "$C_CYAN" "$branch" "$C_RESET"
    printf '    %ssaved:%s    %s  %s\n' "$C_DIM" "$C_RESET" "${saved_sha:0:10}" "$subj"
    if [[ -z "$cur_sha" ]]; then
      printf '    %scurrent:%s  %s(branch deleted)%s\n' "$C_DIM" "$C_RESET" "$C_YELLOW" "$C_RESET"
    elif [[ "$cur_sha" == "$saved_sha" ]]; then
      printf '    %scurrent:%s  %s  %s= snapshot%s\n' "$C_DIM" "$C_RESET" "${cur_sha:0:10}" "$C_GREEN" "$C_RESET"
    else
      local ahead behind
      ahead=$(git rev-list --count "$saved_sha..refs/heads/$branch" 2>/dev/null || echo "?")
      behind=$(git rev-list --count "refs/heads/$branch..$saved_sha" 2>/dev/null || echo "?")
      printf '    %scurrent:%s  %s  %sdiverged: local +%s, snapshot +%s%s\n' \
        "$C_DIM" "$C_RESET" "${cur_sha:0:10}" "$C_YELLOW" "$ahead" "$behind" "$C_RESET"
    fi
  done < <(snapshot_branches_for "$prefix_path" "$run_id")
}

cmd_history_restore() {
  local prefix_path="$1" input="$2" yes="$3"
  require_no_state_file
  require_clean_tree
  local run_id
  run_id=$(parse_run_id "$prefix_path" "$input")

  local pairs=() leaf saved_sha branch
  while IFS=$'\t' read -r leaf saved_sha; do
    [[ -z "$leaf" ]] && continue
    pairs+=("${leaf}"$'\t'"${saved_sha}")
  done < <(snapshot_branches_for "$prefix_path" "$run_id")
  (( ${#pairs[@]} > 0 )) || die "snapshot ${run_id} is empty"

  local entry
  for entry in "${pairs[@]}"; do
    leaf="${entry%%$'\t'*}"
    branch="${prefix_path}/${leaf}"
    require_branch_not_in_worktree "$branch"
  done

  local current
  current=$(current_branch || true)

  if (( ! yes )); then
    log "${C_BOLD}dry run${C_RESET} (pass --yes to apply):"
  else
    log "${C_GREEN}restore${C_RESET} run-id ${C_CYAN}${run_id}${C_RESET}"
  fi

  local stdin=""
  for entry in "${pairs[@]}"; do
    leaf="${entry%%$'\t'*}"
    saved_sha="${entry##*$'\t'}"
    branch="${prefix_path}/${leaf}"
    local cur_sha
    cur_sha=$(git rev-parse --verify --quiet "refs/heads/$branch" 2>/dev/null || echo "0000000000000000000000000000000000000000")
    if [[ "$cur_sha" == "$saved_sha" ]]; then
      log "  ${C_DIM}skip${C_RESET}    ${C_CYAN}$branch${C_RESET} (already at ${saved_sha:0:10})"
      continue
    fi
    if [[ "$branch" == "$current" ]]; then
      if (( yes )); then
        die "current branch '$branch' would be reset; checkout away first"
      fi
      log "  ${C_YELLOW}refuse${C_RESET}  ${C_CYAN}$branch${C_RESET} (current branch — checkout away to apply)"
      continue
    fi
    log "  ${C_GREEN}set${C_RESET}     ${C_CYAN}$branch${C_RESET} ${cur_sha:0:10} -> ${saved_sha:0:10}"
    stdin+="update refs/heads/${branch} ${saved_sha}"$'\n'
  done

  if (( ! yes )); then
    log ""
    log "rerun with: ${C_BOLD}git stack history restore ${input} --yes${C_RESET} ${C_DIM}[gstkhr]${C_RESET}"
    return 0
  fi
  if [[ -z "$stdin" ]]; then
    log "${C_DIM}no changes${C_RESET}"
    return 0
  fi
  printf '%s' "$stdin" | git update-ref --stdin -m "git-stack history restore ${run_id}" \
    || die "git update-ref failed"
  log "${C_GREEN}done${C_RESET}    restored from ${run_id}"

  # A restore only resets/re-creates the snapshotted refs; a prior fold/move
  # that renamed a branch leaves the renamed ref behind, which can now collide
  # on a leaf with a just-restored branch. Surface any such leftovers.
  _warn_duplicate_leaves "$prefix_path"
}

# Warn (to stderr) when two or more branches under the prefix share a leaf
# number — e.g. a fold/move rename whose old name was re-created by a restore.
# Usage: _warn_duplicate_leaves <prefix_path>
_warn_duplicate_leaves() {
  local prefix_path="$1"
  [[ -n "$prefix_path" ]] || return 0
  local branches=()
  _load_stack_branches "${prefix_path}/" branches
  (( ${#branches[@]} > 1 )) || return 0
  local dups b seg
  dups=$(
    for b in "${branches[@]}"; do
      seg="${b##*/}"
      printf '%s\t%s\n' "${seg%%-*}" "$b"
    done | sort | awk -F'\t' '
      { c[$1]++; list[$1] = list[$1] (list[$1] ? ", " : "") $2 }
      END { for (k in c) if (c[k] > 1) print list[k] }
    '
  )
  [[ -n "$dups" ]] || return 0
  warn "duplicate leaf numbers remain — a prior fold/move rename left branches sharing a leaf:"
  local line
  while IFS= read -r line; do
    [[ -n "$line" ]] && printf '  %s%s%s\n' "$C_YELLOW" "$line" "$C_RESET" >&2
  done <<< "$dups"
  printf '  delete the unwanted branch, or run %sgit stack doctor%s %s[gstkd]%s to reconcile\n' \
    "$C_BOLD" "$C_RESET" "$C_DIM" "$C_RESET" >&2
}

# Yes/no confirmation. Prints "<prompt> [y/N] " to stderr, reads one char from
# the tty. Returns 0 only on an explicit y/yes. Non-TTY → returns 1 (no).
_confirm() {
  local prompt="$1"
  [[ -e /dev/tty ]] || return 1
  printf '%s%s [y/N]%s ' "$C_DIM" "$prompt" "$C_RESET" >&2
  local ans
  read -r ans < /dev/tty || return 1
  ans=$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')
  [[ "${ans:0:1}" == "y" ]]
}

# Tidy a stack: prune local branches whose upstream is [gone], delete remote
# branches under the prefix that have no local counterpart (confirm-gated —
# declining skips only that step), then reflow the survivors onto
# origin/<default>. Replaces `close` + the old `gstkcl`/`gstkrom` helpers.
# Walk the survivors and report the lowest index at which a branch is no longer
# threaded on its predecessor's tip (pred_tip(0)=base_ref, pred_tip(i)=tip of
# survivor[i-1]). Echoes that index, or nothing when the whole stack is threaded.
# An empty base_ref skips the i=0 check (offline/degenerate — no trunk to anchor
# the bottom branch against), so only internal drift (i >= 1) is reported.
# This single walk unifies moved-base, mid-stack prune orphans, and local drift.
_clean_drift_from_idx() {
  local base_ref="$1"; shift
  local survivors=("$@")
  local n=${#survivors[@]} i pred
  for ((i = 0; i < n; i++)); do
    if (( i == 0 )); then
      [[ -n "$base_ref" ]] || continue
      pred="$base_ref"
    else
      pred="refs/heads/${survivors[i-1]}"
    fi
    if ! git merge-base --is-ancestor "$pred" "refs/heads/${survivors[i]}" 2>/dev/null; then
      printf '%s\n' "$i"
      return 0
    fi
  done
  return 0
}

cmd_clean() {
  OPT_PREFIX=""
  local opt_dry_run=0 opt_keep_history=0
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --dry-run)       opt_dry_run=1; shift ;;
      --keep-history)  opt_keep_history=1; shift ;;
      -*) die "unknown clean flag: $1" ;;
      *)  die "clean: unexpected arg '$1'" ;;
    esac
  done

  require_in_repo
  require_no_op_in_progress
  require_no_state_file

  # Resolve the target prefix from the *current* stack branch (or --prefix)
  # before HEAD can move underneath us.
  local prefix prefix_path default_branch
  prefix=$(detect_prefix "$OPT_PREFIX")
  prefix_path="${prefix%/}"
  default_branch=$(cmd_default_branch)

  # 1. Fetch so [gone] tracking + the remote branch list are current.
  if (( ! opt_dry_run )); then
    log "${C_DIM}fetching all remotes...${C_RESET}"
    git fetch --all --prune >/dev/null 2>&1 || warn "git fetch failed; [gone]/remote state may be stale"
  fi

  # 2. If the current HEAD is a [gone] branch under this prefix, hop to the
  #    default branch first so the prune below can delete it.
  local current
  current=$(current_branch || echo "")
  if (( ! opt_dry_run )) && [[ -n "$current" && "$current" == "${prefix}"* ]]; then
    local cur_track
    cur_track=$(git for-each-ref --format='%(upstream:track)' "refs/heads/$current")
    if [[ "$cur_track" == "[gone]" ]]; then
      log "${C_DIM}current branch '$current' upstream is gone; switching to $default_branch${C_RESET}"
      git checkout -q "$default_branch" || die "clean: cannot checkout '$default_branch'"
      git pull --ff-only --quiet 2>/dev/null || warn "clean: 'git pull --ff-only' on $default_branch failed; continuing"
      current=$(current_branch || echo "")
    fi
  fi

  local branches=()
  _load_stack_branches "$prefix" branches

  # 3. Plan the local [gone] prune.
  local gone=() leaves=() b track
  for b in "${branches[@]}"; do
    track=$(git for-each-ref --format='%(upstream:track)' "refs/heads/$b")
    if [[ "$track" == "[gone]" ]]; then
      gone+=("$b")
      leaves+=("${b##*/}")
    fi
  done

  local stdin="" sha gone_shas=()
  if (( ${#gone[@]} > 0 )); then
    for b in "${gone[@]}"; do
      [[ "$b" == "$current" ]] && die "branch '$b' is current HEAD; checkout away first"
      require_branch_not_in_worktree "$b"
      sha=$(git rev-parse "refs/heads/$b")
      gone_shas+=("$sha")
      stdin+="delete refs/heads/${b} ${sha}"$'\n'
    done
    local removed_history=0
    if (( ! opt_keep_history )); then
      local refname leaf gleaf
      while IFS= read -r refname; do
        [[ -z "$refname" ]] && continue
        leaf="${refname##*/}"
        for gleaf in "${leaves[@]}"; do
          if [[ "$leaf" == "$gleaf" ]]; then
            stdin+="delete ${refname}"$'\n'
            removed_history=$((removed_history + 1))
            break
          fi
        done
      done < <(git for-each-ref --format='%(refname)' "refs/stack-backup/${prefix_path}/")
    fi
    log "${C_YELLOW}prune${C_RESET}   ${#gone[@]} local branch(es) with gone upstream:"
    for b in "${gone[@]}"; do
      sha=$(git rev-parse --short "refs/heads/$b")
      log "  ${C_DIM}delete${C_RESET}  ${C_CYAN}${b}${C_RESET} (${sha})"
    done
    if (( removed_history > 0 )); then
      log "  ${C_DIM}+ ${removed_history} backup ref(s)${C_RESET}"
    elif (( ! opt_keep_history )); then
      log "  ${C_DIM}(no matching backup refs)${C_RESET}"
    fi
  else
    log "${C_DIM}no local branches under '${prefix}' have a gone upstream${C_RESET}"
  fi

  # 4. Find remote branches under the prefix with no local counterpart.
  local remote_orphans=() rref lname rleaf
  while IFS= read -r rref; do
    [[ -z "$rref" ]] && continue
    lname="${rref#origin/}"
    [[ "$lname" == "${prefix}"* ]] || continue
    rleaf="${lname##*/}"
    [[ "$rleaf" =~ ^[0-9]+- ]] || continue
    git show-ref -q --verify "refs/heads/$lname" || remote_orphans+=("$lname")
  done < <(git for-each-ref --format='%(refname:short)' "refs/remotes/origin/${prefix}*")

  # 5. Compute the reflow plan (read-only) before any mutation.
  #    Survivors = branches that remain after the prune, in stack order.
  local survivors=() s_b s_g s_is_gone
  for s_b in "${branches[@]}"; do
    s_is_gone=0
    for s_g in "${gone[@]+"${gone[@]}"}"; do [[ "$s_b" == "$s_g" ]] && { s_is_gone=1; break; }; done
    (( s_is_gone )) || survivors+=("$s_b")
  done

  # Resolve the base via the shared resolver: honors stack.base (fixes a clean-
  # only inconsistency vs other verbs), returns origin/<base> when a remote
  # exists, falls back to a local trunk when offline, and is empty only when no
  # trunk resolves at all.
  local base_name="" base_ref=""
  base_name=$(_resolve_parent_name 2>/dev/null) || base_name=""
  if [[ -n "$base_name" ]]; then
    base_ref=$(_resolve_parent_ref "$base_name" 2>/dev/null) || base_ref=""
  fi

  # The ancestor walk is the sole reflow driver: the lowest survivor index that
  # drifted off its predecessor's tip. Empty => the stack is threaded.
  local from_idx=""
  if (( ${#survivors[@]} > 0 )); then
    from_idx=$(_clean_drift_from_idx "$base_ref" "${survivors[@]}")
  fi

  # When the bottom branch drifted off the base (from_idx==0), distinguish an
  # advanced trunk (loud) from a locally-diverged bottom branch (quiet).
  local base_advanced=0 b_old_base="" b_onto_sha="" b_range=""
  if [[ "$from_idx" == 0 && -n "$base_ref" ]]; then
    b_onto_sha=$(git rev-parse "$base_ref" 2>/dev/null || true)
    b_old_base=$(git merge-base "refs/heads/${survivors[0]}" "$base_ref" 2>/dev/null || true)
    if [[ -n "$b_old_base" && -n "$b_onto_sha" ]]; then
      local b_adv
      b_adv=$(git rev-list --count "${b_old_base}..${b_onto_sha}" 2>/dev/null || echo 0)
      if (( b_adv > 0 )); then
        base_advanced=1
        b_range=" ${C_DIM}$(git rev-parse --short "$b_old_base")..$(git rev-parse --short "$b_onto_sha")${C_RESET} (+${b_adv} commit(s))"
      fi
    fi
  fi

  # Pre-flight resolvability: a survivor we'd reflow may thread commits beyond its
  # predecessor. Those are safe to drop only when they're branches clean just
  # pruned (merged). Detect an *unmergeable* extra here — current SHAs vs the gone
  # set — so the run refuses atomically (before prune/snapshot) instead of dying
  # mid-reflow. Mirrors the engine's multi-commit guard; the engine stays the
  # backstop for restack/move/drop. (Extras shared with the predecessor are
  # masked, but those are either merged-safe or the predecessor's own problem;
  # an unmerged commit unique to this survivor is never in the predecessor.)
  local pf_msg="" pf_i pf_pred pf_s pf_total pf_collapse=()
  if [[ -n "$from_idx" ]]; then
    for ((pf_i = from_idx; pf_i < ${#survivors[@]}; pf_i++)); do
      if (( pf_i == 0 )); then
        [[ -n "$base_ref" ]] || continue
        pf_pred="$base_ref"
      else
        pf_pred="refs/heads/${survivors[$((pf_i - 1))]}"
      fi
      pf_s="refs/heads/${survivors[$pf_i]}"
      # Gate on the engine's own multi-commit condition (reachable-count diff, not
      # a two-dot range — see do_one_step). A single-commit branch never trips the
      # guard, even with an amended predecessor whose pick goes empty (absorbed).
      pf_total=$(( $(git rev-list --count "$pf_s" 2>/dev/null || echo 0) \
                 - $(git rev-list --count "$pf_pred" 2>/dev/null || echo 0) ))
      (( pf_total > 1 )) || continue
      if ! _reflow_own_only "$pf_pred" "$pf_s" ${gone_shas[@]+"${gone_shas[@]}"}; then
        pf_msg="clean: branch '${survivors[$pf_i]}' has commit(s) beyond '${pf_pred#refs/heads/}' that aren't in the branches it just pruned — clean won't drop work it didn't prune. Squash/rebase '${survivors[$pf_i]}' to a single commit and retry, or run 'git stack restack --onto ${base_ref:-<base>} --force' to cherry-pick tips and deliberately drop them."
        break
      fi
      # Resolvable multi-commit => the reflow tip-only-collapses it. Record the
      # dropped count for the live note / dry-run forecast.
      pf_collapse+=("${survivors[$pf_i]}:$((pf_total - 1))")
    done
  fi

  # 6. Dry-run: print the plan (incl. the walk-driven reflow forecast) and stop.
  if (( opt_dry_run )); then
    if (( ${#remote_orphans[@]} > 0 )); then
      log "${C_YELLOW}remote${C_RESET}  ${#remote_orphans[@]} remote branch(es) under '${prefix}' with no local counterpart:"
      for lname in "${remote_orphans[@]}"; do log "  ${C_DIM}delete${C_RESET}  ${C_CYAN}origin/${lname}${C_RESET}"; done
    fi
    log ""
    if [[ -n "$pf_msg" ]]; then
      log "${C_BOLD}dry run${C_RESET}: would refuse — ${pf_msg#clean: }"
    elif [[ -z "$from_idx" ]]; then
      log "${C_BOLD}dry run${C_RESET}: stack threaded on ${base_ref:-the base}; would skip reflow"
    elif [[ "$from_idx" == 0 ]]; then
      if (( base_advanced )); then
        log "${C_BOLD}dry run${C_RESET}: ${base_ref} has moved${b_range}; would reflow ${#survivors[@]} survivor(s) onto it"
      else
        log "${C_BOLD}dry run${C_RESET}: bottom branch diverged from ${base_ref:-the base}; would reflow ${#survivors[@]} survivor(s)"
      fi
    else
      log "${C_BOLD}dry run${C_RESET}: drift at ${survivors[$from_idx]}; would reflow from ${survivors[$from_idx]} up; rerun without --dry-run to apply"
    fi
    local pf_c
    for pf_c in ${pf_collapse[@]+"${pf_collapse[@]}"}; do
      log "  ${C_DIM}would reflow ${pf_c%%:*} tip-only, dropping ${pf_c##*:} superseded commit(s)${C_RESET}"
    done
    return 0
  fi

  # Refuse atomically: an unresolvable survivor would otherwise die mid-reflow
  # with the prune already applied. Bail here, before any ref is touched.
  [[ -n "$pf_msg" ]] && die "$pf_msg"

  # 7. Guard: a reflow rewrites refs, so require a clean tree *now* — before any
  #    mutation (incl. the snapshot below) — so a dirty tree bails with nothing
  #    touched. A prune-only run does not need a clean tree, so the guard is
  #    conditional on a planned reflow.
  if [[ -n "$from_idx" ]]; then
    require_clean_tree
  fi

  # 8. Up-front snapshot: one anchor covering prune + reflow, taken before any
  #    branch mutation, so a single `history restore` undoes both. Local refs
  #    only — remote deletions are not snapshotted and stay deleted across a
  #    restore. The nested reflow's own snapshot is suppressed (see step 11) so
  #    this one is the sole restore point.
  if (( ${#gone[@]} > 0 )) || [[ -n "$from_idx" ]]; then
    # Compound focus: clean can prune and reflow in one run. base→ when the
    # bottom reflows onto an advanced trunk; from: for an internal-drift reflow.
    # NL outside the quotes — $'\n' inside "${:+…}" is version-dependent.
    local _cf="" NL=$'\n'
    (( ${#gone[@]} > 0 )) && _cf="pruned=${#gone[@]}"
    if [[ "$from_idx" == 0 && -n "$base_ref" ]] && (( base_advanced )); then
      [[ -n "$_cf" ]] && _cf="$_cf$NL"
      _cf="${_cf}base=${base_ref##*/}"
    elif [[ -n "$from_idx" ]] && (( from_idx > 0 )); then
      [[ -n "$_cf" ]] && _cf="$_cf$NL"
      _cf="${_cf}from=${survivors[$from_idx]##*/}"
    fi
    _SNAPSHOT_FOCUS="$_cf"
    snapshot_stack clean "$prefix" "${branches[@]}"
  fi

  # 9. Apply the local prune.
  if (( ${#gone[@]} > 0 )); then
    if ! printf '%s' "$stdin" | git update-ref --stdin -m "git-stack clean" 2>/dev/null; then
      die "git update-ref batch failed; refs unchanged (atomic)"
    fi
    log "${C_GREEN}pruned${C_RESET}  ${#gone[@]} local branch(es)"
  fi

  # 10. Delete remote orphans (confirm-gated; declining skips only this step).
  if (( ${#remote_orphans[@]} > 0 )); then
    log "${C_YELLOW}remote${C_RESET}  ${#remote_orphans[@]} remote branch(es) under '${prefix}' with no local counterpart:"
    for lname in "${remote_orphans[@]}"; do log "  ${C_CYAN}origin/${lname}${C_RESET}"; done
    if _confirm "delete these on origin?"; then
      for lname in "${remote_orphans[@]}"; do
        if git push origin --delete "$lname" >/dev/null 2>&1; then
          log "  ${C_GREEN}deleted${C_RESET} origin/${lname}"
        else
          warn "failed to delete origin/${lname}"
        fi
      done
    else
      log "${C_DIM}skipped remote deletion${C_RESET}"
    fi
  fi

  # 11. Reflow per the walk. from_idx==0 => whole stack onto base; >0 => minimal
  #     reflow from the drift point up (branches below keep their SHAs/PRs).
  if (( ${#survivors[@]} == 0 )); then
    log "${C_DIM}no branches remain under '${prefix}'; nothing to reflow${C_RESET}"
    return 0
  fi
  if [[ -z "$from_idx" ]]; then
    log "${C_DIM}stack already on ${base_ref:-the base}; skipping reflow${C_RESET}"
    return 0
  fi
  # The up-front snapshot (step 8) already covers this reflow, so suppress the
  # redundant inner one cmd_restack would take.
  _SNAPSHOT_SUPPRESS=1
  # A survivor that still threads a just-pruned (merged) branch reads as a multi-
  # commit branch to the engine guard. Pass the pruned SHAs as the safe-to-drop
  # set so the reflow cherry-picks the tip and drops the proven-merged ancestors.
  REFLOW_SAFE_DROP=("${gone_shas[@]+"${gone_shas[@]}"}")
  if [[ "$from_idx" == 0 ]]; then
    if [[ -z "$base_ref" ]]; then
      warn "clean: base unresolved; cannot reflow the whole stack onto a trunk"
      return 0
    fi
    if (( base_advanced )); then
      log "${C_YELLOW}base${C_RESET}    ${base_ref} moved${b_range}; restacking ${C_BOLD}${#survivors[@]}${C_RESET} survivor(s) onto it"
    else
      log "${C_DIM}reflowing ${#survivors[@]} survivor(s) onto ${base_ref}...${C_RESET}"
    fi
    cmd_restack --prefix "$prefix" --onto "$base_ref"
  else
    if [[ -z "$base_ref" ]]; then
      warn "clean: base unresolved; re-threaded internally, did not rebase onto a trunk"
    fi
    log "${C_DIM}reflowing from ${C_RESET}${C_CYAN}${survivors[$from_idx]}${C_RESET}${C_DIM} up (drift detected)...${C_RESET}"
    cmd_restack --prefix "$prefix" --from "${survivors[$from_idx]}"
  fi
  _SNAPSHOT_SUPPRESS=0

  # 12. Advisory only (never mutating): a survivor whose tree now equals its
  #     predecessor's was absorbed during the reflow. clean deletes by remote-
  #     gone signal only, so point at doctor/fold rather than dropping it.
  local adv=() av_i
  _load_stack_branches "$prefix" adv
  for ((av_i = 1; av_i < ${#adv[@]}; av_i++)); do
    if git diff --quiet "refs/heads/${adv[av_i-1]}" "refs/heads/${adv[av_i]}" 2>/dev/null; then
      log "${C_YELLOW}note${C_RESET}    ${C_CYAN}${adv[av_i]}${C_RESET} is now empty (absorbed into ${C_CYAN}${adv[av_i-1]}${C_RESET}) — run ${C_BOLD}doctor${C_RESET} to drop it, or ${C_BOLD}fold${C_RESET} to collapse"
    fi
  done
}

cmd_rename() {
  OPT_PREFIX=""
  local opt_dry_run=0 opt_no_history=0 opt_allow_pr_rebuild=0 new_pfx=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --dry-run)          opt_dry_run=1; shift ;;
      --no-history)       opt_no_history=1; shift ;;
      --allow-pr-rebuild) opt_allow_pr_rebuild=1; shift ;;
      -*)                 die "unknown rename flag: $1" ;;
      *)                  [[ -z "$new_pfx" ]] || die "rename: extra arg '$1'"; new_pfx="$1"; shift ;;
    esac
  done
  [[ -n "$new_pfx" ]] || die "usage: git stack rename <new-prefix> [--dry-run] [--no-history] [--allow-pr-rebuild]"

  require_in_repo
  require_clean_tree
  require_no_op_in_progress
  require_no_state_file

  local old_pfx_full
  old_pfx_full=$(detect_prefix "$OPT_PREFIX")
  local old_pfx="${old_pfx_full%/}"
  new_pfx="${new_pfx%/}"

  [[ "$old_pfx" != "$new_pfx" ]] || die "rename: new prefix is the same as the old ('$old_pfx')"

  local branches=()
  _load_stack_branches "${old_pfx}/" branches "no stack branches found under '${old_pfx}/'"

  # Collision check.
  local b leaf collisions=()
  for b in "${branches[@]}"; do
    leaf="${b##*/}"
    if git rev-parse --verify --quiet "refs/heads/${new_pfx}/${leaf}" >/dev/null; then
      collisions+=("${new_pfx}/${leaf}")
    fi
  done
  if (( ${#collisions[@]} > 0 )); then
    warn "rename would collide with existing branches:"
    local c
    for c in "${collisions[@]}"; do warn "  $c"; done
    die "delete colliding branches first (e.g., git branch -D <name>)"
  fi

  # Worktree check.
  for b in "${branches[@]}"; do
    require_branch_not_in_worktree "$b"
  done

  # PR-orphan guard. Renaming the prefix renames every branch, which closes
  # any open head PRs on GitHub. Refuse by default unless --allow-pr-rebuild
  # or --no-push was passed.
  if (( ! opt_allow_pr_rebuild )) && (( ! OPT_NO_PUSH )) && (( ! opt_dry_run )); then
    if _check_no_open_prs "${branches[@]}"; then
      die "rename would orphan PR #${_ORPHAN_PR_NUM} for ${_ORPHAN_PR_BRANCH}; head-PRs can't survive a branch rename on GitHub. Pass --allow-pr-rebuild to accept the PR will be closed and recreated (a fresh PR opens for the renamed branch via 'pr sync'). Or run 'git stack pr desync' first to take the stack offline, then rename, then 'git stack pr sync' to re-publish cleanly."
    fi
  fi

  local batch
  batch=$(emit_rename_batch "$old_pfx" "$new_pfx" $((1 - opt_no_history)))
  if [[ -z "$batch" ]]; then
    die "nothing to rename (empty batch)"
  fi

  if (( opt_dry_run )); then
    log "${C_BOLD}dry run${C_RESET}: would run 'git update-ref --stdin' with:"
    printf '%s\n' "$batch"
    return 0
  fi

  log "${C_GREEN}rename${C_RESET}  ${C_CYAN}${old_pfx}/${C_RESET} -> ${C_CYAN}${new_pfx}/${C_RESET} (${#branches[@]} branches$([ "$opt_no_history" = 1 ] && echo "" || echo ", + history"))"

  # Retarget HEAD's symref BEFORE the batch deletes the old branch, otherwise
  # HEAD would dangle. Captured original target is restored if the batch fails.
  local head_target_before="" head_new_target=""
  if head_target_before=$(git symbolic-ref --quiet HEAD 2>/dev/null); then
    if [[ "$head_target_before" == "refs/heads/${old_pfx}/"* ]]; then
      head_new_target="refs/heads/${new_pfx}/${head_target_before#refs/heads/${old_pfx}/}"
      git symbolic-ref HEAD "$head_new_target"
    fi
  fi

  if ! printf '%s\n' "$batch" | git update-ref --stdin -m "git-stack rename ${old_pfx} -> ${new_pfx}"; then
    # Roll HEAD back to its original target.
    if [[ -n "$head_new_target" ]]; then
      git symbolic-ref HEAD "$head_target_before" 2>/dev/null || true
    fi
    die "git update-ref batch failed; refs unchanged (atomic)"
  fi

  # Update stack.prefix config if it pointed at the old prefix.
  local cfg
  cfg=$(git config --get stack.prefix 2>/dev/null || true)
  if [[ -n "$cfg" ]]; then
    local cfg_clean="${cfg%/}"
    if [[ "$cfg_clean" == "$old_pfx" ]]; then
      git config stack.prefix "${new_pfx}/"
      log "  ${C_DIM}config:${C_RESET} stack.prefix -> ${new_pfx}/"
    fi
  fi

  log "${C_GREEN}done${C_RESET}    rename complete"

  # Stage 2 + 3: remote rename + pr sync. Routed through the engine's
  # remote-sync phase (a one-phase plan) so a remote failure pauses with state
  # retained — 'continue' retries the idempotent phase — instead of dying with
  # only a manual-recovery hint. The local rename above stays inline: it does
  # stack.prefix config + HEAD retargeting that the generic rename-batch phase
  # doesn't cover.
  if (( ! OPT_NO_PUSH )); then
    local b leaf
    STACK_RENAME_PAIRS=()
    STACK_BRANCHES=()
    for b in "${branches[@]}"; do
      leaf="${b##*/}"
      STACK_RENAME_PAIRS+=("$b" "${new_pfx}/${leaf}")
      STACK_BRANCHES+=("${new_pfx}/${leaf}")
    done
    STACK_PREFIX="$new_pfx"
    STACK_OPT_NO_PUSH="$OPT_NO_PUSH"
    STACK_OPT_NO_SYNC="$OPT_NO_SYNC"
    # Capture the starting branch AFTER the inline rename retargeted HEAD, so
    # finalize/abort check out the new name (or main, if HEAD was not on the
    # renamed stack) — never the now-deleted old name.
    STACK_STARTING_BRANCH=$(current_branch 2>/dev/null || echo "")
    STACK_STARTED_AT=$(date +%s)
    STACK_ORIG_SHAS=()
    STACK_PUSH_FAILURES=()
    STACK_FROM_IDX=${#STACK_BRANCHES[@]}
    STACK_PUSH=0
    STACK_FORCE=0
    STACK_ONTO=""
    STACK_ONTO_REF=""
    STACK_PHASES=(remote-sync)
    STACK_PHASE_IDX=0
    STACK_UNIT_IDX=0
    save_engine_state
    _engine_run
  fi
}

# ---------- cmd_add helpers ----------

# Slug validation: permissive — allows letters, digits, underscores, hyphens.
# Must start with a letter or underscore. Slashes forbidden (they're the
# branch suffix separator).
#
# Returns 0 if valid; else sets _VALIDATE_MSG and returns 1 (no die). Callers on
# the argument path do `|| die "$cmd: $_VALIDATE_MSG"`; the interactive
# re-prompt loops show the message and ask again. The message carries no command
# prefix so either caller can frame it.
_validate_slug() {
  local s="$1"
  _VALIDATE_MSG=""
  if [[ -z "$s" ]]; then _VALIDATE_MSG="slug is required"; return 1; fi
  if [[ ! "$s" =~ ^[A-Za-z_][A-Za-z0-9_-]*$ ]]; then
    _VALIDATE_MSG="slug '$s' invalid (must match ^[A-Za-z_][A-Za-z0-9_-]*\$)"
    return 1
  fi
  return 0
}

# Prefix shape validation (mirrors the old bootstrap checks). Takes the raw
# prefix argument (no trailing slash required). Returns 0 if valid; else sets
# _VALIDATE_MSG and returns 1. Does NOT check emptiness-of-stack (that needs a
# repo + ref scan) — cmd_create does that separately.
_validate_prefix() {
  local p="${1%/}"
  _VALIDATE_MSG=""
  if [[ -z "$p" || "$p" == "/" ]]; then _VALIDATE_MSG="prefix is empty"; return 1; fi
  if [[ "$p" == /* ]]; then _VALIDATE_MSG="prefix must not start with /"; return 1; fi
  if [[ "$p" == *' '* ]]; then _VALIDATE_MSG="prefix must not contain spaces"; return 1; fi
  local first_seg="${p##*/}"
  if [[ "$first_seg" =~ ^[0-9]+- ]]; then
    _VALIDATE_MSG="prefix '$p/' would clash with leaf-numbering pattern"
    return 1
  fi
  return 0
}

# Prompt for a single required value on /dev/tty, re-editing a rejected prior
# entry in place where the shell supports it.
#
#   _prompt_prefill <label> <prev_value> <out_var>
#
# On bash 4+ the prior value is pre-filled on the input line (readline `-i`), so
# the user edits rather than retypes. On bash 3.2 (no `read -i`) it degrades to a
# blank prompt whose label already carries the rejected value + reason, so the
# information isn't lost — only the in-place edit is. Returns non-zero on EOF
# (Ctrl-D) so callers can abort; the read value lands in <out_var>.
_prompt_prefill() {
  local label="$1" prev="$2" out="$3" reply=""
  printf '%s%s%s ' "$C_DIM" "$label" "$C_RESET" >&2
  if (( BASH_VERSINFO[0] >= 4 )) && [[ -n "$prev" ]]; then
    read -e -i "$prev" -r reply < /dev/tty || return 1
  else
    read -r reply < /dev/tty || return 1
  fi
  printf -v "$out" '%s' "$reply"
}

# Check the stack for an existing branch with the given slug suffix.
# Returns 0 if collision found (and sets _SLUG_COLLISION_BRANCH); 1 if clear.
_SLUG_COLLISION_BRANCH=""
_check_slug_collision() {
  local slug="$1"; shift
  local b leaf rest
  for b in "$@"; do
    leaf="${b##*/}"
    rest="${leaf#*-}"
    if [[ "$rest" == "$slug" ]]; then
      _SLUG_COLLISION_BRANCH="$b"
      return 0
    fi
  done
  return 1
}

# Pick the next integer leaf number for an append (--last) at the given width.
# Width >= 3 (sparse): rounds up to the next multiple of 10. Empty stack returns 10.
# Width < 3 (legacy 2-digit): returns highest + 1. Empty stack returns 1.
# Args: <branch1> <branch2> ...  (sorted in stack order)
# Echoes the integer. Caller is responsible for refusing if result > 10^width - 1.
_next_leaf_num() {
  local width
  width=$(_leaf_width_for "$@")
  if (( $# == 0 )); then
    if (( width >= 3 )); then
      printf '10\n'
    else
      printf '1\n'
    fi
    return 0
  fi
  local last="${!#}"
  local leaf="${last##*/}"
  [[ "$leaf" =~ ^([0-9]+)- ]] || die "internal: leaf '$leaf' has no numeric prefix"
  local last_num=$((10#${BASH_REMATCH[1]}))
  if (( width >= 3 )); then
    printf '%d\n' $(( ((last_num / 10) + 1) * 10 ))
  else
    printf '%d\n' $((last_num + 1))
  fi
}

# Compute the midpoint leaf number between two existing leaf positions, with
# `lo < new < hi` (open interval). Echoes `floor((lo + hi) / 2)` on success;
# returns non-zero with no output when the gap is too small (`hi - lo < 2`).
# Usage: _midpoint_leaf <lo> <hi>
_midpoint_leaf() {
  local lo="$1" hi="$2"
  if (( hi - lo < 2 )); then
    return 1
  fi
  printf '%d\n' $(( (lo + hi) / 2 ))
}

# Pure placement resolver shared by cmd_add and cmd_move flag modes. Given a
# placement MODE, its ARG, the stack WIDTH, and the ordered branch list, decide
# the new leaf number and predecessor. No git, no die: it prints a result and
# returns a status so callers own the user-facing error message.
#
#   MODE    ARG             meaning
#   last    (ignored)       append at the end of the stack
#   at      <leaf-num>      explicit leaf placement
#   before  <full-branch>   insert just below an existing branch
#   after   <full-branch>   insert just above an existing branch
#
# before/after take an already-resolved full branch name (caller runs
# _resolve_branch_ref first). On success prints "<leaf><TAB><predecessor>"
# (empty predecessor = use the stack base) and returns 0. On failure prints one
# of the following and returns 1:
#   "ceiling<TAB><leaf>"            next/explicit leaf exceeds the 999 ceiling
#   "collision<TAB><branch>"        explicit leaf already taken
#   "gap-exhausted<TAB><lo><TAB><hi>"  no integer leaf fits the open (lo,hi)
#   "not-found<TAB><ref>"           before/after ref not in the stack
#
# Usage: _placement_resolve <mode> <arg> <width> <branch>...
_placement_resolve() {
  local mode="$1" arg="$2" width="$3"
  shift 3
  local branches=("$@")
  local n=$#

  case "$mode" in
    last)
      local new_num
      new_num=$(_next_leaf_num "${branches[@]+"${branches[@]}"}")
      if (( width >= 3 )) && (( new_num > 999 )); then
        printf 'ceiling\t%d\n' "$new_num"; return 1
      fi
      if (( n == 0 )); then
        printf '%d\t\n' "$new_num"
      else
        printf '%d\t%s\n' "$new_num" "${branches[$((n - 1))]}"
      fi
      ;;
    at)
      local new_num="$arg"
      if (( width >= 3 )) && (( new_num > 999 )); then
        printf 'ceiling\t%d\n' "$new_num"; return 1
      fi
      local b
      for b in "${branches[@]+"${branches[@]}"}"; do
        [[ "${b##*/}" =~ ^([0-9]+)- ]] || continue
        if (( 10#${BASH_REMATCH[1]} == new_num )); then
          printf 'collision\t%s\n' "$b"; return 1
        fi
      done
      local insert_idx=$n i
      for ((i = 0; i < n; i++)); do
        [[ "${branches[$i]##*/}" =~ ^([0-9]+)- ]] || continue
        if (( 10#${BASH_REMATCH[1]} > new_num )); then insert_idx=$i; break; fi
      done
      if (( insert_idx == 0 )); then
        printf '%d\t\n' "$new_num"
      else
        printf '%d\t%s\n' "$new_num" "${branches[$((insert_idx - 1))]}"
      fi
      ;;
    before)
      local ref_idx rc=0
      ref_idx=$(branch_index "$arg" "${branches[@]+"${branches[@]}"}") || rc=$?
      (( rc == 0 )) || { printf 'not-found\t%s\n' "$arg"; return 1; }
      [[ "${arg##*/}" =~ ^([0-9]+)- ]] || { printf 'not-found\t%s\n' "$arg"; return 1; }
      local hi=$((10#${BASH_REMATCH[1]})) lo pred
      if (( ref_idx == 0 )); then
        lo=0; pred=""
      else
        local prev="${branches[$((ref_idx - 1))]}"
        [[ "${prev##*/}" =~ ^([0-9]+)- ]] || { printf 'not-found\t%s\n' "$arg"; return 1; }
        lo=$((10#${BASH_REMATCH[1]})); pred="$prev"
      fi
      local mid
      if mid=$(_midpoint_leaf "$lo" "$hi"); then
        printf '%d\t%s\n' "$mid" "$pred"
      else
        printf 'gap-exhausted\t%d\t%d\n' "$lo" "$hi"; return 1
      fi
      ;;
    after)
      local ref_idx rc=0
      ref_idx=$(branch_index "$arg" "${branches[@]+"${branches[@]}"}") || rc=$?
      (( rc == 0 )) || { printf 'not-found\t%s\n' "$arg"; return 1; }
      [[ "${arg##*/}" =~ ^([0-9]+)- ]] || { printf 'not-found\t%s\n' "$arg"; return 1; }
      local lo=$((10#${BASH_REMATCH[1]}))
      if (( ref_idx == n - 1 )); then
        local new_num
        if (( width >= 3 )); then
          new_num=$(( ((lo / 10) + 1) * 10 ))
        else
          new_num=$((lo + 1))
        fi
        if (( width >= 3 )) && (( new_num > 999 )); then
          printf 'ceiling\t%d\n' "$new_num"; return 1
        fi
        printf '%d\t%s\n' "$new_num" "$arg"
      else
        local next="${branches[$((ref_idx + 1))]}"
        [[ "${next##*/}" =~ ^([0-9]+)- ]] || { printf 'not-found\t%s\n' "$arg"; return 1; }
        local hi=$((10#${BASH_REMATCH[1]})) mid
        if mid=$(_midpoint_leaf "$lo" "$hi"); then
          printf '%d\t%s\n' "$mid" "$arg"
        else
          printf 'gap-exhausted\t%d\t%d\n' "$lo" "$hi"; return 1
        fi
      fi
      ;;
  esac
  return 0
}

# Caller-side bridge over _placement_resolve: map its error kinds to a
# user-facing die() with command context, and resolve the predecessor into a
# ref. On success sets _PL_LEAF, _PL_PRED_REF, _PL_PRED_LABEL (an empty
# placement predecessor means "use the stack base", resolved here).
# Usage: _resolve_placement <cmd-context> <mode> <arg> <width> <branch>...
_resolve_placement() {
  local cmd="$1"; shift
  local out rc=0
  out=$(_placement_resolve "$@") || rc=$?
  if (( rc != 0 )); then
    local kind="${out%%$'\t'*}" rest="${out#*$'\t'}"
    case "$kind" in
      ceiling)
        die "$cmd: leaf space exhausted (would be $rest, max 999); pick an --at value or wait for doctor-reflow" ;;
      collision)
        die "$cmd: leaf is already taken by '$rest'" ;;
      gap-exhausted)
        die "$cmd: no insertable leaf between ${rest%%$'\t'*} and ${rest#*$'\t'} (gap exhausted); pick a different position or wait for doctor-reflow" ;;
      not-found)
        die "$cmd: '$rest' not in stack" ;;
      *)
        die "internal: placement failed: $out" ;;
    esac
  fi
  _PL_LEAF="${out%%$'\t'*}"
  local pred="${out#*$'\t'}"
  if [[ -z "$pred" ]]; then
    local parent_name
    parent_name=$(_resolve_parent_name) \
      || die "$cmd: cannot determine parent branch (set stack.base or create main/master)"
    _PL_PRED_REF=$(_resolve_parent_ref "$parent_name") \
      || die "$cmd: cannot resolve parent ref for '$parent_name'"
    _PL_PRED_LABEL="$parent_name"
  else
    _PL_PRED_REF="refs/heads/$pred"
    _PL_PRED_LABEL="$pred"
  fi
}

# Pure candidate-list generator for the interactive picker. Given the chosen
# reference branch, a before|after position, and the ordered branch list,
# produce the predecessor and a ranked list of insertable leaf numbers. No git,
# no die. On success prints "<predecessor><TAB><lo><TAB><hi><TAB><leaf> <leaf>
# ..." (empty predecessor = use the stack base; hi == -1 = open-ended append)
# and returns 0 — the bounds let the interactive picker validate free manual
# entry against the same open gap. On a too-tight gap prints
# "gap-exhausted<TAB><lo><TAB><hi>" and returns 1.
# Usage: _placement_candidates <ref_branch> <before|after> <branch>...
_placement_candidates() {
  local ref_branch="$1" pos="$2"
  shift 2
  local branches=("$@")
  local n=$#
  local ref_idx rc=0
  ref_idx=$(branch_index "$ref_branch" "${branches[@]+"${branches[@]}"}") || rc=$?
  (( rc == 0 )) || { printf 'not-found\t%s\n' "$ref_branch"; return 1; }
  [[ "${ref_branch##*/}" =~ ^([0-9]+)- ]] || { printf 'not-found\t%s\n' "$ref_branch"; return 1; }
  local ref_leaf_num=$((10#${BASH_REMATCH[1]}))

  local lo hi pred=""
  if [[ "$pos" == "before" ]]; then
    hi=$ref_leaf_num
    if (( ref_idx == 0 )); then
      lo=0; pred=""
    else
      local prev="${branches[$((ref_idx - 1))]}"
      [[ "${prev##*/}" =~ ^([0-9]+)- ]] || { printf 'not-found\t%s\n' "$ref_branch"; return 1; }
      lo=$((10#${BASH_REMATCH[1]})); pred="$prev"
    fi
  else  # after
    lo=$ref_leaf_num; pred="$ref_branch"
    if (( ref_idx == n - 1 )); then
      hi=-1  # open-ended (append)
    else
      local next="${branches[$((ref_idx + 1))]}"
      [[ "${next##*/}" =~ ^([0-9]+)- ]] || { printf 'not-found\t%s\n' "$ref_branch"; return 1; }
      hi=$((10#${BASH_REMATCH[1]}))
    fi
  fi

  local candidates=()
  if (( hi == -1 )); then
    local default_leaf=$(( ((lo / 10) + 1) * 10 ))
    candidates=("$default_leaf" "$((default_leaf + 10))" "$((default_leaf + 20))")
  elif (( hi - lo < 2 )); then
    printf 'gap-exhausted\t%d\t%d\n' "$lo" "$hi"; return 1
  else
    local mid=$(( (lo + hi) / 2 ))
    local gap=$((hi - lo - 1))  # valid leaves in the open interval
    if (( gap <= 10 )); then
      # Enumerate all valid leaves, midpoint first, then ascending fill.
      local k
      candidates+=("$mid")
      for ((k = lo + 1; k < hi; k++)); do
        (( k != mid )) && candidates+=("$k")
      done
    else
      # Curate ~5 spread options.
      local quart=$(( gap / 4 ))
      local eighth=$(( gap / 8 ))
      (( eighth < 1 )) && eighth=1
      candidates+=("$mid")
      (( mid - quart > lo )) && candidates+=("$((mid - quart))")
      (( mid + quart < hi )) && candidates+=("$((mid + quart))")
      (( mid - eighth > lo && mid - eighth != mid - quart )) && candidates+=("$((mid - eighth))")
      (( mid + eighth < hi && mid + eighth != mid + quart )) && candidates+=("$((mid + eighth))")
    fi
  fi
  printf '%s\t%d\t%d\t%s\n' "$pred" "$lo" "$hi" "${candidates[*]}"
  return 0
}

# Candidate leaves for a *renumber-in-place* (move's no-op-position path): the
# branch is not moving, so its valid leaves are the open interval between its
# fixed predecessor and successor. Unlike _placement_candidates (tuned to insert
# a NEW branch near a gap's midpoint), this centers on the branch's CURRENT leaf
# and expands outward, so "nudge 10 to ~12" surfaces 12 right away. Excludes the
# current leaf itself (picking it would be a no-op). hi == -1 means an open upper
# bound (renumbering the last branch). Prints space-separated leaves ascending,
# or nothing when the gap has no room.
# Usage: _renumber_candidates <cur-leaf> <lo> <hi>
_renumber_candidates() {
  local cur="$1" lo="$2" hi="$3"
  local out=() d=1 max=7
  while (( ${#out[@]} < max )); do
    local added=0 lower=$((cur - d))
    if (( lower > lo )); then out+=("$lower"); added=1; fi
    if (( ${#out[@]} < max )) && (( hi == -1 || cur + d < hi )); then
      out+=("$((cur + d))"); added=1
    fi
    (( added )) || break
    (( d++ ))
  done
  (( ${#out[@]} > 0 )) || return 0
  local sorted
  sorted=$(printf '%s\n' "${out[@]}" | sort -n)
  printf '%s\n' "${sorted//$'\n'/ }"
}

# Pure validator for a manually-entered leaf in the interactive leaf pickers.
# No git, no tty. Bounds mirror _placement_resolve: the valid slot is the open
# gap (lo,hi); hi == -1 is an open-ended append where only the 999 ceiling
# applies, and only when width >= 3 (2-digit stacks get no explicit upper bound,
# same as the --at flag path). <exclude> (may be empty) is a leaf to reject as a
# no-op — the branch's current leaf on move's renumber path. On success prints
# the normalized integer and returns 0. On failure prints an error kind and
# returns 1: "nan" | "low<TAB><lo>" | "high<TAB><hi>" | "ceiling<TAB>999" |
# "noop<TAB><exclude>".
# Usage: _validate_leaf_entry <value> <lo> <hi> <width> <exclude>
_validate_leaf_entry() {
  local value="$1" lo="$2" hi="$3" width="$4" exclude="$5"
  [[ "$value" =~ ^[0-9]+$ ]] || { printf 'nan\n'; return 1; }
  local x=$((10#$value))
  (( x > lo )) || { printf 'low\t%d\n' "$lo"; return 1; }
  if (( hi == -1 )); then
    if (( width >= 3 )) && (( x > 999 )); then printf 'ceiling\t999\n'; return 1; fi
  else
    (( x < hi )) || { printf 'high\t%d\n' "$hi"; return 1; }
  fi
  if [[ -n "$exclude" ]] && (( x == exclude )); then printf 'noop\t%d\n' "$exclude"; return 1; fi
  printf '%d\n' "$x"
  return 0
}

# Three-step interactive position picker for `cmd_add` and `cmd_move`. Drives
# the user through:
#   1. pick a reference branch from the stack
#   2. pick before/after that branch
#   3. pick a leaf number from a curated list within the gap
#
# On success, sets two globals for the caller:
#   _PICKED_LEAF_NUM    — the chosen integer leaf number
#   _PICKED_PREDECESSOR — branch name to use as predecessor, or empty string to
#                         indicate "use the stack base branch"
# Returns 0 on success, non-zero if the user aborts at any step or the gap is
# exhausted (in which case it die()s with the gap-exhausted message).
#
# Usage: _pick_position_for_new <branch1> <branch2> ...
# Caller is responsible for excluding the source branch when used from cmd_move.
_pick_position_for_new() {
  _PICKED_LEAF_NUM=""
  _PICKED_PREDECESSOR=""
  local branches=("$@")
  (( ${#branches[@]} > 0 )) || die "internal: _pick_position_for_new called with no branches"

  # Step 1: pick reference branch.
  local ref_branch
  ref_branch=$(_pick_one "branch to insert before/after:" "${branches[@]}") \
    || return 1

  # Step 2: pick before/after.
  local pos
  pos=$(_pick_one "position relative to $ref_branch:" "before $ref_branch" "after $ref_branch") \
    || return 1
  local pos_kw="before"
  if [[ "$pos" == "after $ref_branch" ]]; then pos_kw="after"; fi

  # Compute predecessor + ranked candidate leaves (pure).
  local out rc=0
  out=$(_placement_candidates "$ref_branch" "$pos_kw" "${branches[@]}") || rc=$?
  if (( rc != 0 )); then
    local kind="${out%%$'\t'*}" rest="${out#*$'\t'}"
    case "$kind" in
      gap-exhausted)
        die "no insertable leaf between ${rest%%$'\t'*} and ${rest#*$'\t'} (gap exhausted); pick a different position or wait for doctor-reflow" ;;
      *)
        die "internal: placement candidates failed: $out" ;;
    esac
  fi
  # Parse "<pred>\t<lo>\t<hi>\t<cands>" by hand: a leading empty predecessor
  # (base-insert) would be eaten by read's IFS-whitespace trimming of the tab.
  _PICKED_PREDECESSOR="${out%%$'\t'*}"
  local rest="${out#*$'\t'}"
  local lo="${rest%%$'\t'*}"; rest="${rest#*$'\t'}"
  local hi="${rest%%$'\t'*}"; rest="${rest#*$'\t'}"
  local candidates=() c
  for c in $rest; do candidates+=("$c"); done

  # Step 3: pick a suggested leaf or type any leaf valid for the gap. The
  # midpoint (first candidate) is the empty-input default.
  local width picked_leaf
  width=$(_leaf_width_for "${branches[@]}")
  picked_leaf=$(_pick_or_enter_leaf "leaf number:" "$lo" "$hi" "$width" "${candidates[0]}" "" "${candidates[@]}") \
    || return 1

  _PICKED_LEAF_NUM="$picked_leaf"
  return 0
}

cmd_add() {
  OPT_PREFIX=""; OPT_NO_SYNC=0; OPT_NO_PUSH=0; OPT_FORCE=0
  local slug="" opt_last=0 opt_before="" opt_after="" opt_at=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --last)    opt_last=1; shift ;;
      --first)   die "add: --first has been removed (it cascade-renumbered existing branches, which destroys their PRs on GitHub). Use '--before <ref>' instead — e.g. '--before <lowest-leaf>' to insert at the very start." ;;
      --before)  shift; [[ $# -gt 0 ]] || die "--before needs an argument"; opt_before="$1"; shift ;;
      --after)   shift; [[ $# -gt 0 ]] || die "--after needs an argument"; opt_after="$1"; shift ;;
      --at)      shift; [[ $# -gt 0 ]] || die "--at needs an argument"; opt_at="$1"; shift ;;
      --force)   OPT_FORCE=1; shift ;;
      -*)        die "unknown add flag: $1" ;;
      *)         [[ -z "$slug" ]] || die "add: extra arg '$1'"; slug="$1"; shift ;;
    esac
  done

  # If no slug was passed and we have a TTY, prompt for one. Non-TTY callers
  # still get the existing "slug is required" die from _validate_slug. (A
  # re-prompt loop here is a tracked follow-up; today this prompt is single-shot.)
  if [[ -z "$slug" ]] && [[ -e /dev/tty ]] && [[ -t 0 || -t 2 ]]; then
    printf '%sslug:%s ' "$C_DIM" "$C_RESET" >&2
    read -r slug < /dev/tty || die "add: aborted"
  fi

  _validate_slug "$slug" || die "add: $_VALIDATE_MSG"

  # --at requires a non-negative integer (no slugs or branch refs).
  if [[ -n "$opt_at" && ! "$opt_at" =~ ^[0-9]+$ ]]; then
    die "add --at: requires a non-negative integer leaf number (got '$opt_at'); use --before/--after for branch-relative inserts"
  fi

  # Mutual exclusion among position flags.
  local n_pos=$opt_last
  [[ -n "$opt_before" ]] && (( n_pos++ )) || true
  [[ -n "$opt_after"  ]] && (( n_pos++ )) || true
  [[ -n "$opt_at"     ]] && (( n_pos++ )) || true
  (( n_pos <= 1 )) || die "add: --last, --before, --after, --at are mutually exclusive"

  require_in_repo
  require_no_op_in_progress
  require_no_state_file
  # No require_clean_tree: a dirty tree is carried onto the new branch below
  # (see _carry_begin). Everything from here through placement resolution is
  # read-only, so dirty state flows through harmlessly.

  # `add` places a branch in the *current* stack only — no bootstrap. Starting
  # a brand-new stack is `create`; switching to an existing one is `pick`.
  local prefix=""
  if [[ -n "$OPT_PREFIX" ]]; then
    prefix="${OPT_PREFIX%/}/"
  elif prefix=$(_try_detect_prefix "" 2>/dev/null); then
    :  # ok
  else
    die "add: not in a stack. Start one with 'git stack create <prefix> <slug>' ${C_DIM}[gstkcr]${C_RESET}, or switch to an existing stack with 'git stack pick' ${C_DIM}[gstkp]${C_RESET}."
  fi

  local branches=()
  _load_stack_branches "$prefix" branches

  if (( ${#branches[@]} > 0 )); then
    _require_valid_leaf_nums "${branches[@]}"
  fi

  # Slug collision check (against existing stack only).
  if (( ${#branches[@]} > 0 )) && _check_slug_collision "$slug" "${branches[@]}"; then
    die "add: slug '$slug' collides with existing branch '$_SLUG_COLLISION_BRANCH'"
  fi

  local width
  width=$(_leaf_width_for "${branches[@]+"${branches[@]}"}")

  # Resolve (new_num, predecessor) based on flag / picker / defaults.
  local new_num predecessor_ref predecessor_label
  local resolved=0

  # Empty stack (only reachable via --prefix to an empty prefix): use
  # _next_leaf_num (10 for sparse / 1 for legacy). --at <num> is honored directly.
  if (( ${#branches[@]} == 0 )) && (( n_pos == 0 )); then
    new_num=$(_next_leaf_num)
    local parent_name
    parent_name=$(_resolve_parent_name) \
      || die "add: cannot determine parent branch (set stack.base or create main/master)"
    predecessor_ref=$(_resolve_parent_ref "$parent_name") \
      || die "add: cannot resolve parent ref for '$parent_name'"
    predecessor_label="$parent_name"
    resolved=1
  fi

  # Interactive: no flag passed, branches exist, TTY available.
  if (( ! resolved )) && (( n_pos == 0 )) && (( ${#branches[@]} > 0 )) \
       && [[ -e /dev/tty ]] && [[ -t 0 || -t 2 ]]; then
    _pick_position_for_new "${branches[@]}" || die "add: cancelled"
    new_num="$_PICKED_LEAF_NUM"
    if [[ -z "$_PICKED_PREDECESSOR" ]]; then
      local parent_name
      parent_name=$(_resolve_parent_name) \
        || die "add: cannot determine parent branch (set stack.base or create main/master)"
      predecessor_ref=$(_resolve_parent_ref "$parent_name") \
        || die "add: cannot resolve parent ref for '$parent_name'"
      predecessor_label="$parent_name"
    else
      predecessor_ref="refs/heads/$_PICKED_PREDECESSOR"
      predecessor_label="$_PICKED_PREDECESSOR"
    fi
    resolved=1
  fi

  # Non-TTY default: --last.
  if (( ! resolved )) && (( n_pos == 0 )); then
    opt_last=1
    n_pos=1
  fi

  # Non-interactive flag resolution — all four modes go through the pure
  # placement resolver.
  if (( ! resolved )) && (( opt_last )); then
    _resolve_placement "add --last" last "" "$width" "${branches[@]+"${branches[@]}"}"
    new_num="$_PL_LEAF"; predecessor_ref="$_PL_PRED_REF"; predecessor_label="$_PL_PRED_LABEL"
    resolved=1
  fi

  if (( ! resolved )) && [[ -n "$opt_before" ]]; then
    (( ${#branches[@]} > 0 )) || die "add --before: no branches in stack '$prefix'"
    local ref_branch rc=0
    ref_branch=$(_resolve_branch_ref "$opt_before" "${branches[@]}") || rc=$?
    (( rc == 0 )) || die "add --before: '$opt_before' not in stack '$prefix'"
    _resolve_placement "add --before $ref_branch" before "$ref_branch" "$width" "${branches[@]}"
    new_num="$_PL_LEAF"; predecessor_ref="$_PL_PRED_REF"; predecessor_label="$_PL_PRED_LABEL"
    resolved=1
  fi

  if (( ! resolved )) && [[ -n "$opt_after" ]]; then
    (( ${#branches[@]} > 0 )) || die "add --after: no branches in stack '$prefix'"
    local ref_branch rc=0
    ref_branch=$(_resolve_branch_ref "$opt_after" "${branches[@]}") || rc=$?
    (( rc == 0 )) || die "add --after: '$opt_after' not in stack '$prefix'"
    _resolve_placement "add --after $ref_branch" after "$ref_branch" "$width" "${branches[@]}"
    new_num="$_PL_LEAF"; predecessor_ref="$_PL_PRED_REF"; predecessor_label="$_PL_PRED_LABEL"
    resolved=1
  fi

  if (( ! resolved )) && [[ -n "$opt_at" ]]; then
    _resolve_placement "add --at" at "$opt_at" "$width" "${branches[@]+"${branches[@]}"}"
    new_num="$_PL_LEAF"; predecessor_ref="$_PL_PRED_REF"; predecessor_label="$_PL_PRED_LABEL"
    resolved=1
  fi

  (( resolved )) || die "internal: add: position resolution failed"

  # Format the new branch name.
  local leaf new_branch
  leaf=$(_format_leaf "$new_num" "$width")
  new_branch="${prefix}${leaf}-${slug}"

  # Paranoia: new branch ref must not exist.
  if git rev-parse --verify --quiet "refs/heads/$new_branch" >/dev/null; then
    die "add: target ref 'refs/heads/$new_branch' already exists"
  fi

  # Resolve predecessor SHA.
  local predecessor_sha
  predecessor_sha=$(git rev-parse "$predecessor_ref") \
    || die "add: cannot resolve predecessor '$predecessor_ref'"

  # Carry a dirty tree onto the new branch (stash now if relocating; the
  # checkout carries it for free when predecessor == HEAD).
  _carry_begin "$predecessor_sha" "git-stack add → $new_branch"

  # Snapshot before mutation.
  _SNAPSHOT_FOCUS="leaf=${new_branch##*/}"
  if (( ${#branches[@]} > 0 )); then
    snapshot_stack add "$prefix" "${branches[@]}"
  else
    snapshot_stack add "$prefix"
  fi

  # Create the branch — single update-ref, no cascade.
  if ! git update-ref "refs/heads/${new_branch}" "${predecessor_sha}" ""; then
    _carry_unwind
    die "git update-ref failed; ref unchanged"
  fi

  # Switch HEAD to the new branch.
  git checkout --quiet "$new_branch" || { _carry_unwind; die "add: failed to checkout '$new_branch'"; }

  # Pop the carried work onto the new branch (no-op unless we stashed).
  _carry_finish

  log "${C_GREEN}add${C_RESET}     ${C_CYAN}${new_branch}${C_RESET} ${C_DIM}(from ${predecessor_label})${C_RESET}"
}

# Start a brand-new stack: the first branch off the resolved base (stack.base →
# origin/<default> → local default), or --onto <ref>. Errors if the prefix
# already has branches (use `add` for that). Checks out the new branch. The
# first leaf is sparse width-3 (010).
#
# <prefix> and <slug> may be omitted on a TTY — each missing one is prompted for
# in a re-prompt loop that preserves what you've already entered (a rejected
# value is re-edited in place on bash 4+, ADR 0012). Non-interactively (no TTY),
# a missing value is a usage error, preserving the scriptable contract.
cmd_create() {
  OPT_PREFIX=""; OPT_ONTO=""; OPT_CARRY=0
  local prefix_arg="" slug=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --onto) shift; [[ $# -gt 0 ]] || die "--onto needs an argument"; OPT_ONTO="$1"; shift ;;
      --stash) OPT_CARRY=1; shift ;;
      -*)     die "unknown create flag: $1" ;;
      *)      if [[ -z "$prefix_arg" ]]; then prefix_arg="$1"
              elif [[ -z "$slug" ]];    then slug="$1"
              else die "create: extra arg '$1'"; fi
              shift ;;
    esac
  done

  local have_tty=0
  if [[ -e /dev/tty ]] && [[ -t 0 || -t 2 ]]; then have_tty=1; fi

  # Values passed as arguments hard-fail on bad input (non-interactive contract
  # preserved); missing values are prompted later on a TTY, else a usage die.
  if [[ -n "$prefix_arg" ]]; then
    _validate_prefix "$prefix_arg" || die "create: $_VALIDATE_MSG"
  elif (( ! have_tty )); then
    die "usage: git stack create <prefix> <slug> [--onto <ref>] [--stash]"
  fi
  if [[ -n "$slug" ]]; then
    _validate_slug "$slug" || die "create: $_VALIDATE_MSG"
  elif (( ! have_tty )); then
    die "create: missing <slug> (usage: git stack create <prefix> <slug>)"
  fi

  require_in_repo
  require_no_op_in_progress
  require_no_state_file
  # No require_clean_tree: a dirty tree may be carried into the new stack (the
  # carry decision runs below, before prompting; the stash is deferred to the
  # mutation). Read-only until the snapshot.

  # Resolve the base ref (fail fast, before any prompt): --onto override, else
  # the configured/default base.
  local predecessor_ref predecessor_label
  if [[ -n "$OPT_ONTO" ]]; then
    git rev-parse --verify --quiet "${OPT_ONTO}^{commit}" >/dev/null \
      || die "create --onto: cannot resolve '$OPT_ONTO' to a commit"
    predecessor_ref="$OPT_ONTO"
    predecessor_label="$OPT_ONTO"
  else
    local parent_name
    parent_name=$(_resolve_parent_name) \
      || die "create: cannot determine base branch (set stack.base or create main/master, or pass --onto)"
    predecessor_ref=$(_resolve_parent_ref "$parent_name") \
      || die "create: cannot resolve base ref for '$parent_name'"
    predecessor_label="$parent_name"
  fi
  local predecessor_sha
  predecessor_sha=$(git rev-parse "$predecessor_ref") \
    || die "create: cannot resolve base '$predecessor_ref'"

  # Dirty-tree carry DECISION — before prompting, so declining (or a non-TTY
  # dirty tree) aborts before the user types anything. The stash itself is
  # deferred to just before the ref mutation, so a Ctrl-C mid-prompt strands
  # nothing. --stash is the scriptable affirmative.
  local do_carry=0
  if _tree_is_dirty; then
    if (( OPT_CARRY )); then
      do_carry=1
    elif (( have_tty )); then
      if _prompt_carry_into_stack; then do_carry=1; else die "create: aborted (changes left untouched)"; fi
    else
      die "working tree has uncommitted changes; commit or stash first (or pass --stash)"
    fi
  fi

  # Resolve the prefix: validate shape (done above for the arg path) and require
  # it be empty of branches (else this is an `add`). A prompted prefix loops on
  # either failure; a passed one dies.
  local prefix="" branches=()
  if [[ -n "$prefix_arg" ]]; then
    prefix="${prefix_arg%/}/"
    _load_stack_branches "$prefix" branches
    (( ${#branches[@]} == 0 )) \
      || die "create: stack '$prefix' already has ${#branches[@]} branch(es); use 'git stack add <slug>' ${C_DIM}[gstkad]${C_RESET} to add to it"
  else
    local _prev=""
    while :; do
      _prompt_prefill "prefix:" "$_prev" prefix_arg || die "create: aborted"
      _prev="$prefix_arg"
      if ! _validate_prefix "$prefix_arg"; then
        printf '  %s\n' "$_VALIDATE_MSG" >&2
        continue
      fi
      prefix="${prefix_arg%/}/"
      _load_stack_branches "$prefix" branches
      if (( ${#branches[@]} != 0 )); then
        printf "  stack '%s' already has %d branch(es); pick another prefix (Ctrl-C to cancel and use 'add')\n" \
          "$prefix" "${#branches[@]}" >&2
        continue
      fi
      break
    done
  fi

  # Resolve the slug: a prompted slug loops until valid; a passed one was
  # validated above.
  if [[ -z "$slug" ]]; then
    local _prev=""
    while :; do
      _prompt_prefill "slug:" "$_prev" slug || die "create: aborted"
      _prev="$slug"
      if _validate_slug "$slug"; then break; fi
      printf '  %s\n' "$_VALIDATE_MSG" >&2
    done
  fi

  # First leaf: sparse width-3 (010).
  local width new_num leaf new_branch
  width=$(_leaf_width_for)
  new_num=$(_next_leaf_num)
  leaf=$(_format_leaf "$new_num" "$width")
  new_branch="${prefix}${leaf}-${slug}"

  # Belt-and-suspenders: unreachable once the prefix is confirmed empty (the leaf
  # would have been counted), but cheap to keep.
  if git rev-parse --verify --quiet "refs/heads/$new_branch" >/dev/null; then
    die "create: target ref 'refs/heads/$new_branch' already exists"
  fi

  # Carry stash action (deferred from the decision above).
  if (( do_carry )); then
    _carry_begin "$predecessor_sha" "git-stack create → $new_branch"
  fi

  _SNAPSHOT_FOCUS="leaf=${new_branch##*/}"
  snapshot_stack create "$prefix"

  if ! git update-ref "refs/heads/${new_branch}" "${predecessor_sha}" ""; then
    _carry_unwind
    die "git update-ref failed; ref unchanged"
  fi
  git checkout --quiet "$new_branch" || { _carry_unwind; die "create: failed to checkout '$new_branch'"; }

  # Pop the carried work onto the new branch (no-op unless we stashed).
  _carry_finish

  log "${C_GREEN}create${C_RESET}  ${C_CYAN}${new_branch}${C_RESET} ${C_DIM}(off ${predecessor_label})${C_RESET}"
}

cmd_move() {
  OPT_PREFIX=""; OPT_NO_SYNC=0; OPT_NO_PUSH=0; OPT_FORCE=0
  local src="" opt_last=0 opt_before="" opt_after="" opt_at=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --last)    opt_last=1; shift ;;
      --first)   die "move: --first has been removed (it cascade-renumbered branches, destroying their PRs on GitHub). Use '--before <ref>' instead — e.g. '--before <lowest-leaf>' to move to the very start." ;;
      --before)  shift; [[ $# -gt 0 ]] || die "--before needs an argument"; opt_before="$1"; shift ;;
      --after)   shift; [[ $# -gt 0 ]] || die "--after needs an argument"; opt_after="$1"; shift ;;
      --at)      shift; [[ $# -gt 0 ]] || die "--at needs an argument"; opt_at="$1"; shift ;;
      --allow-pr-rebuild) die "move: --allow-pr-rebuild has been removed (move is now fully local and never touches PRs). To reorder a published stack, run 'git stack pr desync' first, then reorder, then 'git stack pr sync'." ;;
      --force)   OPT_FORCE=1; shift ;;
      -*)        die "unknown move flag: $1" ;;
      *)         [[ -z "$src" ]] || die "move: extra arg '$1'"; src="$1"; shift ;;
    esac
  done

  # Default <branch> to the current branch when omitted.
  if [[ -z "$src" ]]; then
    src=$(current_branch) \
      || die "usage: git stack move [<branch>] [--last|--before <ref>|--after <ref>|--at <num>]
move: no <branch> given and HEAD is detached"
  fi

  # --at requires a non-negative integer (no slugs or branch refs).
  if [[ -n "$opt_at" && ! "$opt_at" =~ ^[0-9]+$ ]]; then
    die "move --at: requires a non-negative integer leaf number (got '$opt_at'); use --before/--after for branch-relative inserts"
  fi

  local n_pos=$opt_last
  [[ -n "$opt_before" ]] && (( n_pos++ )) || true
  [[ -n "$opt_after" ]] && (( n_pos++ )) || true
  [[ -n "$opt_at" ]] && (( n_pos++ )) || true
  (( n_pos <= 1 )) || die "move: --last, --before, --after, --at are mutually exclusive"

  require_in_repo
  require_clean_tree
  require_no_op_in_progress
  require_no_state_file

  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")

  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under '$prefix'"
  (( ${#branches[@]} >= 2 )) || die "move: stack has fewer than 2 branches"

  _require_valid_leaf_nums "${branches[@]}"

  # Resolve source.
  local src_branch rc=0
  src_branch=$(_resolve_branch_ref "$src" "${branches[@]}") || rc=$?
  (( rc == 0 )) || die "move: '$src' not in stack '$prefix'"
  local src_idx
  src_idx=$(branch_index "$src_branch" "${branches[@]}")

  # TTY picker if no position flag. Three-step picker (branch + before/after +
  # leaf is overkill for move — pickers map cleanly to --before/--after/--last
  # since the reflow recomputes leaves anyway). For simplicity we keep a
  # single-step picker here showing each non-src branch as a "[before <X>]" /
  # "[after <X>]" pair plus a "[last]" terminator.
  if (( n_pos == 0 )) && [[ -e /dev/tty ]] && [[ -t 0 || -t 2 ]]; then
    local picker_items=()
    local b
    for b in "${branches[@]}"; do
      [[ "$b" == "$src_branch" ]] && continue
      picker_items+=("before $b" "after $b")
    done
    local picked
    picked=$(_pick_one "move ${src_branch} to:" "${picker_items[@]}") \
      || die "move: no position selected"
    if [[ "$picked" == "before "* ]]; then
      opt_before="${picked#before }"
    elif [[ "$picked" == "after "* ]]; then
      opt_after="${picked#after }"
    fi
    n_pos=1
  fi
  (( n_pos == 1 )) || die "move: no position specified (and no TTY for picker); pass --last/--before/--after/--at"

  # Resolve destination index in the *post-removal* array (i.e., the array with src_branch removed).
  # This is the index *where src will sit* after the move.
  local dst_idx
  if (( opt_last )); then
    dst_idx=$((${#branches[@]} - 1))
  elif [[ -n "$opt_before" ]]; then
    local before_branch
    before_branch=$(_resolve_branch_ref "$opt_before" "${branches[@]}") \
      || die "move --before: '$opt_before' not in stack '$prefix'"
    [[ "$before_branch" != "$src_branch" ]] || die "move: cannot reference itself"
    local before_idx
    before_idx=$(branch_index "$before_branch" "${branches[@]}")
    if (( before_idx > src_idx )); then
      dst_idx=$((before_idx - 1))
    else
      dst_idx=$before_idx
    fi
  elif [[ -n "$opt_after" ]]; then
    local after_branch
    after_branch=$(_resolve_branch_ref "$opt_after" "${branches[@]}") \
      || die "move --after: '$opt_after' not in stack '$prefix'"
    [[ "$after_branch" != "$src_branch" ]] || die "move: cannot reference itself"
    local after_idx
    after_idx=$(branch_index "$after_branch" "${branches[@]}")
    if (( after_idx > src_idx )); then
      dst_idx=$after_idx
    else
      dst_idx=$((after_idx + 1))
    fi
  elif [[ -n "$opt_at" ]]; then
    # --at <num>: explicit leaf placement. Refuses if leaf is taken by any
    # branch other than src itself. Computes dst_idx from where <num> would
    # sort among the (non-src) branches.
    local at_num="$opt_at" b leaf_num
    for b in "${branches[@]}"; do
      [[ "$b" == "$src_branch" ]] && continue
      [[ "${b##*/}" =~ ^([0-9]+)- ]] || continue
      leaf_num=$((10#${BASH_REMATCH[1]}))
      if (( leaf_num == at_num )); then
        die "move --at: leaf $at_num is already taken by '$b'"
      fi
    done
    # Compute dst_idx: index in the post-removal array where leaf at_num lands.
    dst_idx=0
    local seen=0 i
    for ((i = 0; i < ${#branches[@]}; i++)); do
      [[ "${branches[$i]}" == "$src_branch" ]] && continue
      [[ "${branches[$i]##*/}" =~ ^([0-9]+)- ]] || { seen=$((seen + 1)); continue; }
      leaf_num=$((10#${BASH_REMATCH[1]}))
      if (( leaf_num < at_num )); then
        seen=$((seen + 1))
      fi
    done
    dst_idx=$seen
  fi

  # Destination == source position: the branch isn't moving. Rather than error,
  # treat this as a renumber-in-place request — change the leaf number without
  # reordering. A pure rename: no commits move, so no reflow. (See ADR 0002.)
  if (( dst_idx == src_idx )); then
    [[ "${src_branch##*/}" =~ ^([0-9]+)- ]] \
      || die "internal: source leaf '${src_branch##*/}' malformed"
    local cur_leaf=$((10#${BASH_REMATCH[1]}))
    local src_rest="${src_branch##*/}"; src_rest="${src_rest#*-}"

    # Resolve the target leaf number.
    local new_num=""
    if [[ -n "$opt_at" ]]; then
      new_num="$opt_at"
    elif [[ -n "$opt_before" || -n "$opt_after" ]]; then
      # --before/--after (or the interactive position picker) resolved to the
      # branch's current slot. The branch isn't moving, so its valid leaves are
      # the open gap between its fixed predecessor and successor. Offer a leaf
      # picker; with no TTY there is nothing to pick, so point the user at --at.
      # Lower bound = predecessor's leaf (base => 0); upper = successor's leaf
      # (last branch => -1, open-ended).
      local _lo _hi
      if (( src_idx == 0 )); then
        _lo=0
      else
        [[ "${branches[$((src_idx - 1))]##*/}" =~ ^([0-9]+)- ]] \
          || die "internal: predecessor leaf malformed"
        _lo=$((10#${BASH_REMATCH[1]}))
      fi
      if (( src_idx == ${#branches[@]} - 1 )); then
        _hi=-1
      else
        [[ "${branches[$((src_idx + 1))]##*/}" =~ ^([0-9]+)- ]] \
          || die "internal: successor leaf malformed"
        _hi=$((10#${BASH_REMATCH[1]}))
      fi
      if [[ -e /dev/tty ]] && [[ -t 0 || -t 2 ]]; then
        local _cands=($(_renumber_candidates "$cur_leaf" "$_lo" "$_hi"))
        (( ${#_cands[@]} > 0 )) \
          || die "move: no free leaf to renumber '$src_branch' into here; pass --at <num>"
        # No default: renumber is invoked to land a specific number, and the
        # current leaf sits inside the gap, so <exclude> rejects it as a no-op.
        local _w; _w=$(_leaf_width_for "${branches[@]}")
        new_num=$(_pick_or_enter_leaf "renumber ${src_branch} to leaf:" "$_lo" "$_hi" "$_w" "" "$cur_leaf" "${_cands[@]}") \
          || die "move: no leaf selected"
      else
        local _rel="before" _ref="$before_branch"
        [[ -n "$opt_after" ]] && { _rel="after"; _ref="$after_branch"; }
        die "move: '$src_branch' is already directly $_rel '$_ref'; pass --at <num> to renumber it in place (no TTY for the leaf picker)"
      fi
    else
      # --last on a branch already at the end: a genuine no-op.
      die "move: '$src_branch' is already at position $((src_idx + 1))"
    fi

    # No leaf change requested -> graceful no-op.
    if (( new_num == cur_leaf )); then
      log "${C_GREEN}move${C_RESET}    '${src_branch}' already at leaf ${cur_leaf}; nothing to do"
      return 0
    fi

    local width new_leaf new_full
    width=$(_leaf_width_for "${branches[@]}")
    new_leaf=$(_format_leaf "$new_num" "$width")
    new_full="${prefix}${new_leaf}-${src_rest}"

    # Defensive: the --at path already rejected leaves taken by other branches,
    # and the picker draws only from the free gap, but guard anyway.
    if git rev-parse --verify --quiet "refs/heads/$new_full" >/dev/null; then
      die "move --at: leaf $new_num is already taken by '$new_full'"
    fi

    require_branch_not_in_worktree "$src_branch"

    # PR-orphan guard: renumbering renames the branch (new leaf number) but move
    # is fully local — the open PR still sits on the old remote branch, so a
    # later 'pr sync' would open a fresh PR and orphan the old one. Hard-block
    # and point at the desync workflow (checked unconditionally; the helper
    # no-ops when gh is unusable).
    if _check_no_open_prs "$src_branch"; then
      die "move: '${_ORPHAN_PR_BRANCH}' has an open PR (#${_ORPHAN_PR_NUM}); reordering would desync it from GitHub. Run 'git stack pr desync' to take the stack offline first, then reorder, then 'git stack pr sync'."
    fi

    _SNAPSHOT_FOCUS="leaf=${src_branch##*/}"$'\n'"pos=${new_num}"
    snapshot_stack move "$prefix" "${branches[@]}"

    # Pure rename: local rename batch only — move is fully local. No reflow-pick
    # phase (the commit graph is untouched) and no remote-sync (republishing is
    # a separate 'pr sync' step).
    STACK_BRANCHES=("${branches[@]}")
    STACK_ORIG_SHAS=()
    STACK_STARTED_AT=$(date +%s)
    STACK_STARTING_BRANCH=$(current_branch || echo "")
    STACK_PREFIX="$prefix"
    STACK_PUSH=0
    STACK_FORCE=0
    STACK_ONTO=""
    STACK_ONTO_REF=""
    STACK_FROM_IDX=0
    STACK_PUSH_FAILURES=()
    STACK_OPT_NO_PUSH="$OPT_NO_PUSH"
    STACK_OPT_NO_SYNC="$OPT_NO_SYNC"
    STACK_RENAME_PAIRS=("$src_branch" "$new_full")
    STACK_PHASES=(rename-batch)
    STACK_PHASE_IDX=0
    STACK_UNIT_IDX=0

    save_engine_state
    _engine_run
    return
  fi

  # Build the post-move ordering: branches minus src, with src spliced at dst_idx.
  local post=() i
  for ((i = 0; i < ${#branches[@]}; i++)); do
    (( i == src_idx )) && continue
    post+=("${branches[$i]}")
  done
  local spliced=()
  for ((i = 0; i < dst_idx; i++)); do spliced+=("${post[$i]}"); done
  spliced+=("$src_branch")
  for ((i = dst_idx; i < ${#post[@]}; i++)); do spliced+=("${post[$i]}"); done
  post=("${spliced[@]}")

  # First affected branch index in the post-move ordering.
  local first_affected
  if (( dst_idx < src_idx )); then
    first_affected=$dst_idx
  else
    first_affected=$src_idx
  fi

  # Multi-commit guard for affected branches.
  if (( ! OPT_FORCE )); then
    for ((i = first_affected; i < ${#post[@]}; i++)); do
      local pb="${post[$i]}"
      # Check against the CURRENT predecessor (from the original branches[] ordering),
      # not the future predecessor. This matches do_one_step's cherry-pick semantics.
      local cur_idx
      cur_idx=$(branch_index "$pb" "${branches[@]}")
      local prev_ref
      if (( cur_idx == 0 )); then
        local parent_name
        parent_name=$(_resolve_parent_name) \
          || die "move: cannot determine parent branch (set stack.base or create main/master)"
        prev_ref=$(_resolve_parent_ref "$parent_name")
      else
        prev_ref="refs/heads/${branches[$((cur_idx - 1))]}"
      fi
      local cnt_b cnt_prev n_commits
      cnt_b=$(git rev-list --count "refs/heads/$pb" 2>/dev/null || echo 0)
      cnt_prev=$(git rev-list --count "$prev_ref" 2>/dev/null || echo 0)
      n_commits=$((cnt_b - cnt_prev))
      if (( n_commits > 1 )); then
        die "branch '$pb' has $n_commits commits beyond its current predecessor; move would drop all but the tip. Pass --force to proceed."
      fi
    done
  fi

  # Worktree safety: every affected branch must not be checked out elsewhere.
  for ((i = first_affected; i < ${#post[@]}; i++)); do
    require_branch_not_in_worktree "${post[$i]}"
  done

  # PR-orphan guard. The cherry-pick reflow rewrites each affected branch's tip
  # and the post-rename phase changes leaf numbers, but move is fully local — an
  # affected branch's open PR still sits on its old remote branch, so a later
  # 'pr sync' would open a fresh PR and orphan the old one. Hard-block and point
  # at the desync workflow (checked unconditionally; the helper no-ops when gh
  # is unusable).
  local affected=()
  for ((i = first_affected; i < ${#post[@]}; i++)); do
    affected+=("${post[$i]}")
  done
  if _check_no_open_prs "${affected[@]+"${affected[@]}"}"; then
    die "move: '${_ORPHAN_PR_BRANCH}' has an open PR (#${_ORPHAN_PR_NUM}); reordering would desync it from GitHub. Run 'git stack pr desync' to take the stack offline first, then reorder, then 'git stack pr sync'."
  fi

  # Snapshot before mutation.
  _SNAPSHOT_FOCUS="leaf=${src_branch##*/}"$'\n'"pos=$((dst_idx + 1))"
  snapshot_stack move "$prefix" "${branches[@]}"

  # Plan: reflow-pick (rebase affected branches onto new predecessors) →
  # rename-batch (gap-aware post-move cascade). Fully local — no remote-sync;
  # republishing is a separate 'pr sync' step.
  STACK_BRANCHES=("${post[@]}")
  STACK_ORIG_SHAS=()
  for ((i = 0; i < ${#STACK_BRANCHES[@]}; i++)); do
    if (( i >= first_affected )); then
      STACK_ORIG_SHAS+=("$(git rev-parse "refs/heads/${STACK_BRANCHES[$i]}")")
    else
      STACK_ORIG_SHAS+=("")
    fi
  done
  STACK_STARTED_AT=$(date +%s)
  STACK_STARTING_BRANCH=$(current_branch || echo "")
  STACK_PREFIX="$prefix"
  STACK_PUSH=0
  # cmd_move's pre-check (above) already verified each affected branch has
  # ≤1 commit beyond its current predecessor.  do_one_step's guard compares
  # against the *new* predecessor, which yields a false positive when a branch
  # inherits ancestors from an earlier stack position.  Set STACK_FORCE=1 so
  # the do_one_step guard is suppressed; the cherry-pick is safe.
  STACK_FORCE=1
  STACK_ONTO=""
  STACK_ONTO_REF=""
  STACK_FROM_IDX="$first_affected"
  STACK_PUSH_FAILURES=()
  STACK_OPT_NO_PUSH="$OPT_NO_PUSH"
  STACK_OPT_NO_SYNC="$OPT_NO_SYNC"
  if (( first_affected == 0 )); then
    local parent_name parent_ref
    parent_name=$(_resolve_parent_name) \
      || die "move: cannot determine parent branch (set stack.base or create main/master)"
    parent_ref=$(_resolve_parent_ref "$parent_name") \
      || die "move: cannot resolve parent ref for '$parent_name'"
    STACK_ONTO=$(git rev-parse "$parent_ref")
    STACK_ONTO_REF="$parent_name"
  fi

  # Compute the gap-aware post-move rename cascade now. It depends only on the
  # post-move names/leaves (which the reflow does not change), so it is static
  # plan data; the rename-batch phase reads each branch's SHA at apply time.
  _doctor_scan_renames STACK_RENAME_PAIRS "$prefix" "${post[@]}"

  STACK_PHASES=(reflow-pick)
  (( ${#STACK_RENAME_PAIRS[@]} > 0 )) && STACK_PHASES+=(rename-batch)
  STACK_PHASE_IDX=0
  STACK_UNIT_IDX=0

  save_engine_state
  _engine_run
}

# ---------- doctor helpers ----------

# Scan a stack for out-of-order leaf numbers. Populates the named array with
# alternating <old branch> <new branch> pairs. Pure read-only.
# Usage: _doctor_scan_renames <out_array_name> <prefix> <branch>...
_doctor_scan_renames() {
  local out_name="$1" prefix="$2"; shift 2
  local branches=("$@")
  local width
  width=$(_leaf_width_for "${branches[@]}")
  eval "$out_name=()"
  local prev_num=0
  local i b leaf old_num old_rest new_num new_leaf new_full
  for ((i = 0; i < ${#branches[@]}; i++)); do
    b="${branches[$i]}"
    leaf="${b##*/}"
    [[ "$leaf" =~ ^([0-9]+)- ]] || die "internal: leaf '$leaf' malformed"
    old_num=$((10#${BASH_REMATCH[1]}))
    old_rest="${leaf#*-}"
    if (( old_num > prev_num )); then
      prev_num=$old_num
      continue
    fi
    new_num=$((prev_num + 1))
    new_leaf=$(_format_leaf "$new_num" "$width")
    new_full="${prefix}${new_leaf}-${old_rest}"
    eval "$out_name+=($(printf '%q ' "$b" "$new_full"))"
    prev_num=$new_num
  done
}

# Refuse if any rename target collides with an existing branch that isn't
# itself being renamed away.
# Usage: _doctor_check_rename_collisions <rename_pairs>...
_doctor_check_rename_collisions() {
  local pairs=("$@")
  local i j new_full conflict
  for ((i = 1; i < ${#pairs[@]}; i+=2)); do
    new_full="${pairs[$i]}"
    if git rev-parse --verify --quiet "refs/heads/$new_full" >/dev/null; then
      conflict=1
      for ((j = 0; j < ${#pairs[@]}; j+=2)); do
        if [[ "${pairs[$j]}" == "$new_full" ]]; then conflict=0; break; fi
      done
      (( conflict == 0 )) || die "doctor: cascade target '$new_full' already exists"
    fi
  done
}

# Apply a confirmed batch of renames atomically via git update-ref --stdin.
# Local-only: the remote tail (remote rename + pr sync) is driven separately by
# cmd_doctor's finish phase through the engine, so it's resumable and runs after
# the reflow. Caller is responsible for snapshot + collision check.
# Usage: _doctor_apply_renames_batch <rename_pairs>...
_doctor_apply_renames_batch() {
  local pairs=("$@")
  (( ${#pairs[@]} > 0 )) || return 0

  local i
  for ((i = 0; i < ${#pairs[@]}; i+=2)); do
    require_branch_not_in_worktree "${pairs[$i]}"
  done

  local batch="" old new sha
  for ((i = 0; i < ${#pairs[@]}; i+=2)); do
    old="${pairs[$i]}"
    new="${pairs[$((i + 1))]}"
    sha=$(git rev-parse "refs/heads/$old")
    batch+="create refs/heads/${new} ${sha}"$'\n'
    batch+="delete refs/heads/${old} ${sha}"$'\n'
  done

  local head_before="" head_new=""
  if head_before=$(git symbolic-ref --quiet HEAD 2>/dev/null); then
    for ((i = 0; i < ${#pairs[@]}; i+=2)); do
      if [[ "$head_before" == "refs/heads/${pairs[$i]}" ]]; then
        head_new="refs/heads/${pairs[$((i + 1))]}"
        git symbolic-ref HEAD "$head_new"
        break
      fi
    done
  fi

  if ! printf '%s' "$batch" | git update-ref --stdin -m "git-stack doctor"; then
    if [[ -n "$head_new" ]]; then
      git symbolic-ref HEAD "$head_before" 2>/dev/null || true
    fi
    die "git update-ref batch failed; refs unchanged (atomic)"
  fi

  log "${C_GREEN}doctor${C_RESET}  renamed ${C_BOLD}$((${#pairs[@]} / 2))${C_RESET} branch(es)"
}

# Walk a stack and emit one line per group of branches sharing a leaf number.
# Line format: <leaf_num><TAB><index1>,<index2>,...   (0-based positions in the
# input array). Groups of size 1 are skipped — only true duplicates are reported.
# Assumes the input is already in sort -V leaf order (as _load_stack_branches
# produces), so duplicates appear consecutively.
# Usage: _doctor_find_duplicate_groups <branch>...
_doctor_find_duplicate_groups() {
  local branches=("$@")
  local i b leaf num cur_num="" cur_indices=""
  for ((i = 0; i < ${#branches[@]}; i++)); do
    b="${branches[$i]}"
    leaf="${b##*/}"
    [[ "$leaf" =~ ^([0-9]+)- ]] || continue
    num=$((10#${BASH_REMATCH[1]}))
    if [[ -n "$cur_num" && "$num" == "$cur_num" ]]; then
      cur_indices+=",$i"
    else
      if [[ "$cur_indices" == *,* ]]; then
        printf '%s\t%s\n' "$cur_num" "$cur_indices"
      fi
      cur_num="$num"
      cur_indices="$i"
    fi
  done
  if [[ "$cur_indices" == *,* ]]; then
    printf '%s\t%s\n' "$cur_num" "$cur_indices"
  fi
}

# Prompt the user to pick an order for one duplicate group, then reorder the
# named branches array in place. The "top" branch in the user's order keeps the
# group's current leaf number; the rest cascade upward when the rename pass runs.
# Re-prompts on invalid input. Returns:
#   0 — order accepted (with or without changes)
#   1 — user quit
# Usage: _doctor_resolve_duplicate_group <branches_array_name> <leaf_num> <indices_csv> <label_idx> <label_total>
_doctor_resolve_duplicate_group() {
  local out_name="$1" leaf_num="$2" indices_csv="$3"
  local label_idx="$4" label_total="$5"

  local _ifs="$IFS"
  IFS=','
  local indices=($indices_csv)
  IFS="$_ifs"
  local n=${#indices[@]}

  local i idx_i val
  local names=()
  for ((i = 0; i < n; i++)); do
    idx_i=${indices[$i]}
    eval "val=\"\${$out_name[$idx_i]}\""
    names+=("$val")
  done

  printf '\n%s[%d/%d]%s %s%s%s  %sduplicate leaf %s (%d branches)%s\n' \
    "$C_BOLD" "$label_idx" "$label_total" "$C_RESET" \
    "$C_CYAN" "leaf $leaf_num" "$C_RESET" \
    "$C_DIM" "$leaf_num" "$n" "$C_RESET" >&2
  printf '  %sthe top branch keeps leaf %s; others cascade upward%s\n' \
    "$C_DIM" "$leaf_num" "$C_RESET" >&2

  while :; do
    printf '  %scurrent order:%s\n' "$C_DIM" "$C_RESET" >&2
    for ((i = 0; i < n; i++)); do
      printf '    %d) %s%s%s\n' "$((i + 1))" "$C_CYAN" "${names[$i]}" "$C_RESET" >&2
    done
    local example="" k
    for ((k = 1; k <= n; k++)); do example="${example:+$example }$k"; done
    printf '  %snew order (space/comma-separated, e.g. "%s"), RET=keep, q=quit:%s ' \
      "$C_DIM" "$example" "$C_RESET" >&2

    local input
    if ! read -r input < /dev/tty; then
      return 0
    fi

    if [[ -z "${input// /}" ]]; then
      return 0
    fi
    if [[ "$input" =~ ^[[:space:]]*[Qq][[:space:]]*$ ]]; then
      return 1
    fi

    local norm
    norm=$(printf '%s' "$input" | tr ',' ' ')
    local perm=($norm)

    if (( ${#perm[@]} != n )); then
      printf '  %serror:%s expected %d numbers, got %d\n' \
        "$C_YELLOW" "$C_RESET" "$n" "${#perm[@]}" >&2
      continue
    fi

    local valid=1 p seen=""
    for p in "${perm[@]}"; do
      if ! [[ "$p" =~ ^[0-9]+$ ]] || (( p < 1 || p > n )); then
        printf '  %serror:%s "%s" not in 1..%d\n' \
          "$C_YELLOW" "$C_RESET" "$p" "$n" >&2
        valid=0; break
      fi
      if [[ ",$seen," == *",$p,"* ]]; then
        printf '  %serror:%s "%s" repeated\n' \
          "$C_YELLOW" "$C_RESET" "$p" >&2
        valid=0; break
      fi
      seen="${seen}${seen:+,}${p}"
    done
    (( valid )) || continue

    local j changed=0
    local new_names=()
    for ((j = 0; j < n; j++)); do
      new_names+=("${names[$((perm[j] - 1))]}")
      if [[ "${names[$j]}" != "${new_names[$j]}" ]]; then
        changed=1
      fi
    done

    if (( changed )); then
      for ((j = 0; j < n; j++)); do
        idx_i=${indices[$j]}
        eval "$out_name[$idx_i]=$(printf '%q' "${new_names[$j]}")"
      done
      printf '  %sreordered%s\n' "$C_GREEN" "$C_RESET" >&2
    else
      printf '  %skept current order%s\n' "$C_DIM" "$C_RESET" >&2
    fi
    return 0
  done
}

# Pure classification of a branch's squash issue kind from pre-gathered git
# facts (no git access, no die — safe to unit-test). Returns 0 and prints the
# kind when a fix is needed; returns 1 (no output) when the branch is clean.
#   absorbed — tree already equals the predecessor's (fully merged upstream,
#              now redundant); dominates the other kinds.
#   merge    — tip is a merge commit.
#   multi    — more than one commit ahead of the predecessor.
#   both     — merge tip AND multi-commit.
# Usage: _doctor_squash_kind_pure <b_tree> <b_count> <prev_tree> <prev_count> <b_has_merge>
_doctor_squash_kind_pure() {
  local b_tree="$1" b_count="$2" prev_tree="$3" prev_count="$4" b_has_merge="$5"

  # Tree equality dominates: a branch already merged into its predecessor should
  # be offered for deletion, not squashed.
  if [[ "$b_tree" == "$prev_tree" ]]; then
    printf 'absorbed\n'
    return 0
  fi

  # Same heuristic as do_one_step: a positive diff in reachable-commit counts
  # indicates multi-commit. Sound for linear stacks; robust enough for the
  # merge-tip case too because either flag suffices.
  local is_multi=0
  (( b_count - prev_count > 1 )) && is_multi=1

  if   (( b_has_merge && is_multi )); then printf 'both\n';  return 0
  elif (( b_has_merge ));             then printf 'merge\n'; return 0
  elif (( is_multi ));                then printf 'multi\n'; return 0
  fi
  return 1
}

# Pure: map a stack's shape (pre-gathered facts) to an ordered issue list — the
# same "pure core" role the PR-sync reconciler plays. No git, no TTY. Emits one
# TSV issue per line, kind tag first so a leading field is never empty (avoids
# the IFS-strip trap when read back):
#   squash<TAB><branch_idx><TAB><kind>      (kind: absorbed|merge|multi|both)
#   dup<TAB><leaf_num><TAB><idx_csv>
#   rename<TAB><old_branch><TAB><new_branch>
# Order: all squash issues (branch order), then duplicate groups, then renames.
# Facts per branch: name, tree SHA, has-merge-tip flag (0|1), commit count.
# Usage: _doctor_scan <prefix> <base_tree> <base_count> -- <name> <tree> <merge> <count>...
_doctor_scan() {
  local prefix="$1" base_tree="$2" base_count="$3"
  shift 3
  [[ "${1-}" == "--" ]] || die "internal: _doctor_scan expects -- separator"
  shift
  local names=() trees=() merges=() counts=()
  while (( $# >= 4 )); do
    names+=("$1"); trees+=("$2"); merges+=("$3"); counts+=("$4")
    shift 4
  done

  local n=${#names[@]} i prev_tree prev_count kind
  # Squash issues: classify each branch against its positional predecessor.
  for ((i = 0; i < n; i++)); do
    if (( i == 0 )); then
      prev_tree="$base_tree"; prev_count="$base_count"
    else
      prev_tree="${trees[$((i-1))]}"; prev_count="${counts[$((i-1))]}"
    fi
    if kind=$(_doctor_squash_kind_pure \
                "${trees[$i]}" "${counts[$i]}" "$prev_tree" "$prev_count" "${merges[$i]}"); then
      printf 'squash\t%d\t%s\n' "$i" "$kind"
    fi
  done

  # Duplicate groups (leaf clashes). _doctor_find_duplicate_groups emits
  # <leaf><TAB><idx_csv>; prefix the kind tag.
  local dline
  while IFS= read -r dline; do
    [[ -n "$dline" ]] && printf 'dup\t%s\n' "$dline"
  done < <(_doctor_find_duplicate_groups "${names[@]+"${names[@]}"}")

  # Rename cascade (leaves out of order).
  local pairs=()
  _doctor_scan_renames pairs "$prefix" "${names[@]+"${names[@]}"}"
  for ((i = 0; i < ${#pairs[@]}; i += 2)); do
    printf 'rename\t%s\t%s\n' "${pairs[$i]}" "${pairs[$((i+1))]}"
  done
}

# Effectful: gather the git facts _doctor_scan needs into a caller-named array,
# laid out in _doctor_scan's argument order from <base_tree> onward —
#   base_tree base_count -- <name> <tree> <merge> <count> ...
# so the caller runs: _doctor_scan "$prefix" "${facts[@]}". This is the only
# git-reading step of the scan; the classification itself stays pure.
# Usage: _doctor_gather <out_array> <base_ref> <branch>...
_doctor_gather() {
  local out_name="$1" base_ref="$2"; shift 2
  local branches=("$@")
  local base_tree base_count
  base_tree=$(git rev-parse "${base_ref}^{tree}")
  base_count=$(git rev-list --count "$base_ref" 2>/dev/null || echo 0)
  eval "$out_name=($(printf '%q ' "$base_tree" "$base_count" "--"))"
  local b b_ref tree count merge
  for b in "${branches[@]+"${branches[@]}"}"; do
    b_ref="refs/heads/$b"
    tree=$(git rev-parse "${b_ref}^{tree}")
    count=$(git rev-list --count "$b_ref" 2>/dev/null || echo 0)
    merge=0
    if git rev-parse --verify --quiet "${b_ref}^2" >/dev/null 2>&1; then
      merge=1
    fi
    eval "$out_name+=($(printf '%q ' "$b" "$tree" "$merge" "$count"))"
  done
}

# Concatenated commit messages from prev..tip (oldest first, blank-line
# separated). Used as the default squash commit message.
# Usage: _doctor_default_squash_msg <prev_ref> <tip_ref>
_doctor_default_squash_msg() {
  local prev_ref="$1" tip_ref="$2"
  git log --reverse --format='%B' "${prev_ref}..${tip_ref}"
}

# Tree-equality test for the empty-squash case (branch already absorbed into
# predecessor). Returns 0 if trees are equal, 1 otherwise.
_doctor_squash_is_empty() {
  local b="$1" prev_ref="$2"
  local tree_b tree_prev
  tree_b=$(git rev-parse "refs/heads/${b}^{tree}")
  tree_prev=$(git rev-parse "${prev_ref}^{tree}")
  [[ "$tree_b" == "$tree_prev" ]]
}

# Soft-reset + commit a branch on top of its predecessor. Captures the full
# prev..tip diff as one commit, regardless of whether prev was an ancestor of
# the old tip.
# Returns:
#   0 — commit made
#   2 — empty-squash case; branch left untouched, caller offers delete
#   3 — user aborted the editor; branch left at predecessor with staged diff
# Usage: _doctor_apply_squash <branch> <prev_ref> <edit_msg:0|1>
_doctor_apply_squash() {
  local b="$1" prev_ref="$2" edit_msg="$3"

  # Pre-check tree equality so we never touch refs in the empty case.
  if _doctor_squash_is_empty "$b" "$prev_ref"; then
    return 2
  fi

  git checkout --quiet "$b"
  git reset --soft --quiet "$prev_ref"
  local msg
  msg=$(_doctor_default_squash_msg "$prev_ref" "ORIG_HEAD")
  if (( edit_msg )); then
    git commit --quiet --edit -m "$msg" || return 3
  else
    git commit --quiet -m "$msg"
  fi
  return 0
}

# Delete a branch that's been fully absorbed into its predecessor.
# Usage: _doctor_delete_branch <branch> <prev_ref>
_doctor_delete_branch() {
  local b="$1" prev_ref="$2"
  git checkout --quiet "$prev_ref"
  git update-ref -d "refs/heads/$b"
}

# Read one char from /dev/tty, lowercase it, echo to stdout. Empty string on
# bare RET. Returns 1 if /dev/tty isn't readable.
# Usage: _doctor_prompt <prompt-string>
_doctor_prompt() {
  local prompt="$1"
  [[ -e /dev/tty ]] || return 1
  printf '%s%s%s' "$C_DIM" "$prompt" "$C_RESET" >&2
  local ans
  read -r ans < /dev/tty || return 1
  # Portable lowercase (bash 3.2 on macOS lacks ${var,,}).
  ans=$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')
  ans="${ans:0:1}"
  printf '%s\n' "$ans"
}

# Print the per-issue header to stderr.
# Args: <idx_1based> <total> <branch> <kind>
_doctor_print_issue_header() {
  local idx="$1" total="$2" branch="$3" kind="$4"
  local label
  case "$kind" in
    merge)  label="merge commit at tip" ;;
    multi)  label="multi-commit branch" ;;
    both)   label="merge commit + multi-commit" ;;
    rename) label="leaf out of order" ;;
    *)      label="$kind" ;;
  esac
  printf '\n%s[%d/%d]%s %s%s%s  %s%s%s\n' \
    "$C_BOLD" "$idx" "$total" "$C_RESET" \
    "$C_CYAN" "$branch" "$C_RESET" \
    "$C_DIM" "$label" "$C_RESET" >&2
}

# Finish a doctor run as ONE resumable engine plan, composing:
#   - reflow-pick   when from_idx is in range (stale predecessors to re-thread
#                   after a squash/sweep or duplicate renumber)
#   - remote-sync   when renames were applied this run and push is enabled
# Driving both through a single plan means 'continue'/'abort' carry the whole
# remainder, and the remote tail (remote rename + pr sync) is the genuine last
# step — pr sync reflects the reflowed SHAs, and a remote failure pauses with
# state retained rather than dying with a manual-recovery hint. The caller sets
# STACK_RENAME_PAIRS to the applied renames (alternating old/new); empty ⇒ no
# remote tail. Returns 0 (no plan) when there's nothing to do.
# Usage: _doctor_finish <prefix> <from_idx> <branch>...
_doctor_finish() {
  local prefix="$1" from_idx="$2"; shift 2
  local branches=("$@")

  local want_reflow=0 want_remote=0
  (( from_idx >= 0 && from_idx < ${#branches[@]} )) && want_reflow=1
  (( ${#STACK_RENAME_PAIRS[@]} > 0 && ! OPT_NO_PUSH )) && want_remote=1
  # Fold always has a remote victim to delete (+ breadcrumb), even with no rename.
  [[ -n "$STACK_FOLD_VICTIM" ]] && (( ! OPT_NO_PUSH )) && want_remote=1
  (( want_reflow || want_remote )) || return 0

  STACK_BRANCHES=("${branches[@]}")
  STACK_ORIG_SHAS=()
  STACK_PUSH_FAILURES=()
  STACK_STARTED_AT=$(date +%s)
  STACK_STARTING_BRANCH=$(current_branch 2>/dev/null || echo "")
  STACK_PREFIX="$prefix"
  STACK_PUSH=0
  STACK_ONTO=""
  STACK_ONTO_REF=""
  STACK_OPT_NO_PUSH="$OPT_NO_PUSH"
  STACK_OPT_NO_SYNC="$OPT_NO_SYNC"
  STACK_PHASES=()
  STACK_PHASE_IDX=0
  STACK_UNIT_IDX=0

  if (( want_reflow )); then
    local i
    for ((i = 0; i < ${#branches[@]}; i++)); do
      STACK_ORIG_SHAS+=("$(git rev-parse "refs/heads/${branches[$i]}")")
    done
    # --force is safe here: every multi-commit / merge-tip branch was already
    # either squashed or marked absorbed during the squash + sweep phases. Any
    # remaining "ahead by >1" count is purely from stale predecessor ancestry
    # left in the upper branches' history — do_one_step's tip-only cherry-pick
    # is exactly the right behavior for that case. If a user skipped squashing
    # a real multi-commit branch, doctor's snapshot lets them roll back.
    STACK_FORCE=1
    STACK_FROM_IDX="$from_idx"
    STACK_PHASES+=(reflow-pick)
    log ""
    log "${C_DIM}reflow${C_RESET}  re-threading branches from index $from_idx"
    # Callers that already snapshotted the pre-mutation state (e.g. fold, whose
    # snapshot must capture the to-be-deleted victim) suppress this one so the
    # newest snapshot is the meaningful one.
    (( ${STACK_SUPPRESS_REFLOW_SNAPSHOT:-0} )) \
      || snapshot_stack doctor-reflow "$prefix" "${STACK_BRANCHES[@]}"
  else
    STACK_FORCE=0
    STACK_FROM_IDX=${#STACK_BRANCHES[@]}
  fi
  (( want_remote )) && STACK_PHASES+=(remote-sync)

  save_engine_state
  _engine_run
}

cmd_fold() {
  OPT_PREFIX=""; OPT_NO_SYNC=0; OPT_NO_PUSH=0
  local victim_arg="" opt_up=0 opt_yes=0 opt_slug="" opt_at="" opt_allow_pr_rebuild=0 opt_dry_run=0
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then shift "$_FLAG_SHIFT"; continue; fi
    case "$1" in
      --up)   opt_up=1; shift ;;
      --down) opt_up=0; shift ;;
      --slug) shift; [[ $# -gt 0 ]] || die "--slug needs an argument"; opt_slug="$1"; shift ;;
      --at)   shift; [[ $# -gt 0 ]] || die "--at needs an argument"; opt_at="$1"; shift ;;
      --allow-pr-rebuild) opt_allow_pr_rebuild=1; shift ;;
      --dry-run) opt_dry_run=1; shift ;;
      --yes)  opt_yes=1; shift ;;
      -*)     die "unknown fold flag: $1" ;;
      *)      [[ -z "$victim_arg" ]] || die "fold: extra arg '$1'"; victim_arg="$1"; shift ;;
    esac
  done
  if [[ -n "$opt_at" && ! "$opt_at" =~ ^[0-9]+$ ]]; then
    die "fold --at: requires a non-negative integer leaf number (got '$opt_at')"
  fi

  require_in_repo
  require_clean_tree
  require_no_op_in_progress
  require_no_state_file

  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")

  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under '$prefix'"
  (( ${#branches[@]} >= 2 )) || die "fold: stack has fewer than 2 branches; use 'git stack clean' to remove a lone branch"
  _require_valid_leaf_nums "${branches[@]}"

  # Default victim to the current branch.
  if [[ -z "$victim_arg" ]]; then
    victim_arg=$(current_branch) \
      || die "usage: git stack fold [<branch>] [--up|--down]
fold: no <branch> given and HEAD is detached"
  fi
  local victim rc=0
  victim=$(_resolve_branch_ref "$victim_arg" "${branches[@]}") || rc=$?
  (( rc == 0 )) || die "fold: '$victim_arg' not in stack '$prefix'"
  local victim_idx
  victim_idx=$(branch_index "$victim" "${branches[@]}")

  # Resolve the survivor: the neighbor in the fold direction (default down =
  # predecessor). Hard-error with a directional hint at the stack boundaries.
  local survivor_idx survivor
  if (( opt_up )); then
    (( victim_idx < ${#branches[@]} - 1 )) \
      || die "fold: '$victim' is the tip — nothing above to fold into; use --down"
    survivor_idx=$((victim_idx + 1))
  else
    (( victim_idx > 0 )) \
      || die "fold: '$victim' is the bottom branch — nothing below to fold into; use --up"
    survivor_idx=$((victim_idx - 1))
  fi
  survivor="${branches[$survivor_idx]}"

  # The merged commit spans [lo's stack-parent .. hi's tip], keeps the
  # survivor's name, and sits in the survivor's slot.
  local lo=$victim_idx hi=$victim_idx
  if (( survivor_idx < victim_idx )); then lo=$survivor_idx; else hi=$survivor_idx; fi

  local base_ref
  if (( lo == 0 )); then
    local parent_name
    parent_name=$(_resolve_parent_name) \
      || die "fold: cannot determine parent branch (set stack.base or create main/master)"
    base_ref=$(_resolve_parent_ref "$parent_name")
  else
    base_ref="refs/heads/${branches[$((lo - 1))]}"
  fi

  # On a TTY (no --slug/--yes/--dry-run), offer to set the result slug inline —
  # the "write the slug" moment. Default is the victim's slug (the branch you ran
  # fold on names the result); empty input keeps it. Done before name resolution
  # so the entered slug flows through the gate + validation.
  if (( ! opt_yes && ! opt_dry_run )) && [[ -z "$opt_slug" && -e /dev/tty && ( -t 0 || -t 2 ) ]]; then
    local _cur_slug="${victim##*/}"; _cur_slug="${_cur_slug#*-}"
    local _entered=""
    printf '%sresult slug [%s]:%s ' "$C_DIM" "$_cur_slug" "$C_RESET" >&2
    if read -r _entered < /dev/tty && [[ -n "$_entered" ]]; then
      opt_slug="$_entered"
    fi
  fi

  # Resolve the result branch name (leaf + slug). The result keeps the survivor's
  # leaf (position) but defaults its slug to the *victim's* — the branch you ran
  # fold on names the result. --slug overrides the slug, --at the leaf. Validate
  # before any mutation so a bad --at fails clean.
  local seg="${survivor##*/}"
  local survivor_leaf="${seg%%-*}" survivor_slug="${seg#*-}"
  local victim_seg="${victim##*/}"
  local victim_slug="${victim_seg#*-}"
  local new_slug="${opt_slug:-$victim_slug}"
  local width result_leaf_num
  width=$(_leaf_width_for "${branches[@]}")
  if [[ -n "$opt_at" ]]; then
    result_leaf_num=$((10#$opt_at))
    # Bound strictly between the merged pair's predecessor and the first child,
    # so the result cannot reorder past a neighbor.
    local pred_leaf_num=0
    (( lo > 0 )) && { local pseg="${branches[$((lo - 1))]##*/}"; pred_leaf_num=$((10#${pseg%%-*})); }
    (( result_leaf_num > pred_leaf_num )) \
      || die "fold --at: leaf $opt_at is not above the predecessor leaf $pred_leaf_num"
    if (( hi + 1 < ${#branches[@]} )); then
      local cseg="${branches[$((hi + 1))]##*/}" child_leaf_num
      child_leaf_num=$((10#${cseg%%-*}))
      (( result_leaf_num < child_leaf_num )) \
        || die "fold --at: leaf $opt_at would reorder past child leaf $child_leaf_num; pick a lower number"
    fi
    local cb
    for cb in "${branches[@]}"; do
      [[ "$cb" == "$victim" || "$cb" == "$survivor" ]] && continue
      local cbseg="${cb##*/}"
      (( 10#${cbseg%%-*} == result_leaf_num )) && die "fold --at: leaf $opt_at collides with '$cb'"
    done
  else
    result_leaf_num=$((10#$survivor_leaf))
  fi
  result_leaf=$(_format_leaf "$result_leaf_num" "$width")
  local new_survivor="${prefix}${result_leaf}-${new_slug}"
  [[ "$new_survivor" == */* ]] || die "fold: could not derive result branch name"
  if [[ "$new_survivor" != "$survivor" ]]; then
    git rev-parse --verify --quiet "refs/heads/${new_survivor}" >/dev/null \
      && die "fold: target branch '${new_survivor}' already exists"
  fi

  # Dry run: describe the plan (incl. any PRs that would close) and stop before
  # any mutation. No --yes / TTY needed since nothing changes.
  if (( opt_dry_run )); then
    local n_children=$(( ${#branches[@]} - 1 - hi ))
    log "${C_BOLD}dry run${C_RESET}: would fold ${C_BOLD}${C_CYAN}${victim}${C_RESET} into ${C_BOLD}${C_CYAN}${new_survivor}${C_RESET}"
    [[ "$new_survivor" != "$survivor" ]] \
      && log "  ${C_DIM}survivor ${survivor} renamed to ${new_survivor}${C_RESET}"
    log "  ${C_DIM}reflow ${n_children} child(ren) onto ${new_survivor}${C_RESET}"
    if (( ! OPT_NO_PUSH )); then
      local dr_gate=("$victim")
      [[ "$new_survivor" != "$survivor" ]] && dr_gate+=("$survivor")
      if _check_no_open_prs "${dr_gate[@]}"; then
        log "  ${C_YELLOW}would close PR #${_ORPHAN_PR_NUM}${C_RESET} for ${_ORPHAN_PR_BRANCH} (needs --allow-pr-rebuild, or 'pr desync' first)"
      fi
    fi
    log "  ${C_DIM}rerun without --dry-run to apply${C_RESET}"
    return 0
  fi

  # PR gate: deleting the victim (always) and renaming the survivor (slug change)
  # close their head PRs on GitHub, with no reattach. Refuse by default unless
  # --allow-pr-rebuild or --no-push.
  if (( ! opt_allow_pr_rebuild )) && (( ! OPT_NO_PUSH )); then
    local gate_branches=("$victim")
    [[ "$new_survivor" != "$survivor" ]] && gate_branches+=("$survivor")
    if _check_no_open_prs "${gate_branches[@]}"; then
      die "fold would close PR #${_ORPHAN_PR_NUM} for ${_ORPHAN_PR_BRANCH} — deleting or renaming a branch closes its head PR on GitHub, with no reattach. Pass --allow-pr-rebuild to accept the close (a breadcrumb to the superseding PR is posted, and 'pr sync' rebuilds the survivor). Or run 'git stack pr desync' first to take the stack offline, then fold, then 'git stack pr sync' to re-publish cleanly."
    fi
  fi

  # Destructive op: confirm on a TTY, refuse non-interactively without --yes.
  if (( ! opt_yes )); then
    if [[ -e /dev/tty && ( -t 0 || -t 2 ) ]]; then
      # Spell out the plan, multi-line and prefix-stripped so it stays legible.
      local _v="${victim#"$prefix"}" _s="${survivor#"$prefix"}" _r="${new_survivor#"$prefix"}"
      # Branch names in bold cyan; reset before each (to clear the dim framing)
      # and re-dim after, so the names genuinely stand out.
      local _hl="${C_RESET}${C_BOLD}${C_CYAN}" _fr="${C_RESET}${C_DIM}"
      if [[ "$new_survivor" != "$survivor" ]]; then
        printf '%sfold %s%s%s\n  into %s%s%s\n  → result %s%s%s (deletes both originals). proceed?%s [Y/n] ' \
          "$C_DIM" "$_hl" "$_v" "$_fr" \
          "$_hl" "$_s" "$_fr" \
          "$_hl" "$_r" "$_fr" "$C_RESET" >&2
      else
        printf '%sfold %s%s%s\n  into %s%s%s (deletes %s%s%s). proceed?%s [Y/n] ' \
          "$C_DIM" "$_hl" "$_v" "$_fr" \
          "$_hl" "$_s" "$_fr" \
          "$_hl" "$_v" "$_fr" "$C_RESET" >&2
      fi
      local _ans
      read -r _ans < /dev/tty || die "fold: aborted"
      _ans=$(printf '%s' "$_ans" | tr '[:upper:]' '[:lower:]')
      [[ "${_ans:0:1}" == "n" ]] && die "fold: aborted"
    else
      die "fold: refusing to fold '${victim}' into '${new_survivor}' non-interactively; pass --yes"
    fi
  fi

  # Snapshot the full pre-fold state (including the victim, which the apply step
  # deletes) so 'history restore' can undo the whole fold. The inner reflow
  # snapshot is suppressed so this stays the newest one.
  _SNAPSHOT_FOCUS="result=${new_survivor##*/}"$'\n'"victim=${victim##*/}"
  snapshot_stack fold "$prefix" "${branches[@]}"
  STACK_SUPPRESS_REFLOW_SNAPSHOT=1

  local base_sha merged_tree msg squash
  base_sha=$(git rev-parse "$base_ref")
  merged_tree=$(git rev-parse "refs/heads/${branches[$hi]}^{tree}")
  msg=$(git log -1 --format=%B "refs/heads/${survivor}")
  squash=$(printf '%s' "$msg" | git commit-tree "$merged_tree" -p "$base_sha")

  # Point the (possibly renamed) survivor at the squash, then drop the victim
  # and the old survivor name. Detach first so we never hold a ref we delete.
  git checkout --quiet --detach "$squash"
  git update-ref "refs/heads/${new_survivor}" "$squash"
  [[ "$new_survivor" != "$survivor" ]] && git update-ref -d "refs/heads/${survivor}"
  git update-ref -d "refs/heads/${victim}"
  git checkout --quiet "$new_survivor"

  log "${C_GREEN}done${C_RESET}    folded ${C_BOLD}${C_CYAN}${victim}${C_RESET} into ${C_BOLD}${C_CYAN}${new_survivor}${C_RESET}"

  # Re-thread the children (everything above the merged pair) onto the
  # survivor, via the resumable reflow engine — same composer doctor uses.
  # A slug change is a rename, fed to the remote tail via STACK_RENAME_PAIRS.
  local post=() b
  for b in "${branches[@]}"; do
    [[ "$b" == "$victim" ]] && continue
    if [[ "$b" == "$survivor" ]]; then post+=("$new_survivor"); else post+=("$b"); fi
  done
  local survivor_post_idx
  survivor_post_idx=$(branch_index "$new_survivor" "${post[@]}")
  if [[ "$new_survivor" != "$survivor" ]]; then
    STACK_RENAME_PAIRS=("$survivor" "$new_survivor")
  else
    STACK_RENAME_PAIRS=()
  fi
  # The remote tail (in the remote-sync phase) deletes the victim's remote
  # branch and breadcrumbs its PR to the superseding one.
  STACK_FOLD_VICTIM="$victim"
  STACK_FOLD_SURVIVOR_NEW="$new_survivor"
  _doctor_finish "$prefix" "$((survivor_post_idx + 1))" "${post[@]}"
}

# Discard a branch's diff and reflow its children onto the predecessor — the
# destructive sibling of fold (fold keeps the work; drop throws it away). Fully
# local (ADR 0008): no push / rename / pr sync; the orphaned remote is left for
# a later clean to reap. Carries fold's destructive ceremony and move's
# multi-commit pre-check / STACK_FORCE.
cmd_drop() {
  OPT_PREFIX=""; OPT_NO_SYNC=0; OPT_NO_PUSH=0
  local victim_arg="" opt_force=0 opt_dry_run=0 opt_yes=0
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then shift "$_FLAG_SHIFT"; continue; fi
    case "$1" in
      --force)   opt_force=1; shift ;;
      --dry-run) opt_dry_run=1; shift ;;
      --yes|-y)  opt_yes=1; shift ;;
      -*)        die "unknown drop flag: $1" ;;
      *)         [[ -z "$victim_arg" ]] || die "drop: extra arg '$1'"; victim_arg="$1"; shift ;;
    esac
  done

  require_in_repo
  require_clean_tree
  require_no_op_in_progress
  require_no_state_file

  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")

  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under '$prefix'"
  _require_valid_leaf_nums "${branches[@]}"

  # Default victim to the current branch.
  if [[ -z "$victim_arg" ]]; then
    victim_arg=$(current_branch) \
      || die "usage: git stack drop [<branch>] [--force] [--dry-run] [--yes]
drop: no <branch> given and HEAD is detached"
  fi
  local victim rc=0
  victim=$(_resolve_branch_ref "$victim_arg" "${branches[@]}") || rc=$?
  (( rc == 0 )) || die "drop: '$victim_arg' not in stack '$prefix'"
  local victim_idx
  victim_idx=$(branch_index "$victim" "${branches[@]}")

  # Capture the victim's tip before we delete its ref below — it's the one commit
  # the child reflow is allowed to drop (see STACK_SAFE_DROP at the reflow setup).
  local victim_sha
  victim_sha=$(git rev-parse "refs/heads/${victim}")

  local n=${#branches[@]}
  local n_children=$(( n - 1 - victim_idx ))

  # Resolve the landing ref for the children + HEAD: the predecessor branch, or
  # the base when the victim is the bottom (or lone) branch.
  local pred_ref pred_label is_base=0
  if (( victim_idx == 0 )); then
    local parent_name
    parent_name=$(_resolve_parent_name) \
      || die "drop: cannot determine parent branch (set stack.base or create main/master)"
    pred_ref=$(_resolve_parent_ref "$parent_name") \
      || die "drop: cannot resolve parent ref for '$parent_name'"
    pred_label="$parent_name"
    is_base=1
  else
    pred_label="${branches[$((victim_idx - 1))]}"
    pred_ref="refs/heads/${pred_label}"
  fi

  # Dry run: describe the plan (victim, landing ref, child count, PR-gate
  # forecast) and stop before any mutation — always previews, even when a
  # multi-commit child would later force the run. No --yes / TTY needed.
  if (( opt_dry_run )); then
    log "${C_BOLD}dry run${C_RESET}: would drop ${C_BOLD}${C_CYAN}${victim}${C_RESET} (discards its work)"
    if (( n_children > 0 )); then
      log "  ${C_DIM}reflow ${n_children} child(ren) onto ${pred_label}${C_RESET}"
    else
      log "  ${C_DIM}no children — pure delete; HEAD lands on ${pred_label}${C_RESET}"
    fi
    if _check_no_open_prs "$victim"; then
      log "  ${C_YELLOW}would refuse: ${victim} has open PR #${_ORPHAN_PR_NUM}${C_RESET} (run 'pr desync' first)"
    fi
    log "  ${C_DIM}rerun without --dry-run to apply${C_RESET}"
    return 0
  fi

  # Resolvability pre-flight: mirror the engine's multi-commit guard against each
  # child's *post-drop* predecessor so an unresolvable reflow refuses atomically
  # — before the victim ref is deleted below — instead of dying mid-reflow with
  # the delete already applied. The first child lands on the victim's predecessor
  # (pred_ref); the rest keep their current predecessor (the chain above the
  # victim is untouched). The victim's tip is the one commit a tip-only reflow may
  # drop, so it's excluded via --not; a child threading any *other* extra commit
  # (e.g. a manually-built branch off the victim's middle, which the count diff
  # alone can't see) still refuses. --force waives the whole pre-flight; the
  # engine's STACK_FORCE backstop then drops tips knowingly. The victim itself is
  # discarded wholesale, so it needs no guard.
  if (( ! opt_force )); then
    local i pb pf_pred cnt_b cnt_prev nc
    for ((i = victim_idx + 1; i < n; i++)); do
      pb="refs/heads/${branches[$i]}"
      if (( i == victim_idx + 1 )); then
        pf_pred="$pred_ref"
      else
        pf_pred="refs/heads/${branches[$((i - 1))]}"
      fi
      cnt_b=$(git rev-list --count "$pb" 2>/dev/null || echo 0)
      cnt_prev=$(git rev-list --count "$pf_pred" 2>/dev/null || echo 0)
      nc=$((cnt_b - cnt_prev))
      (( nc > 1 )) || continue
      if ! _reflow_own_only "$pf_pred" "$pb" "$victim_sha"; then
        die "branch '${branches[$i]}' has commits beyond '${pf_pred#refs/heads/}' that drop didn't discard; reflowing it tip-only would lose all but the tip. Squash/rebase '${branches[$i]}' to a single commit and retry, or pass --force to cherry-pick the tip and deliberately drop them."
      fi
    done
  fi

  # PR gate — victim only. Deleting the victim's head branch closes its PR on
  # GitHub with no reattach and (unlike fold) no superseding PR to breadcrumb
  # to. Children keep their names, so their PRs survive a later 'pr sync' and
  # pass through ungated. Checked unconditionally (like move); the only escape
  # is the desync workflow.
  if _check_no_open_prs "$victim"; then
    die "drop: '${victim}' has an open PR (#${_ORPHAN_PR_NUM}); deleting its head branch closes the PR on GitHub with no reattach and no superseding PR to breadcrumb to. Run 'git stack pr desync' to take the stack offline first, then 'git stack drop', then 'git stack pr sync' to re-publish cleanly."
  fi

  # Destructive op: confirm on a TTY, refuse non-interactively without --yes.
  if (( ! opt_yes )); then
    if [[ -e /dev/tty && ( -t 0 || -t 2 ) ]]; then
      local _v="${victim#"$prefix"}" _p="${pred_label#"$prefix"}"
      local _hl="${C_RESET}${C_BOLD}${C_CYAN}" _fr="${C_RESET}${C_DIM}"
      if (( n_children > 0 )); then
        printf '%sdrop %s%s%s\n  discards its work; reflow %d child(ren) onto %s%s%s. proceed?%s [Y/n] ' \
          "$C_DIM" "$_hl" "$_v" "$_fr" "$n_children" "$_hl" "$_p" "$_fr" "$C_RESET" >&2
      else
        printf '%sdrop %s%s%s\n  discards its work (pure delete). proceed?%s [Y/n] ' \
          "$C_DIM" "$_hl" "$_v" "$_fr" "$C_RESET" >&2
      fi
      local _ans
      read -r _ans < /dev/tty || die "drop: aborted"
      _ans=$(printf '%s' "$_ans" | tr '[:upper:]' '[:lower:]')
      [[ "${_ans:0:1}" == "n" ]] && die "drop: aborted"
    else
      die "drop: refusing to drop '${victim}' non-interactively; pass --yes"
    fi
  fi

  # Snapshot the full pre-drop state (including the victim, which we delete
  # below) so 'history restore' can undo the whole drop. This single snapshot is
  # the restore point.
  _SNAPSHOT_FOCUS="leaf=${victim##*/}"
  snapshot_stack drop "$prefix" "${branches[@]}"

  # If HEAD is on the victim, move off it to the landing ref before we delete it
  # — both so the delete succeeds and so the engine's end-of-run restore (to
  # STACK_STARTING_BRANCH, captured just below) lands on the predecessor/base.
  # When HEAD is on another branch, leave it: that branch reflows and HEAD
  # returns to it.
  local cur
  cur=$(current_branch 2>/dev/null || echo "")
  if [[ "$cur" == "$victim" ]]; then
    if (( is_base )) && ! git rev-parse --verify --quiet "refs/heads/${pred_label}" >/dev/null; then
      git checkout --quiet --detach "$pred_ref"
    else
      git checkout --quiet "$pred_label"
    fi
  fi
  git update-ref -d "refs/heads/${victim}"

  log "${C_GREEN}done${C_RESET}    dropped ${C_BOLD}${C_CYAN}${victim}${C_RESET}"

  # Reflow the children onto the landing ref via the resumable engine. Build the
  # plan inline (reflow-pick only, no remote phase) — unlike fold, the bottom
  # case reflows the first child at post-index 0, which needs STACK_ONTO set to
  # the base (something _doctor_finish never does).
  if (( n_children > 0 )); then
    local post=() i
    for ((i = 0; i < n; i++)); do
      (( i == victim_idx )) && continue
      post+=("${branches[$i]}")
    done
    local first_affected=$victim_idx   # children start here in post-space

    STACK_BRANCHES=("${post[@]}")
    STACK_ORIG_SHAS=()
    for ((i = 0; i < ${#STACK_BRANCHES[@]}; i++)); do
      if (( i >= first_affected )); then
        STACK_ORIG_SHAS+=("$(git rev-parse "refs/heads/${STACK_BRANCHES[$i]}")")
      else
        STACK_ORIG_SHAS+=("")
      fi
    done
    STACK_STARTED_AT=$(date +%s)
    STACK_STARTING_BRANCH=$(current_branch 2>/dev/null || echo "")
    STACK_PREFIX="$prefix"
    STACK_PUSH=0
    # do_one_step's guard compares each child against its *new* predecessor and
    # would false-positive: the child's history still contains the dropped
    # branch's commit, registering as an extra commit. Rather than waive the
    # guard wholesale (STACK_FORCE), name exactly what's safe to lose — the
    # victim's tip. The guard's `--not "$victim_sha"` then excludes it (and its
    # ancestors), so a legitimate child collapses to just its own tip and passes,
    # while a child carrying additional unmerged work still refuses. --force
    # still suppresses the guard outright (and skips the pre-check above).
    STACK_SAFE_DROP=("$victim_sha")
    STACK_FORCE="$opt_force"
    STACK_ONTO=""
    STACK_ONTO_REF=""
    STACK_FROM_IDX="$first_affected"
    STACK_PUSH_FAILURES=()
    STACK_OPT_NO_PUSH="$OPT_NO_PUSH"
    STACK_OPT_NO_SYNC="$OPT_NO_SYNC"
    if (( first_affected == 0 )); then
      STACK_ONTO=$(git rev-parse "$pred_ref")
      STACK_ONTO_REF="$pred_label"
    fi
    STACK_PHASES=(reflow-pick)
    STACK_PHASE_IDX=0
    STACK_UNIT_IDX=0
    save_engine_state
    _engine_run
  fi

  # Advisory only (never mutating): a survivor whose tree now equals its
  # predecessor's was absorbed during the reflow. drop deletes exactly the one
  # named branch — never a second one by content — so point at doctor/fold.
  local adv=() av_i
  _load_stack_branches "$prefix" adv
  for ((av_i = 1; av_i < ${#adv[@]}; av_i++)); do
    if git diff --quiet "refs/heads/${adv[av_i-1]}" "refs/heads/${adv[av_i]}" 2>/dev/null; then
      log "${C_YELLOW}note${C_RESET}    ${C_CYAN}${adv[av_i]}${C_RESET} is now empty (absorbed into ${C_CYAN}${adv[av_i-1]}${C_RESET}) — run ${C_BOLD}doctor${C_RESET} to drop it, or ${C_BOLD}fold${C_RESET} to collapse"
    fi
  done
}

cmd_doctor() {
  OPT_PREFIX=""; OPT_NO_SYNC=0; OPT_NO_PUSH=0; OPT_FORCE=0
  STACK_SUPPRESS_REFLOW_SNAPSHOT=0
  local opt_dry_run=0 opt_yes=0 opt_no_squash=0 opt_no_rename=0
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --dry-run)   opt_dry_run=1; shift ;;
      --yes|-y)    opt_yes=1; shift ;;
      --no-squash) opt_no_squash=1; shift ;;
      --no-rename) opt_no_rename=1; shift ;;
      -*)          die "unknown doctor flag: $1" ;;
      *)           die "doctor takes no positional arguments" ;;
    esac
  done

  require_in_repo
  require_clean_tree
  require_no_op_in_progress
  require_no_state_file

  # Interactive only when stdin and stdout are both TTYs and the user hasn't
  # opted out via --yes / --dry-run. Refuse otherwise to avoid silently
  # mis-applying destructive fixes from a pipe.
  local interactive=0
  if (( opt_yes || opt_dry_run )); then
    interactive=0
  elif [[ -t 0 && -t 1 ]]; then
    interactive=1
  else
    die "doctor: not running on a tty; pass --yes to auto-apply or --dry-run to preview"
  fi

  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")
  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under '$prefix'"

  local parent_name parent_ref
  parent_name=$(_resolve_parent_name) \
    || die "doctor: cannot determine parent branch (set stack.base or create main/master)"
  parent_ref=$(_resolve_parent_ref "$parent_name") \
    || die "doctor: cannot resolve parent ref for '$parent_name'"

  # ----- Scan -----
  #
  # Gather git facts once, then map shape -> issue list with the pure scanner,
  # and bucket the issues into the arrays the dry-run / apply stages consume.
  # --no-squash / --no-rename drop their issue kinds here.

  local _facts=()
  _doctor_gather _facts "$parent_ref" "${branches[@]}"
  local squash_idx=() squash_kind=() rename_pairs=() dup_groups=()
  local _tag _f1 _f2
  while IFS=$'\t' read -r _tag _f1 _f2; do
    case "$_tag" in
      squash) (( opt_no_squash )) || { squash_idx+=("$_f1"); squash_kind+=("$_f2"); } ;;
      dup)    (( opt_no_rename )) || dup_groups+=("${_f1}"$'\t'"${_f2}") ;;
      rename) (( opt_no_rename )) || rename_pairs+=("$_f1" "$_f2") ;;
    esac
  done < <(_doctor_scan "$prefix" "${_facts[@]}")

  if (( ${#rename_pairs[@]} > 0 )); then
    _doctor_check_rename_collisions "${rename_pairs[@]}"
  fi

  local total_issues=$(( ${#squash_idx[@]} + ${#rename_pairs[@]} / 2 ))
  if (( total_issues == 0 )); then
    log "${C_GREEN}doctor${C_RESET}  stack '$prefix' already valid"
    return 0
  fi

  # ----- Dry-run -----

  if (( opt_dry_run )); then
    log "${C_BOLD}doctor (dry-run):${C_RESET} stack ${C_CYAN}${prefix}${C_RESET}"
    if (( ${#dup_groups[@]} > 0 )); then
      local g_str leaf_num idx_csv _ifs di
      for g_str in "${dup_groups[@]}"; do
        leaf_num="${g_str%%$'\t'*}"
        idx_csv="${g_str#*$'\t'}"
        log "  ${C_YELLOW}duplicate leaf ${leaf_num}${C_RESET} (sort-V order; interactive mode lets you reorder):"
        _ifs="$IFS"
        IFS=','
        local dup_indices=($idx_csv)
        IFS="$_ifs"
        for ((di = 0; di < ${#dup_indices[@]}; di++)); do
          log "    ${C_CYAN}${branches[${dup_indices[$di]}]}${C_RESET}"
        done
      done
    fi
    local k
    for ((k = 0; k < ${#squash_idx[@]}; k++)); do
      log "  squash  ${C_CYAN}${branches[${squash_idx[$k]}]}${C_RESET}  (${squash_kind[$k]})"
    done
    local i
    for ((i = 0; i < ${#rename_pairs[@]}; i+=2)); do
      log "  rename  ${C_CYAN}${rename_pairs[$i]}${C_RESET} -> ${C_CYAN}${rename_pairs[$((i+1))]}${C_RESET}"
    done
    return 0
  fi

  # ----- Apply: one snapshot covers the whole session -----

  snapshot_stack doctor "$prefix" "${branches[@]}"

  local applied_squash=0 lowest_squash_idx=-1
  local lowest_dup_idx=-1
  local apply_all=$(( opt_yes ))
  local user_quit=0
  # Renames applied this run (alternating old/new), carried to the finish phase
  # so its remote tail (remote rename + pr sync) runs after the reflow.
  local doctor_rename_pairs=()

  # ----- Squash phase (bottom-up, applies immediately) -----

  if (( ${#squash_idx[@]} > 0 )); then
    local k idx b prev_ref kind ans rc tip_sha tip_subj n_commits edit_msg
    for ((k = 0; k < ${#squash_idx[@]}; k++)); do
      (( user_quit )) && break
      idx="${squash_idx[$k]}"
      b="${branches[$idx]}"
      kind="${squash_kind[$k]}"
      if (( idx == 0 )); then
        prev_ref="$parent_ref"
      else
        prev_ref="refs/heads/${branches[$((idx-1))]}"
      fi

      # Absorbed-branch case: no squash needed; offer delete directly.
      if [[ "$kind" == "absorbed" ]]; then
        _doctor_print_issue_header "$((k+1))" "${#squash_idx[@]}" "$b" "absorbed"
        printf '  %sbranch is fully absorbed into %s%s%s (tree matches predecessor)%s\n' \
          "$C_DIM" "$C_CYAN" "${prev_ref##refs/heads/}" "$C_DIM" "$C_RESET" >&2
        local del_ans
        if (( apply_all )); then
          del_ans=y
        elif (( interactive )); then
          del_ans=$(_doctor_prompt "  delete branch? [y/N/q]: ") || del_ans=n
        else
          del_ans=y
        fi
        case "$del_ans" in
          y)
            _doctor_delete_branch "$b" "$prev_ref"
            printf '  %sdeleted%s %s%s%s\n' "$C_YELLOW" "$C_RESET" "$C_CYAN" "$b" "$C_RESET" >&2
            local nb=() m
            for ((m = 0; m < ${#branches[@]}; m++)); do
              if (( m != idx )); then nb+=("${branches[$m]}"); fi
            done
            branches=("${nb[@]}")
            local mm
            for ((mm = k + 1; mm < ${#squash_idx[@]}; mm++)); do
              squash_idx[$mm]=$(( squash_idx[mm] - 1 ))
            done
            applied_squash=$((applied_squash + 1))
            if (( lowest_squash_idx < 0 )); then
              lowest_squash_idx=$idx
            fi
            ;;
          q) user_quit=1 ;;
          *) printf '  %sskip%s\n' "$C_DIM" "$C_RESET" >&2 ;;
        esac
        continue
      fi

      _doctor_print_issue_header "$((k+1))" "${#squash_idx[@]}" "$b" "$kind"

      tip_sha=$(git rev-parse --short "refs/heads/$b")
      tip_subj=$(git log -1 --format='%s' "refs/heads/$b")
      n_commits=$(( $(git rev-list --count "refs/heads/$b") - $(git rev-list --count "$prev_ref") ))
      printf '  %stip:%s %s %s%s%s\n' \
        "$C_DIM" "$C_RESET" "$tip_sha" "$C_DIM" "$tip_subj" "$C_RESET" >&2
      printf '  %s%d commit(s) ahead of %s%s%s:%s\n' \
        "$C_DIM" "$n_commits" "$C_CYAN" "${prev_ref##refs/heads/}" "$C_DIM" "$C_RESET" >&2
      git log --reverse --format="    %h %s" "${prev_ref}..refs/heads/${b}" >&2 || true
      printf '  %sdefault squash message:%s\n' "$C_DIM" "$C_RESET" >&2
      _doctor_default_squash_msg "$prev_ref" "refs/heads/$b" | sed 's/^/    /' >&2

      edit_msg=0
      if (( apply_all )); then
        ans=y
      elif (( interactive )); then
        ans=$(_doctor_prompt "  squash? [y/e/N/a/q]: ") || ans=n
        case "$ans" in
          y) ;;
          e) edit_msg=1; ans=y ;;
          a) apply_all=1; ans=y ;;
          q) user_quit=1; continue ;;
          *) ans=n ;;
        esac
      else
        ans=n
      fi

      if [[ "$ans" != "y" ]]; then
        printf '  %sskip%s\n' "$C_DIM" "$C_RESET" >&2
        continue
      fi

      rc=0
      _doctor_apply_squash "$b" "$prev_ref" "$edit_msg" || rc=$?
      case "$rc" in
        0)
          local new_sha
          new_sha=$(git rev-parse --short "refs/heads/$b")
          printf '  %ssquashed%s %s%s%s: %s -> %s\n' \
            "$C_GREEN" "$C_RESET" "$C_CYAN" "$b" "$C_RESET" "$tip_sha" "$new_sha" >&2
          applied_squash=$((applied_squash + 1))
          if (( lowest_squash_idx < 0 )); then
            lowest_squash_idx=$idx
          fi
          ;;
        2)
          # Empty squash — branch is fully absorbed into predecessor. Offer delete.
          local del_ans
          printf '  %sbranch is fully absorbed into %s%s%s (no diff)%s\n' \
            "$C_DIM" "$C_CYAN" "${prev_ref##refs/heads/}" "$C_DIM" "$C_RESET" >&2
          if (( apply_all )); then
            del_ans=y
          elif (( interactive )); then
            del_ans=$(_doctor_prompt "  delete branch? [y/N/q]: ") || del_ans=n
          else
            del_ans=y
          fi
          case "$del_ans" in
            y)
              _doctor_delete_branch "$b" "$prev_ref"
              printf '  %sdeleted%s %s%s%s\n' "$C_YELLOW" "$C_RESET" "$C_CYAN" "$b" "$C_RESET" >&2
              local nb=() m
              for ((m = 0; m < ${#branches[@]}; m++)); do
                if (( m != idx )); then nb+=("${branches[$m]}"); fi
              done
              branches=("${nb[@]}")
              # Subsequent squash_idx entries now refer to shifted positions.
              local mm
              for ((mm = k + 1; mm < ${#squash_idx[@]}; mm++)); do
                squash_idx[$mm]=$(( squash_idx[mm] - 1 ))
              done
              applied_squash=$((applied_squash + 1))
              if (( lowest_squash_idx < 0 )); then
                lowest_squash_idx=$idx
              fi
              ;;
            q) user_quit=1 ;;
            *) printf '  %sskip%s (branch left untouched at original tip)\n' "$C_DIM" "$C_RESET" >&2 ;;
          esac
          ;;
        3)
          die "commit edit aborted on '$b'; branch left at predecessor with staged diff. Run 'git stack abort' ${C_DIM}[gstkab]${C_RESET} to restore, or re-commit manually."
          ;;
      esac
    done
  fi

  # ----- Duplicate-leaf resolution phase -----
  #
  # Detected after the squash phase so squash's tree/ancestry checks see the
  # original positional ordering. For each group of branches sharing a leaf
  # number, the user picks an order; the first member keeps the current number
  # and the rest cascade upward via the rename pass. Reflow must run from the
  # first cascaded index, since those branches' commit ancestry no longer
  # matches their new positional predecessor.

  if (( ! opt_no_rename && ! user_quit )); then
    dup_groups=()
    local _dline2
    while IFS= read -r _dline2; do
      [[ -n "$_dline2" ]] && dup_groups+=("$_dline2")
    done < <(_doctor_find_duplicate_groups "${branches[@]}")

    if (( ${#dup_groups[@]} > 0 )); then
      local g_str leaf_num idx_csv label_idx label_total rc _ifs
      label_total=${#dup_groups[@]}
      for ((label_idx = 0; label_idx < label_total; label_idx++)); do
        (( user_quit )) && break
        g_str="${dup_groups[$label_idx]}"
        leaf_num="${g_str%%$'\t'*}"
        idx_csv="${g_str#*$'\t'}"

        if (( apply_all )); then
          # Auto: keep current sort-V order. Still flag for reflow because the
          # second-and-later members will be renumbered.
          :
        elif (( interactive )); then
          rc=0
          _doctor_resolve_duplicate_group branches "$leaf_num" "$idx_csv" \
            "$((label_idx + 1))" "$label_total" || rc=$?
          if (( rc == 1 )); then
            user_quit=1
            continue
          fi
        fi

        _ifs="$IFS"
        IFS=','
        local g_indices=($idx_csv)
        IFS="$_ifs"
        # The second slot is the first index that gets renumbered → reflow
        # must start no later than there.
        if (( lowest_dup_idx < 0 || ${g_indices[1]} < lowest_dup_idx )); then
          lowest_dup_idx=${g_indices[1]}
        fi
      done
    fi

    # Once duplicates have been resolved, the cascading renames + reflow are
    # mechanical consequences of the chosen order — auto-apply them. Skipping a
    # rename here would desynchronize the in-memory (reordered) branches array
    # from actual refs and corrupt the reflow that follows.
    if (( lowest_dup_idx >= 0 && ! user_quit )); then
      apply_all=1
    fi
  fi

  # ----- Rename phase -----

  if (( ! opt_no_rename && ! user_quit )); then
    # Re-scan in case any squashes/deletes changed the branch list.
    rename_pairs=()
    _doctor_scan_renames rename_pairs "$prefix" "${branches[@]}"
    if (( ${#rename_pairs[@]} > 0 )); then
      _doctor_check_rename_collisions "${rename_pairs[@]}"

      local confirmed=()
      local i from_b to_b label_idx label_total ans
      label_total=$(( ${#rename_pairs[@]} / 2 ))
      for ((i = 0; i < ${#rename_pairs[@]}; i+=2)); do
        from_b="${rename_pairs[$i]}"
        to_b="${rename_pairs[$((i+1))]}"
        label_idx=$(( i / 2 + 1 ))
        _doctor_print_issue_header "$label_idx" "$label_total" "$from_b" "rename"
        printf '  %srename to:%s %s%s%s\n' "$C_DIM" "$C_RESET" "$C_CYAN" "$to_b" "$C_RESET" >&2

        if (( apply_all )); then
          ans=y
        elif (( interactive )); then
          ans=$(_doctor_prompt "  rename? [y/N/a/q]: ") || ans=n
          case "$ans" in
            y) ;;
            a) apply_all=1; ans=y ;;
            q) user_quit=1; ans=n ;;
            *) ans=n ;;
          esac
        else
          ans=n
        fi

        if [[ "$ans" == "y" ]]; then
          confirmed+=("$from_b" "$to_b")
        else
          printf '  %sskip%s\n' "$C_DIM" "$C_RESET" >&2
        fi
        (( user_quit )) && break
      done

      if (( ${#confirmed[@]} > 0 )); then
        _doctor_apply_renames_batch "${confirmed[@]}"
        doctor_rename_pairs=("${confirmed[@]}")
        # Renames mutate ref names — reload branches for reflow.
        branches=()
        _load_stack_branches "$prefix" branches
      fi
    fi
  fi

  # ----- Post-squash absorbed-branch sweep -----
  #
  # When a merge-tip squash collapses an upper branch's diff into the
  # squashed commit (e.g., 02-b absorbs 03-c via the merge), the upper
  # branch is now redundant — same tree as its new predecessor. Reflow
  # would hit an empty cherry-pick and bail. Sweep these first.

  if (( applied_squash > 0 && ! user_quit )); then
    local sweep_done=0
    while (( ! sweep_done )); do
      sweep_done=1
      local s_idx
      for ((s_idx = lowest_squash_idx + 1; s_idx < ${#branches[@]}; s_idx++)); do
        local s_b="${branches[$s_idx]}"
        local s_prev_ref
        if (( s_idx == 0 )); then
          s_prev_ref="$parent_ref"
        else
          s_prev_ref="refs/heads/${branches[$((s_idx-1))]}"
        fi
        if _doctor_squash_is_empty "$s_b" "$s_prev_ref"; then
          printf '\n%ssweep%s %s%s%s  %sabsorbed by squash%s\n' \
            "$C_BOLD" "$C_RESET" "$C_CYAN" "$s_b" "$C_RESET" \
            "$C_DIM" "$C_RESET" >&2
          printf '  %sbranch tree matches %s%s%s — nothing to cherry-pick%s\n' \
            "$C_DIM" "$C_CYAN" "${s_prev_ref##refs/heads/}" "$C_DIM" "$C_RESET" >&2
          local sw_ans
          if (( apply_all )); then
            sw_ans=y
          elif (( interactive )); then
            sw_ans=$(_doctor_prompt "  delete absorbed branch? [y/N/q]: ") || sw_ans=n
          else
            sw_ans=y
          fi
          case "$sw_ans" in
            y)
              _doctor_delete_branch "$s_b" "$s_prev_ref"
              printf '  %sdeleted%s %s%s%s\n' "$C_YELLOW" "$C_RESET" "$C_CYAN" "$s_b" "$C_RESET" >&2
              local nb=() m
              for ((m = 0; m < ${#branches[@]}; m++)); do
                if (( m != s_idx )); then nb+=("${branches[$m]}"); fi
              done
              branches=("${nb[@]}")
              sweep_done=0
              break
              ;;
            q) user_quit=1; sweep_done=1; break ;;
            *) printf '  %sskip%s (branch left in place; reflow will likely fail with empty cherry-pick)\n' "$C_DIM" "$C_RESET" >&2 ;;
          esac
        fi
      done
    done
  fi

  # ----- Finish phase: reflow + remote tail, as one resumable engine plan -----
  #
  # Reflow re-threads branches whose positional predecessor SHA went stale. Two
  # independent triggers:
  #   - squash: branches above a squashed branch must be replayed onto its
  #     new (single-commit) tip. Start at lowest_squash_idx + 1.
  #   - duplicate cascade: branches that got renumbered have a new positional
  #     predecessor whose tip is a different commit than their actual parent.
  #     Start at lowest_dup_idx (the first renumbered slot).
  # When both fire, take the lower index so the cascade covers everything.
  # The remote tail (remote rename + pr sync for any applied renames) is folded
  # into the same plan so it runs *after* the reflow and is itself resumable.
  # Reflow is skipped after a user quit; the remote tail still runs for renames
  # already confirmed and applied this run (keeping local and remote in sync).

  local reflow_from=-1
  if (( applied_squash > 0 && lowest_squash_idx >= 0 )); then
    reflow_from=$((lowest_squash_idx + 1))
  fi
  if (( lowest_dup_idx >= 0 )); then
    if (( reflow_from < 0 || lowest_dup_idx < reflow_from )); then
      reflow_from=$lowest_dup_idx
    fi
  fi
  (( user_quit )) && reflow_from=-1
  STACK_RENAME_PAIRS=("${doctor_rename_pairs[@]+"${doctor_rename_pairs[@]}"}")
  _doctor_finish "$prefix" "$reflow_from" "${branches[@]}"

  log ""
  if (( user_quit )); then
    log "${C_YELLOW}doctor${C_RESET}  stopped at user request; ${applied_squash} squash(es) applied"
  else
    log "${C_GREEN}doctor${C_RESET}  done"
  fi
}

cmd_restack() {
  parse_common_flags "$@"
  require_in_repo
  require_clean_tree
  require_no_op_in_progress

  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")
  local branches=()
  _load_stack_branches "$prefix" branches
  (( ${#branches[@]} >= 1 )) || die "stack '$prefix' has no branches"

  local starting_branch
  starting_branch=$(require_branch)

  local onto_sha=""
  if [[ -n "$OPT_ONTO" ]]; then
    onto_sha=$(git rev-parse --verify --quiet "${OPT_ONTO}^{commit}") \
      || die "--onto: cannot resolve '$OPT_ONTO' to a commit"
  fi

  local from_idx
  if [[ -n "$OPT_FROM" ]]; then
    from_idx=$(branch_index "$OPT_FROM" "${branches[@]}") \
      || die "--from '$OPT_FROM' not in stack"
  elif [[ -n "$onto_sha" ]]; then
    from_idx=0
  else
    local cur_idx
    cur_idx=$(branch_index "$starting_branch" "${branches[@]}") \
      || die "current branch '$starting_branch' not in stack '$prefix'"
    from_idx=$((cur_idx + 1))
  fi
  if [[ -z "$onto_sha" ]]; then
    (( from_idx > 0 )) || die "--from must have a predecessor in the stack (or pass --onto)"
  fi
  if (( from_idx >= ${#branches[@]} )); then
    log "nothing to do (no branches above $starting_branch)"
    return 0
  fi

  STACK_BRANCHES=("${branches[@]}")
  STACK_ORIG_SHAS=()
  local first_capture
  if [[ -n "$onto_sha" ]]; then
    first_capture=$from_idx
  else
    first_capture=$((from_idx - 1))
  fi
  local i
  for ((i = 0; i < ${#STACK_BRANCHES[@]}; i++)); do
    if (( i >= first_capture )); then
      STACK_ORIG_SHAS+=("$(git rev-parse "refs/heads/${STACK_BRANCHES[$i]}")")
    else
      STACK_ORIG_SHAS+=("")
    fi
  done

  STACK_STARTED_AT=$(date +%s)
  STACK_STARTING_BRANCH="$starting_branch"
  STACK_PREFIX="$prefix"
  STACK_PUSH="$OPT_PUSH"
  STACK_FORCE="$OPT_FORCE"
  STACK_SAFE_DROP=("${REFLOW_SAFE_DROP[@]+"${REFLOW_SAFE_DROP[@]}"}")
  REFLOW_SAFE_DROP=()
  STACK_ONTO="$onto_sha"
  STACK_ONTO_REF="$OPT_ONTO"
  STACK_FROM_IDX="$from_idx"
  STACK_PUSH_FAILURES=()
  # Plan: a single reflow-pick phase over branches [from_idx .. last].
  STACK_PHASES=(reflow-pick)
  STACK_PHASE_IDX=0
  STACK_UNIT_IDX=0

  # Focus: an explicit re-root (onto:) or a partial reflow (from:); a plain
  # whole-stack restack leaves it unset and renders as an em dash. Suppressed
  # when invoked from amend/clean, so this only surfaces for direct `restack`.
  if [[ -n "$OPT_ONTO" ]]; then
    _SNAPSHOT_FOCUS="onto=${OPT_ONTO##*/}"
  elif [[ -n "$OPT_FROM" ]]; then
    _SNAPSHOT_FOCUS="from=${OPT_FROM##*/}"
  fi
  snapshot_stack restack "$STACK_PREFIX" "${STACK_BRANCHES[@]}"
  save_engine_state
  _engine_run
}

cmd_continue() {
  require_in_repo
  load_state
  _engine_run resume
}

cmd_abort() {
  require_in_repo
  load_state
  _engine_abort
}

cmd_amend() {
  OPT_PREFIX=""
  local commit_args=()
  local push=0
  local force=0
  local has_msg=0
  local pathspec=()
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      -m)        shift; [[ $# -gt 0 ]] || die "-m needs an argument"
                 commit_args+=("-m" "$1"); has_msg=1; shift ;;
      --no-edit) commit_args+=("--no-edit"); has_msg=1; shift ;;
      --push)    push=1; shift ;;
      --force)   force=1; shift ;;
      --) shift; pathspec=("$@"); break ;;
      -*) die "unknown amend flag: $1 (use '--' before pathspecs)" ;;
      *)  pathspec+=("$1"); shift ;;
    esac
  done
  (( has_msg )) || commit_args+=("--no-edit")

  require_in_repo

  # Pre-flight: if no pathspec was given and the index is empty, the amend
  # would either be a no-op or message-only. Any unstaged working-tree changes
  # would then trip require_clean_tree in the restack that follows — and we'd
  # have already fired pre-commit hooks for nothing. Bail early.
  if (( ${#pathspec[@]} == 0 )) && git diff --cached --quiet --no-ext-diff; then
    if [[ -n $(git status --porcelain --untracked-files=no) ]]; then
      die "nothing staged to amend; stage with 'git add' or pass paths as args"
    fi
  fi

  # Snapshot the stack BEFORE git commit --amend rewrites the current branch
  # tip. This up-front snapshot is the sole restore point; the nested cmd_restack
  # below would take a redundant post-amend one, so it is suppressed (ADR 0010),
  # matching clean's covering-snapshot pattern.
  local _amend_snapped=0
  local _amend_prefix=""
  _amend_prefix=$(detect_prefix "" 2>/dev/null) || _amend_prefix=""
  if [[ -n "$_amend_prefix" ]]; then
    local _amend_branches=()
    _load_stack_branches "$_amend_prefix" _amend_branches
    if (( ${#_amend_branches[@]} > 0 )); then
      local _amend_cur
      _amend_cur=$(current_branch 2>/dev/null || echo "")
      [[ -n "$_amend_cur" ]] && _SNAPSHOT_FOCUS="leaf=${_amend_cur##*/}"
      snapshot_stack amend "$_amend_prefix" "${_amend_branches[@]}"
      _amend_snapped=1
    fi
  fi

  if (( ${#pathspec[@]} > 0 )); then
    git add -- "${pathspec[@]}"
  fi
  git commit --amend "${commit_args[@]}"

  local args=()
  (( push )) && args+=("--push")
  (( force )) && args+=("--force")
  # Suppress cmd_restack's redundant snapshot — but only when our own up-front
  # snapshot fired, else the restack snapshot is the only restore point.
  if (( _amend_snapped )); then
    _SNAPSHOT_SUPPRESS=1
    cmd_restack ${args[@]+"${args[@]}"}
    _SNAPSHOT_SUPPRESS=0
  else
    cmd_restack ${args[@]+"${args[@]}"}
  fi
}

# Push the whole stack to the remote — additive only: force-with-lease on every
# branch, no deletes, no PR work, no per-branch selection. Remote cleanup is
# `clean`'s job; PR chains are `pr sync`'s. Replaces `push`/`push --all`.
cmd_sync() {
  OPT_PREFIX=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      -*) die "unknown sync flag: $1" ;;
      *)  die "sync: unexpected arg '$1'" ;;
    esac
  done

  require_in_repo
  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")
  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches"

  STACK_PUSH_FAILURES=()
  local i
  for ((i = 0; i < ${#branches[@]}; i++)); do
    push_branch "${branches[$i]}" || true
  done
  if (( ${#STACK_PUSH_FAILURES[@]} > 0 )); then
    local b_str="" b
    for b in "${STACK_PUSH_FAILURES[@]}"; do b_str="${b_str:+$b_str }$b"; done
    warn "failed: $b_str"
    return 3
  fi
}

# Sub-dispatcher for `git stack pr <verb>`. Verbs: sync (default), list, desync.
cmd_pr() {
  local sub="${1-}"
  if [[ -z "$sub" || "$sub" == -* ]]; then
    # No subverb given (or only flags) — default to sync.
    cmd_pr_sync "$@"
    return
  fi
  shift
  case "$sub" in
    sync)   cmd_pr_sync "$@" ;;
    list)   cmd_pr_list "$@" ;;
    desync) cmd_pr_desync "$@" ;;
    *) die "unknown pr subcommand: $sub (try 'sync', 'list', or 'desync')" ;;
  esac
}

# Open/update the stack's GitHub PR chain. Three passes:
#   0. push any branches whose remote-tracking ref is missing or stale
#   0.5 filter out branches with no commits ahead of their in-stack parent
#   1. for each remaining (ACTIVE) branch, find existing open PR or create
#      a new draft PR with title "[N/M] <leaf>"
#   2. rewrite each PR's title prefix and stack-nav footer so the chain
#      reflects the current local stack
cmd_pr_sync() {
  OPT_PREFIX=""
  local opt_ready=0 opt_dry_run=0 opt_no_template=0
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --ready)       opt_ready=1; shift ;;
      --dry-run)     opt_dry_run=1; shift ;;
      --no-template) opt_no_template=1; shift ;;
      -*) die "unknown pr sync flag: $1" ;;
      *)  die "pr sync: unexpected arg '$1'" ;;
    esac
  done

  require_in_repo
  _gh_preflight

  # Fresh per-run merged-state cache (this proc may run pr sync more than once,
  # e.g. after a move/fold rename).
  _GH_MERGED_CACHE=""

  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")

  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under $prefix"
  local M=${#branches[@]}

  local base0
  base0=$(_resolve_parent_name) \
    || die "could not resolve stack base branch (set git config stack.base)"

  # --- pass 0: push ---
  local b
  local fatal_unpushed=()
  STACK_PUSH_FAILURES=()
  for b in "${branches[@]}"; do
    if _pr_needs_push "$b"; then
      if (( OPT_NO_PUSH )); then
        fatal_unpushed+=("$b")
      elif (( opt_dry_run )); then
        log "${C_BLUE}push${C_RESET}    ${C_CYAN}$b${C_RESET} ${C_DIM}(dry-run)${C_RESET}"
      else
        push_branch "$b" || true
      fi
    fi
  done
  if (( ${#fatal_unpushed[@]} > 0 )); then
    local s=""
    for b in "${fatal_unpushed[@]}"; do s="${s:+$s }$b"; done
    die "--no-push set, but these branches are not synced on origin: $s"
  fi
  if (( ${#STACK_PUSH_FAILURES[@]} > 0 )); then
    local s=""
    for b in "${STACK_PUSH_FAILURES[@]}"; do s="${s:+$s }$b"; done
    warn "push failed for: $s"
    return 3
  fi

  # --- pass 0.5: filter empty-diff branches ---
  local ACTIVE=()
  _pr_active_branches "$base0" ACTIVE "${branches[@]}"
  # Log a skip line for each empty-diff branch (re-checking the condition is
  # cheap and keeps the active-branch filter pure / log-free for `pr list`).
  local i parent_in_stack
  for ((i = 0; i < M; i++)); do
    if (( i == 0 )); then
      parent_in_stack="$base0"
    else
      parent_in_stack="${branches[i-1]}"
    fi
    if _pr_is_empty_diff "${branches[i]}" "$parent_in_stack"; then
      log "${C_DIM}skip${C_RESET}    ${C_CYAN}${branches[i]}${C_RESET} ${C_DIM}(no commits ahead of $parent_in_stack)${C_RESET}"
    fi
  done
  local N=${#ACTIVE[@]}
  (( N > 0 )) || die "nothing to do — every stack branch is empty"

  # --- pass 1: query existing or create new (bottom-up) ---
  # Parallel arrays indexed 0..N-1. PR_BASES holds each PR's current base on
  # GitHub — for newly-created PRs that's the parent we just passed, for
  # existing ones it's whatever GH reports (which Pass 2 will re-align if it
  # drifted from the stack).
  local PR_NUMS=() PR_TITLES=() PR_BODIES=() PR_BASES=()
  local template_body=""
  if (( ! opt_no_template )); then
    template_body=$(_pr_template_body)
  fi
  local PR_FAILURES=()
  local j parent leaf found
  # One bulk query indexes every open PR; per-branch lookups are then local.
  # If the bulk load fails, fall back to a live per-branch query.
  _gh_load_open_index
  for ((j = 0; j < N; j++)); do
    b="${ACTIVE[j]}"
    if (( j == 0 )); then
      parent="$base0"
    else
      parent="${ACTIVE[j-1]}"
    fi
    if (( _GH_OPEN_INDEX_OK )); then
      found=$(_gh_open_index_find "$b") || found=""
    else
      found=$(_gh_pr_find "$b")
    fi
    if [[ -n "$found" ]]; then
      local cur_num cur_title cur_base cur_body rest
      cur_num="${found%%$'\x1f'*}"
      rest="${found#*$'\x1f'}"
      cur_title="${rest%%$'\x1f'*}"
      rest="${rest#*$'\x1f'}"
      cur_base="${rest%%$'\x1f'*}"
      cur_body="${rest#*$'\x1f'}"
      PR_NUMS+=("$cur_num")
      PR_TITLES+=("$cur_title")
      PR_BASES+=("$cur_base")
      PR_BODIES+=("$cur_body")
      log "${C_DIM}exists${C_RESET}  $(_pr_link "$cur_num") ${C_CYAN}$b${C_RESET}"
    else
      leaf=$(_pr_branch_title "$b")
      local fresh_title
      fresh_title=$(_pr_title_with_pos "$((j+1))" "$N" "$leaf")
      if (( opt_dry_run )); then
        log "${C_GREEN}create${C_RESET}  ${C_CYAN}$b${C_RESET} ${C_DIM}-> ${parent}  title='${fresh_title}'  body=${#template_body}B${C_RESET}"
        PR_NUMS+=("DRY")
        PR_TITLES+=("$fresh_title")
        PR_BASES+=("$parent")
        PR_BODIES+=("$template_body")
        continue
      fi
      local draft=1
      (( opt_ready )) && draft=0
      local new_num
      if new_num=$(_gh_pr_create "$b" "$parent" "$fresh_title" "$draft" "$template_body"); then
        PR_NUMS+=("$new_num")
        PR_TITLES+=("$fresh_title")
        PR_BASES+=("$parent")
        PR_BODIES+=("$template_body")
        log "${C_GREEN}create${C_RESET}  $(_pr_link "$new_num") ${C_CYAN}$b${C_RESET} ${C_DIM}-> ${parent}${C_RESET}"
      else
        warn "pr create failed for $b"
        PR_FAILURES+=("$b")
        PR_NUMS+=("?")
        PR_TITLES+=("$fresh_title")
        PR_BASES+=("$parent")
        PR_BODIES+=("$template_body")
      fi
    fi
  done

  # --- reconcile: pure desired-state computation -> edit plan ---
  # Map the gathered chain-state (PR_* arrays) to a per-PR edit plan held in the
  # PLAN_* arrays. The only gh touch is the isolated merged-predecessor gather
  # (_pr_gather_merged_preds); every presentation rule — [N/M] prefix,
  # strikethrough on position change, nav-footer weave, round-trip-tolerant
  # change detection — runs through the pure _pr_* helpers. `apply` (below)
  # owns all the writes, so `--dry-run` is just "reconcile, then skip apply".
  local PLAN_ACTION=() PLAN_NUM=() PLAN_BRANCH=()
  local PLAN_TITLE_CHANGED=() PLAN_BODY_CHANGED=() PLAN_BASE_CHANGED=()
  local PLAN_DESIRED_TITLE=() PLAN_DESIRED_BODY=() PLAN_CUR_BASE=() PLAN_PARENT=()
  local k
  # Each active branch's last commit subject — the single source for both the PR
  # title content and its nav-footer entry. (Active branches always have a commit
  # ahead of their parent, so this is non-empty.)
  local LEAF_SUBJ=()
  for ((k = 0; k < N; k++)); do
    LEAF_SUBJ+=("$(_pr_branch_title "${ACTIVE[k]}")")
  done
  # Active chain as flat (branch, num, title) triples — the same for every PR's
  # weave, so build it once. The content follows the commit subject (same as the
  # PR title), but each entry keeps its CURRENT [N/M] bracket so the weave can
  # still detect a position move and strike the old position through.
  local active_flat=()
  for ((k = 0; k < N; k++)); do
    local k_bracket=""
    if [[ "${PR_TITLES[k]}" =~ ^(\[[0-9]+/[0-9]+\])[[:space:]] ]]; then
      k_bracket="${BASH_REMATCH[1]} "
    fi
    active_flat+=("${ACTIVE[k]}" "${PR_NUMS[k]}" "${k_bracket}${LEAF_SUBJ[k]}")
  done
  # --- pre-resolve merged predecessors (batched, deduped) ---
  # The per-PR gather below runs in a process-substitution subshell, which can't
  # persist _GH_MERGED_CACHE back to this shell. So resolve every predecessor
  # that needs a live check ONCE here, in this shell — populating the cache the
  # subshells inherit — so a predecessor shared by several PRs is queried a
  # single time. Footer-known merges are skipped (the gather reads those
  # straight from the PR's own footer, no query at all).
  local pre_active_csv=""
  for ((k = 0; k < N; k++)); do pre_active_csv="${pre_active_csv:+$pre_active_csv,}${PR_NUMS[k]}"; done
  local pre_need="" pre_j pre_body pre_num pre_old pre_cand pre_q
  for ((pre_j = 0; pre_j < N; pre_j++)); do
    pre_num="${PR_NUMS[pre_j]}"
    [[ "$pre_num" == "?" ]] && continue
    pre_body="${PR_BODIES[pre_j]}"
    pre_old=$(printf '%s' "$pre_body" | _pr_extract_nav_pr_nums)
    while IFS= read -r pre_cand; do
      [[ -z "$pre_cand" ]] && continue
      _pr_footer_merged_title "$pre_cand" "$pre_body" >/dev/null && continue
      case " $pre_need " in *" $pre_cand "*) continue ;; esac
      pre_need="${pre_need:+$pre_need }$pre_cand"
    done < <(_merged_predecessor_candidates "$pre_num" "$pre_active_csv" $pre_old)
  done
  for pre_q in $pre_need; do
    _gh_merged_resolve "$pre_q" >/dev/null || true
  done
  for ((j = 0; j < N; j++)); do
    b="${ACTIVE[j]}"
    local num="${PR_NUMS[j]}"
    PLAN_NUM+=("$num")
    PLAN_BRANCH+=("$b")
    if [[ "$num" == "?" ]]; then          # creation failed; nothing to apply
      PLAN_ACTION+=("skip")
      PLAN_TITLE_CHANGED+=(0); PLAN_BODY_CHANGED+=(0); PLAN_BASE_CHANGED+=(0)
      PLAN_DESIRED_TITLE+=(""); PLAN_DESIRED_BODY+=(""); PLAN_CUR_BASE+=(""); PLAN_PARENT+=("")
      continue
    fi
    if (( j == 0 )); then
      parent="$base0"
    else
      parent="${ACTIVE[j-1]}"
    fi
    local cur_title="${PR_TITLES[j]}"
    local cur_body="${PR_BODIES[j]}"
    local cur_base="${PR_BASES[j]}"
    leaf="${LEAF_SUBJ[j]}"
    local desired_title
    desired_title=$(_pr_title_with_pos "$((j+1))" "$N" "$leaf")
    local stripped
    stripped=$(printf '%s' "$cur_body" | _pr_strip_nav_footer)
    # The old footer's PR numbers drive both the merged-predecessor gather and
    # the strikethrough gate (a number is struck through only if it was in this
    # PR's prior footer). Keep them as a newline list (for the gather, which
    # splits) and a CSV (for the pure weave's exact-match membership test).
    local old_pr_nums old_csv=""
    old_pr_nums=$(printf '%s' "$cur_body" | _pr_extract_nav_pr_nums)
    local on
    while IFS= read -r on; do
      [[ -n "$on" ]] && old_csv="${old_csv:+$old_csv,}$on"
    done <<< "$old_pr_nums"
    local active_csv=""
    for ((k = 0; k < N; k++)); do active_csv="${active_csv:+$active_csv,}${PR_NUMS[k]}"; done
    # Gather merged predecessors (effectful), then weave the footer triples (pure).
    local merged_flat=()
    local mn mt
    while IFS=$'\t' read -r mn mt; do
      [[ -z "$mn" ]] && continue
      merged_flat+=("$mn" "$mt")
    done < <(_pr_gather_merged_preds "$num" "$active_csv" "$cur_body" $old_pr_nums)
    local footer_args=("$b")
    local wline wb wn wt rest
    # Split each TAB triple by hand: a merged predecessor has an empty leading
    # (branch) field, and `IFS=$'\t' read` would strip it (TAB is IFS
    # whitespace), shifting the fields left. Parameter expansion preserves it.
    while IFS= read -r wline; do
      wb="${wline%%$'\t'*}"; rest="${wline#*$'\t'}"
      wn="${rest%%$'\t'*}"; wt="${rest#*$'\t'}"
      footer_args+=("$wb" "$wn" "$wt")
    done < <(_pr_weave_footer_triples "$old_csv" "${merged_flat[@]+"${merged_flat[@]}"}" -- "${active_flat[@]}")
    local footer
    footer=$(_pr_render_nav_footer "$GH_REPO" "${footer_args[@]}")
    local desired_body
    if [[ -n "$stripped" ]]; then
      desired_body=$(printf '%s\n\n%s' "$stripped" "$footer")
    else
      desired_body="$footer"
    fi
    # Compare normalized bodies so a GitHub round-trip (CRLF / trailing newline)
    # doesn't look like a body change. The desired body we write stays canonical
    # — normalization is comparison-only.
    local title_changed=0 body_changed=0 base_changed=0
    [[ "$desired_title" != "$cur_title" ]] && title_changed=1
    local norm_desired norm_cur
    norm_desired=$(printf '%s' "$desired_body" | _pr_body_normalize)
    norm_cur=$(printf '%s' "$cur_body" | _pr_body_normalize)
    [[ "$norm_desired" != "$norm_cur" ]] && body_changed=1
    [[ "$parent" != "$cur_base" ]] && base_changed=1
    PLAN_TITLE_CHANGED+=("$title_changed")
    PLAN_BODY_CHANGED+=("$body_changed")
    PLAN_BASE_CHANGED+=("$base_changed")
    PLAN_DESIRED_TITLE+=("$desired_title")
    PLAN_DESIRED_BODY+=("$desired_body")
    PLAN_CUR_BASE+=("$cur_base")
    PLAN_PARENT+=("$parent")
    if (( ! title_changed && ! body_changed && ! base_changed )); then
      PLAN_ACTION+=("none")
    else
      PLAN_ACTION+=("edit")
    fi
  done

  # --- apply: execute the edit plan (all gh writes live here) ---
  for ((j = 0; j < N; j++)); do
    local action="${PLAN_ACTION[j]}"
    local num="${PLAN_NUM[j]}"
    b="${PLAN_BRANCH[j]}"
    [[ "$action" == "skip" ]] && continue
    if [[ "$action" == "none" ]]; then
      log_v "${C_DIM}ok${C_RESET}      $(_pr_link "$num") ${C_CYAN}$b${C_RESET}"
      continue
    fi
    local title_changed="${PLAN_TITLE_CHANGED[j]}" body_changed="${PLAN_BODY_CHANGED[j]}" base_changed="${PLAN_BASE_CHANGED[j]}"
    if (( opt_dry_run )); then
      local tc bc bsc
      (( title_changed )) && tc=yes || tc=no
      (( body_changed )) && bc=yes || bc=no
      (( base_changed )) && bsc=yes || bsc=no
      log "${C_BLUE}update${C_RESET}  $(_pr_link "$num") ${C_CYAN}$b${C_RESET} ${C_DIM}(title=$tc body=$bc base=$bsc)${C_RESET}"
      continue
    fi
    local pass_title="" pass_body="" pass_base=""
    (( title_changed )) && pass_title="${PLAN_DESIRED_TITLE[j]}"
    (( body_changed ))  && pass_body="${PLAN_DESIRED_BODY[j]}"
    (( base_changed ))  && pass_base="${PLAN_PARENT[j]}"
    if _gh_pr_edit "$num" "$pass_title" "$pass_body" "$pass_base"; then
      if (( base_changed )); then
        log "${C_BLUE}update${C_RESET}  $(_pr_link "$num") ${C_CYAN}$b${C_RESET} ${C_DIM}(base: ${PLAN_CUR_BASE[j]} -> ${PLAN_PARENT[j]})${C_RESET}"
      else
        log "${C_BLUE}update${C_RESET}  $(_pr_link "$num") ${C_CYAN}$b${C_RESET}"
      fi
    else
      warn "pr edit failed for $b (#${num})"
      PR_FAILURES+=("$b")
    fi
  done

  if (( ${#PR_FAILURES[@]} > 0 )); then
    local s=""
    for b in "${PR_FAILURES[@]}"; do s="${s:+$s }$b"; done
    warn "PR sync failed for: $s"
    return 3
  fi
  log "${C_GREEN}done${C_RESET}    pr sync complete (${C_BOLD}${N}${C_RESET} branches)"
}

# Tear down the stack's PR chain so the branches can be reordered and re-synced
# cleanly — the inverse of `pr sync`. For each branch, close its open PR.
# Merged and already-closed PRs are left alone. OPEN PRs carrying human activity
# (a non-bot comment, an approval, or a changes-requested review) prompt per-PR
# on a TTY — skipped non-interactively unless --yes. With --delete-remote, also
# delete the remote branch of each PR closed, except one still serving as the
# base of a PR we kept open (deleting it would retarget that PR on GitHub).
# --dry-run previews without mutating.
cmd_pr_desync() {
  OPT_PREFIX=""
  local opt_delete_remote=0 opt_yes=0 opt_dry_run=0
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --delete-remote) opt_delete_remote=1; shift ;;
      --yes|-y)        opt_yes=1; shift ;;
      --dry-run)       opt_dry_run=1; shift ;;
      -*) die "unknown pr desync flag: $1" ;;
      *)  die "pr desync: unexpected arg '$1'" ;;
    esac
  done

  require_in_repo
  _gh_preflight

  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")

  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under $prefix"
  local M=${#branches[@]}

  # --- Phase 1: inspect + classify + (interactively) confirm. No mutations.
  # One plan entry per branch, index-aligned with branches[], so the Phase 2
  # base-branch guard can consult a branch's immediate successor by index.
  # OPEN_AFTER[i] tracks whether branch i's PR is still open (1) so a delete of
  # its base can be vetoed; it flips to 0 once we (would) close it.
  local PLAN_NUM=() PLAN_ACTION=() PLAN_NOTE=() OPEN_AFTER=()
  local data num title state is_draft base_ref review_dec comments approvers change_reqs req_reviewers checks merged_at merged_by commenters
  local i b
  for ((i = 0; i < M; i++)); do
    b="${branches[$i]}"
    data=$(_gh_pr_inspect "$b")
    if [[ -z "$data" ]]; then
      # No PR for this branch — the "(no PR)" id cell already says it, so no note.
      PLAN_NUM[i]=""; PLAN_ACTION[i]="skip"; PLAN_NOTE[i]=""; OPEN_AFTER[i]=0
      continue
    fi
    num="${data%%$'\x1f'*}";        data="${data#*$'\x1f'}"
    title="${data%%$'\x1f'*}";      data="${data#*$'\x1f'}"
    state="${data%%$'\x1f'*}";      data="${data#*$'\x1f'}"
    is_draft="${data%%$'\x1f'*}";   data="${data#*$'\x1f'}"
    base_ref="${data%%$'\x1f'*}";   data="${data#*$'\x1f'}"
    review_dec="${data%%$'\x1f'*}"; data="${data#*$'\x1f'}"
    comments="${data%%$'\x1f'*}";   data="${data#*$'\x1f'}"
    approvers="${data%%$'\x1f'*}";  data="${data#*$'\x1f'}"
    change_reqs="${data%%$'\x1f'*}";   data="${data#*$'\x1f'}"
    req_reviewers="${data%%$'\x1f'*}"; data="${data#*$'\x1f'}"
    checks="${data%%$'\x1f'*}";       data="${data#*$'\x1f'}"
    merged_at="${data%%$'\x1f'*}";    data="${data#*$'\x1f'}"
    merged_by="${data%%$'\x1f'*}";    commenters="${data#*$'\x1f'}"

    PLAN_NUM[i]="$num"

    case "$state" in
      MERGED)
        PLAN_ACTION[i]="skip"; OPEN_AFTER[i]=0
        if [[ -n "$merged_by" ]]; then
          PLAN_NOTE[i]="merged by ${merged_by}"
        else
          PLAN_NOTE[i]="merged"
        fi
        continue ;;
      CLOSED)
        PLAN_ACTION[i]="skip"; PLAN_NOTE[i]="already closed"; OPEN_AFTER[i]=0
        continue ;;
    esac

    # OPEN — classify human activity (non-bot comment / approval / changes).
    OPEN_AFTER[i]=1
    local human_comments=0 hc=""
    if [[ "$comments" =~ ^[0-9]+$ ]] && (( comments > 0 )); then
      hc=$(gh api "repos/${GH_REPO}/issues/${num}/comments?per_page=100" --paginate \
        --jq '[.[] | select(.user.type != "Bot")] | length' 2>/dev/null) || hc=""
      if [[ "$hc" =~ ^[0-9]+$ ]]; then human_comments="$hc"; else human_comments="$comments"; fi
    fi
    local act_notes=""
    if (( human_comments == 1 )); then
      act_notes="1 comment"
    elif (( human_comments > 1 )); then
      act_notes="${human_comments} comments"
    fi
    if [[ -n "$approvers" ]]; then
      act_notes="${act_notes:+$act_notes, }approved by ${approvers//,/, }"
    elif [[ "$review_dec" == "APPROVED" ]]; then
      act_notes="${act_notes:+$act_notes, }approved"
    fi
    if [[ -n "$change_reqs" ]]; then
      act_notes="${act_notes:+$act_notes, }changes by ${change_reqs//,/, }"
    elif [[ "$review_dec" == "CHANGES_REQUESTED" ]]; then
      act_notes="${act_notes:+$act_notes, }changes requested"
    fi
    # A review submitted as "Comment" (no approve / changes-requested) shows up
    # as a COMMENTED review, not in reviewDecision — surface its author too.
    if [[ -n "$commenters" ]]; then
      act_notes="${act_notes:+$act_notes, }commented by ${commenters//,/, }"
    fi

    if [[ -z "$act_notes" ]]; then
      PLAN_ACTION[i]="close"
      continue
    fi
    # Has activity — decide whether to close it.
    if (( opt_yes )); then
      PLAN_ACTION[i]="close"; PLAN_NOTE[i]="has activity: ${act_notes}"
    elif (( opt_dry_run )); then
      PLAN_ACTION[i]="skip"; PLAN_NOTE[i]="has activity: ${act_notes} (would prompt)"
    elif _confirm "$(_pr_link "$num") ${b} — ${act_notes}. close anyway?"; then
      PLAN_ACTION[i]="close"; PLAN_NOTE[i]="has activity: ${act_notes}"
    else
      PLAN_ACTION[i]="skip"; PLAN_NOTE[i]="kept — has activity: ${act_notes}"
    fi
  done

  # --- Phase 2: execute, leaf -> base. Close a branch's PR, then (with
  # --delete-remote) delete its remote — unless the branch still backs an open
  # PR (a kept-active successor, or one whose close failed), since deleting it
  # would retarget/disrupt that PR on GitHub.
  local DESYNC_FAILURES=()
  local closed=0 deleted=0 skipped=0
  for ((i = M - 1; i >= 0; i--)); do
    b="${branches[$i]}"
    num="${PLAN_NUM[i]-}"
    local action="${PLAN_ACTION[i]-}"
    local note="${PLAN_NOTE[i]-}"
    local note_sfx=""
    [[ -n "$note" ]] && note_sfx=" ${C_DIM}[${note}]${C_RESET}"

    if [[ "$action" == "skip" ]]; then
      local id_cell="(no PR)"
      [[ -n "$num" ]] && id_cell="$(_pr_link "$num")"
      log "${C_DIM}skip${C_RESET}    ${id_cell} ${C_CYAN}${b}${C_RESET}${note_sfx}"
      skipped=$((skipped + 1))
      continue
    fi

    # action == close
    if (( opt_dry_run )); then
      log "${C_YELLOW}close${C_RESET}   $(_pr_link "$num") ${C_CYAN}${b}${C_RESET} ${C_DIM}(dry-run)${C_RESET}${note_sfx}"
    elif _gh_pr_close "$num"; then
      log "${C_YELLOW}close${C_RESET}   $(_pr_link "$num") ${C_CYAN}${b}${C_RESET}${note_sfx}"
    else
      warn "could not close $(_pr_link "$num") (${b})"
      DESYNC_FAILURES+=("$b")
      continue   # leave its remote in place
    fi
    OPEN_AFTER[i]=0
    closed=$((closed + 1))

    # --delete-remote: drop the remote branch unless it still backs an open PR.
    if (( opt_delete_remote )); then
      if (( i + 1 < M )) && [[ "${OPEN_AFTER[i+1]-}" == "1" ]]; then
        warn "keeping remote ${b} — base of still-open $(_pr_link "${PLAN_NUM[i+1]-}")"
      elif (( opt_dry_run )); then
        log "${C_RED}delete${C_RESET}  remote ${C_CYAN}${b}${C_RESET} ${C_DIM}(dry-run)${C_RESET}"
        deleted=$((deleted + 1))
      elif git ls-remote --exit-code --heads origin "$b" >/dev/null 2>&1; then
        if git push --quiet origin --delete "$b" 2>/dev/null; then
          log "${C_RED}delete${C_RESET}  remote ${C_CYAN}${b}${C_RESET}"
          deleted=$((deleted + 1))
        else
          warn "could not delete remote branch '${b}'"
          DESYNC_FAILURES+=("$b")
        fi
      fi
    fi
  done

  log "${C_BOLD}desynced:${C_RESET} ${closed} closed, ${deleted} remote deleted, ${skipped} skipped"
  if (( ${#DESYNC_FAILURES[@]} > 0 )); then
    local s="" x
    for x in "${DESYNC_FAILURES[@]}"; do s="${s:+$s }$x"; done
    warn "failed: $s"
    return 3
  fi
}

# List the stack's PRs one per line. Mirrors `git stack view`'s look: parent
# header, per-branch row, fetches by default. Adds PR-specific badges:
# state, draft, base-mismatch, review decision, plus a comment count.
cmd_pr_list() {
  OPT_PREFIX=""
  local opt_fetch=1
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      --no-fetch) opt_fetch=0; shift ;;
      -*) die "unknown pr list flag: $1" ;;
      *)  die "pr list: unexpected arg '$1'" ;;
    esac
  done

  require_in_repo
  _gh_preflight

  local prefix rc=0
  prefix=$(_try_detect_prefix "$OPT_PREFIX") || rc=$?
  case "$rc" in
    0) ;;
    1) die "detached HEAD; checkout a branch first or pass --prefix" ;;
    2)
      local prefixes=()
      while IFS= read -r p; do [[ -n "$p" ]] && prefixes+=("$p"); done < <(stack_prefixes)
      (( ${#prefixes[@]} > 0 )) || die "no stacks found; create a branch with a numeric leaf (e.g. feat/01-start)"
      if (( ${#prefixes[@]} == 1 )); then
        prefix="${prefixes[0]}"
        log "${C_DIM}stack: ${C_RESET}${C_BOLD}${prefix%/}${C_RESET}"
      else
        prefix=$(_pick_one "stack" "${prefixes[@]}") || die "no stack selected"
      fi
      ;;
  esac
  local current
  current=$(current_branch || echo "")
  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches found for prefix '$prefix'"

  local base0
  base0=$(_resolve_parent_name) \
    || die "could not resolve stack base branch (set git config stack.base)"

  if (( opt_fetch )); then
    log "${C_DIM}fetching all remotes...${C_RESET}"
    git fetch --all --prune >/dev/null 2>&1 || warn "git fetch failed; counts may be stale"
  fi

  # Parent header (matches cmd_view).
  local parent_ref parent_state
  if parent_ref=$(_resolve_parent_ref "$base0"); then
    parent_state=$(_parent_state "${branches[0]}" "$parent_ref")
    printf '%sparent:%s %s%s%s  %s\n\n' \
      "$C_BOLD" "$C_RESET" "$C_CYAN" "$parent_ref" "$C_RESET" "$parent_state"
  fi

  # Compute active branches for base-mismatch checks.
  local ACTIVE=()
  _pr_active_branches "$base0" ACTIVE "${branches[@]}"

  # Branch column width for alignment across rows. Keeps the header line
  # (branch + #PR + flags) in column parity so statuses are easy to compare.
  local b max_w=0
  for b in "${branches[@]}"; do
    (( ${#b} > max_w )) && max_w=${#b}
  done

  local data num title state is_draft base_ref review_dec comments approvers change_reqs req_reviewers checks merged_at merged_by commenters
  local marker branch_color flags expected_base pr_cell
  for b in "${branches[@]}"; do
    if [[ "$b" == "$current" ]]; then
      marker="${C_GREEN}${C_BOLD}*${C_RESET}"
      branch_color="${C_BOLD}${C_CYAN}"
    else
      marker=" "
      branch_color="${C_CYAN}"
    fi

    data=$(_gh_pr_inspect "$b")
    if [[ -z "$data" ]]; then
      printf '%s %s%-*s%s  %s(no PR)%s\n\n' \
        "$marker" "$branch_color" "$max_w" "$b" "$C_RESET" \
        "$C_DIM" "$C_RESET"
      continue
    fi

    num="${data%%$'\x1f'*}";        data="${data#*$'\x1f'}"
    title="${data%%$'\x1f'*}";      data="${data#*$'\x1f'}"
    state="${data%%$'\x1f'*}";      data="${data#*$'\x1f'}"
    is_draft="${data%%$'\x1f'*}";   data="${data#*$'\x1f'}"
    base_ref="${data%%$'\x1f'*}";   data="${data#*$'\x1f'}"
    review_dec="${data%%$'\x1f'*}"; data="${data#*$'\x1f'}"
    comments="${data%%$'\x1f'*}";   data="${data#*$'\x1f'}"
    approvers="${data%%$'\x1f'*}";  data="${data#*$'\x1f'}"
    change_reqs="${data%%$'\x1f'*}";   data="${data#*$'\x1f'}"
    req_reviewers="${data%%$'\x1f'*}"; data="${data#*$'\x1f'}"
    checks="${data%%$'\x1f'*}";       data="${data#*$'\x1f'}"
    merged_at="${data%%$'\x1f'*}";    data="${data#*$'\x1f'}"
    merged_by="${data%%$'\x1f'*}";    commenters="${data#*$'\x1f'}"

    # Strip the [N/M] prefix from the displayed title — the row order already
    # conveys position, so showing the prefix here is just visual noise.
    if [[ "$title" =~ ^\[[0-9]+/[0-9]+\][[:space:]](.*)$ ]]; then
      title="${BASH_REMATCH[1]}"
    fi

    pr_cell=$(_pr_link "$num")

    # Build flag list.
    flags=""
    case "$state" in
      CLOSED) flags+="${C_RED}${C_DIM}[closed]${C_RESET} " ;;
      MERGED)
        local merged_label="merged"
        if [[ -n "$merged_by" ]]; then
          merged_label+=" by ${merged_by}"
        fi
        if [[ -n "$merged_at" ]]; then
          local rel_time
          rel_time=$(_relative_time "$merged_at")
          [[ -n "$rel_time" ]] && merged_label+=", ${rel_time}"
        fi
        flags+="${C_MAGENTA}${C_DIM}[${merged_label}]${C_RESET} "
        ;;
    esac
    flags+="$(_upstream_status "$b") "
    if [[ "$is_draft" == "1" ]]; then
      flags+="${C_YELLOW}[draft]${C_RESET} "
    fi

    # Base-mismatch check: only for active open PRs (merged/closed PRs may
    # have a different base than the current stack target — that's expected).
    local in_active=0 a
    for a in "${ACTIVE[@]}"; do
      [[ "$a" == "$b" ]] && { in_active=1; break; }
    done
    if (( in_active )) && [[ "$state" == "OPEN" ]]; then
      # Find expected base: previous *active* branch, or base0 for the bottom.
      local idx_in_active=-1 k
      for ((k = 0; k < ${#ACTIVE[@]}; k++)); do
        [[ "${ACTIVE[k]}" == "$b" ]] && { idx_in_active=$k; break; }
      done
      if (( idx_in_active == 0 )); then
        expected_base="$base0"
      else
        expected_base="${ACTIVE[idx_in_active-1]}"
      fi
      if [[ "$base_ref" != "$expected_base" ]]; then
        flags+="${C_YELLOW}[base: ${base_ref}]${C_RESET} "
      fi
    fi

    # Render reviewer flags based on who has actually reviewed, not on the
    # overall reviewDecision — GitHub may report REVIEW_REQUIRED (e.g., when
    # CODEOWNERS still wants more sign-off) even after someone has approved,
    # but we still want to surface the approver. Both flags can coexist when
    # different reviewers are in different states.
    if [[ -n "$approvers" ]]; then
      flags+="${C_GREEN}[approved: ${approvers//,/, }]${C_RESET} "
    elif [[ "$review_dec" == "APPROVED" ]]; then
      flags+="${C_GREEN}[approved]${C_RESET} "
    fi
    if [[ -n "$change_reqs" ]]; then
      flags+="${C_RED}[changes: ${change_reqs//,/, }]${C_RESET} "
    elif [[ "$review_dec" == "CHANGES_REQUESTED" ]]; then
      flags+="${C_RED}[changes]${C_RESET} "
    fi

    # Merge blocker: required reviewers (e.g., CODEOWNERS) still need to sign
    # off. Only relevant for open PRs.
    if [[ "$state" == "OPEN" && "$review_dec" == "REVIEW_REQUIRED" ]]; then
      if [[ -n "$req_reviewers" ]]; then
        flags+="${C_YELLOW}[review required: ${req_reviewers//,/, }]${C_RESET} "
      else
        flags+="${C_YELLOW}[review required]${C_RESET} "
      fi
    fi

    # CI / status checks rollup. Only relevant for open PRs — merged/closed
    # PRs may still report a status but it isn't actionable. Counts come
    # from jq as "pass,fail,pending"; segments with zero are suppressed.
    if [[ "$state" == "OPEN" && -n "$checks" ]]; then
      local c_pass c_fail c_pending
      IFS=, read -r c_pass c_fail c_pending <<< "$checks"
      if (( c_pass + c_fail + c_pending > 0 )); then
        local check_parts=""
        if (( c_fail > 0 )); then
          check_parts+="${C_RED}${c_fail} fail${C_RESET}"
        fi
        if (( c_pending > 0 )); then
          [[ -n "$check_parts" ]] && check_parts+=", "
          check_parts+="${C_YELLOW}${c_pending} pending${C_RESET}"
        fi
        if (( c_pass > 0 )); then
          [[ -n "$check_parts" ]] && check_parts+=", "
          check_parts+="${C_GREEN}${c_pass} pass${C_RESET}"
        fi
        flags+="[checks: ${check_parts}] "
      fi
    fi

    # Trim trailing space on flags.
    flags="${flags% }"

    # Comment count: filter out bot-authored comments. gh pr list's `comments`
    # field counts everything (CI status comments, Atlantis plan outputs, etc.)
    # but doesn't expose user.type, so we re-query via REST when there's at
    # least one comment to filter. per_page=100 + --paginate keeps it to one
    # request for typical PRs.
    local cnt_suffix=""
    if [[ "$comments" =~ ^[0-9]+$ ]] && (( comments > 0 )); then
      local human_count
      human_count=$(gh api "repos/${GH_REPO}/issues/${num}/comments?per_page=100" --paginate \
        --jq '[.[] | select(.user.type != "Bot")] | length' \
        2>/dev/null) || true
      if [[ "$human_count" =~ ^[0-9]+$ ]]; then
        comments="$human_count"
      fi
      if (( comments > 0 )); then
        cnt_suffix="  ${C_DIM}(${comments}c)${C_RESET}"
      fi
    fi

    # Three-line block per branch + trailing blank line for breathing room:
    #   line 1: branch + #PR + comment count (identifier line)
    #   line 2: flag list, indented (status line)
    #   line 3: PR title, dim+indented (content line — settles into background
    #           so the colored status flags above pop)
    # Branch padded to max_w so #PR / comment columns line up across rows.
    printf '%s %s%-*s%s  %s%s\n    %s\n    %s%s%s\n\n' \
      "$marker" "$branch_color" "$max_w" "$b" "$C_RESET" \
      "$pr_cell" "$cnt_suffix" "$flags" \
      "$C_DIM" "$title" "$C_RESET"
  done
}

# Interactive selector. $1 = prompt header, remaining args = options. Prefers
# fzf; falls back to a numbered-list prompt read from /dev/tty. Prints the
# chosen option to stdout, returns non-zero if the user aborts.
_pick_one() {
  local header="$1"; shift
  (( $# > 0 )) || return 1
  if command -v fzf >/dev/null 2>&1; then
    printf '%s\n' "$@" \
      | fzf --prompt="${header} > " --height=40% --reverse --no-multi
    return
  fi
  [[ -e /dev/tty ]] || return 1
  local i=1 opt
  printf '%s\n' "$header" >&2
  for opt in "$@"; do
    printf '  %2d) %s\n' "$i" "$opt" >&2
    i=$((i + 1))
  done
  printf 'pick [1-%d]: ' "$#" >&2
  local n
  read -r n < /dev/tty || return 1
  [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= $# )) || return 1
  printf '%s\n' "${!n}"
}

# Resolve the user's intent from fzf --print-query output (query on line 1, any
# accepted selection on line 2). For a numeric picker the query is
# authoritative: a non-empty query is the leaf the user typed, so we ignore the
# selection — otherwise fzf would fuzzy-match the typed digits to a curated
# candidate (typing "15" matches "152"/"105") and silently return the wrong
# leaf. An empty query means a pure arrow-key pick, so use the selection. Prints
# the resolved value (may be empty -> caller applies the default / re-prompts).
# Usage: _resolve_fzf_leaf <two-line-fzf-output>
_resolve_fzf_leaf() {
  local q="" s=""
  # A query-only fzf result (no-match free entry) has no second line, so the
  # second read hits EOF (rc 1); `|| :` keeps set -e from aborting the function.
  { IFS= read -r q || :; IFS= read -r s || :; } <<< "$1"
  if [[ -n "$q" ]]; then printf '%s\n' "$q"; else printf '%s\n' "$s"; fi
}

# Interactive leaf picker with free manual entry. Shows <candidate>... as
# selectable suggestions (fzf) or as hints (numbered fallback) and accepts any
# leaf valid for the open gap per _validate_leaf_entry. Re-prompts on invalid
# input; returns 1 on abort (Esc/Ctrl-C/EOF). <default> (may be empty) is
# returned on empty input — placement passes the midpoint, renumber passes none.
# <exclude> (may be empty) is rejected as a no-op. Prints the chosen integer.
# Usage: _pick_or_enter_leaf <prompt> <lo> <hi> <width> <default> <exclude> <candidate>...
_pick_or_enter_leaf() {
  local prompt="$1" lo="$2" hi="$3" width="$4" default="$5" exclude="$6"; shift 6
  local cands=("$@")
  local value out rc kind rest
  while :; do
    if command -v fzf >/dev/null 2>&1; then
      out=$(printf '%s\n' "${cands[@]}" \
        | fzf --print-query --prompt="${prompt} > " --height=40% --reverse --no-multi)
      rc=$?
      # 0 = match selected, 1 = no match (free-entry via the typed query);
      # >= 2 covers fzf errors and 130 (Esc/Ctrl-C) — treat as abort.
      (( rc >= 2 )) && return 1
      value=$(_resolve_fzf_leaf "$out")
    else
      [[ -e /dev/tty ]] || return 1
      printf '%s\n' "$prompt" >&2
      printf '  suggested: %s\n' "${cands[*]}" >&2
      if [[ -n "$default" ]]; then
        printf '  enter a leaf [default %s]: ' "$default" >&2
      else
        printf '  enter a leaf: ' >&2
      fi
      read -r value < /dev/tty || return 1
    fi
    [[ -z "$value" && -n "$default" ]] && value="$default"
    if [[ -z "$value" ]]; then
      printf '  please enter a leaf number\n' >&2
      continue
    fi
    if out=$(_validate_leaf_entry "$value" "$lo" "$hi" "$width" "$exclude"); then
      printf '%s\n' "$out"
      return 0
    fi
    kind="${out%%$'\t'*}"; rest="${out#*$'\t'}"
    case "$kind" in
      nan)     printf "  '%s' is not a number\n" "$value" >&2 ;;
      low)     printf '  leaf must be greater than %s\n' "$rest" >&2 ;;
      high)    printf '  leaf must be less than %s\n' "$rest" >&2 ;;
      ceiling) printf '  leaf exceeds the maximum (%s)\n' "$rest" >&2 ;;
      noop)    printf '  already at %s — pick a different leaf\n' "$rest" >&2 ;;
    esac
  done
}

# Interactive branch picker. $1 = prefix label (for the prompt only), $2 =
# current branch (empty if none/detached; used to position the initial cursor),
# remaining args = candidate branch names. Shows "<branch> \t <sha>  <subject>"
# so any field is filterable. Prints the chosen branch name; non-zero on abort.
_pick_branch() {
  local label="$1"; shift
  local current="$1"; shift
  (( $# > 0 )) || return 1
  local lines=() b sha subj
  local cur_idx=0 i=0
  for b in "$@"; do
    i=$((i + 1))
    [[ -n "$current" && "$b" == "$current" ]] && cur_idx=$i
    sha=$(git rev-parse --short "$b" 2>/dev/null || echo "???????")
    subj=$(git log -1 --format='%s' "$b" 2>/dev/null || echo "")
    lines+=("${b}"$'\t'"${sha}  ${subj}")
  done
  if command -v fzf >/dev/null 2>&1; then
    local picked
    local fzf_args=(
      --prompt="${label} branch > " --height=60% --reverse --no-multi
      --delimiter=$'\t' --with-nth=1,2 --nth=1,2
      --preview='git log -1 --color=always --format="%C(auto)%h%d %s%n%n%b" {1}'
      --preview-window=down:6:wrap
    )
    (( cur_idx > 0 )) && fzf_args+=(--bind="load:pos($cur_idx)")
    picked=$(printf '%s\n' "${lines[@]}" | fzf "${fzf_args[@]}") || return 1
    printf '%s\n' "${picked%%$'\t'*}"
    return
  fi
  [[ -e /dev/tty ]] || return 1
  i=1
  printf 'select branch (%s):\n' "$label" >&2
  for b in "$@"; do
    if (( i == cur_idx )); then
      printf '* %2d) %s%s%s\n' "$i" "$C_CYAN" "$b" "$C_RESET" >&2
    else
      printf '  %2d) %s%s%s\n' "$i" "$C_CYAN" "$b" "$C_RESET" >&2
    fi
    i=$((i + 1))
  done
  printf 'pick [1-%d]: ' "$#" >&2
  local n
  read -r n < /dev/tty || return 1
  [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= $# )) || return 1
  printf '%s\n' "${!n}"
}

cmd_checkout_interactive() {
  require_in_repo

  local prefix=""
  prefix=$(_try_detect_prefix "$OPT_PREFIX") || prefix=""

  # Outside a stack: share the all-stacks selector with `list`/`pick`, then
  # drop into the branch picker for a specific branch (vs `pick`'s tip hop).
  if [[ -z "$prefix" ]]; then
    prefix=$(_select_stack "select stack") || die "no stack branches found in this repo"
  fi

  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under '${prefix:-<top-level>}'"

  local current=""
  current=$(current_branch 2>/dev/null) || current=""

  local picked
  picked=$(_pick_branch "${prefix:-<top-level>}" "$current" "${branches[@]}") \
    || die "no branch selected"
  git checkout "$picked"
}

cmd_checkout() {
  OPT_PREFIX=""
  local input=""
  while (( $# > 0 )); do
    if _consume_common_flag "$@"; then
      shift "$_FLAG_SHIFT"
      continue
    fi
    case "$1" in
      -*) die "unknown checkout flag: $1" ;;
      *)  [[ -z "$input" ]] || die "checkout: extra arg '$1'"; input="$1"; shift ;;
    esac
  done

  if [[ -z "$input" ]]; then
    cmd_checkout_interactive
    return
  fi

  [[ "$input" =~ ^[0-9]+$ ]] || die "checkout: '$input' is not a number (e.g., 5, 06)"

  require_in_repo

  local prefix
  prefix=$(detect_prefix "$OPT_PREFIX")
  local branches=()
  _load_stack_branches "$prefix" branches "no stack branches under '$prefix'"

  local matches=() b leaf num
  for b in "${branches[@]}"; do
    leaf="${b##*/}"
    [[ "$leaf" =~ ^([0-9]+)- ]] || continue
    num="${BASH_REMATCH[1]}"
    if awk -v a="$input" -v c="$num" 'BEGIN { exit !(a+0 == c+0) }'; then
      matches+=("$b")
    fi
  done

  case "${#matches[@]}" in
    0) die "no stack branch with number '${input}' under '${prefix}' (try 'git stack view' ${C_DIM}[gstkv]${C_RESET})" ;;
    1) git checkout "${matches[0]}" ;;
    *) local m s=""; for m in "${matches[@]}"; do s="${s:+$s, }$m"; done
       die "ambiguous '${input}' matches: $s" ;;
  esac
}

# ---------- default-branch & shell init ----------

# Print the bare default branch name (no `origin/` prefix). Uses the same
# resolution order as the rest of the script (stack.base → init.defaultBranch →
# main → master), falling back to a bare "main" if nothing is found so that
# shell aliases like `gstkrom` always have something to feed `git fetch`.
cmd_default_branch() {
  require_in_repo
  local b
  if b=$(_resolve_parent_name); then
    printf '%s\n' "$b"
  else
    printf 'main\n'
  fi
}

# Hidden plumbing: emit dynamic shell-completion candidates as
# `candidate<TAB>description` lines on stdout, one per line. Consumed by the
# shell completion wiring. NON-NEGOTIABLE: this runs on every keystroke-tab, so
# it must NEVER die, prompt, or print errors — every degenerate case (no repo,
# detached HEAD, non-stack branch, empty repo, mid-reflow, unknown kind) exits 0
# with empty stdout. Guards the repo check itself and uses only the non-dying
# helpers (_try_detect_prefix, _load_stack_branches without its err arg).
cmd___complete() {
  # Silent repo gate — do NOT call the die-ing require_in_repo.
  git rev-parse --git-dir >/dev/null 2>&1 || exit 0
  local kind="${1-}"
  shift || true
  case "$kind" in
    verbs)    _complete_verbs ;;
    subverbs) _complete_subverbs "${1-}" ;;
    leaves)   _complete_leaves "$@" ;;
    prefixes) _complete_prefixes ;;
    *) exit 0 ;;
  esac
}

# Every user-facing verb with a one-line description. Source of truth for the
# verb list — excludes removed verbs (new/close/push/status) and plumbing
# (init, default-branch, prefix, __complete).
_complete_verbs() {
  printf '%s\t%s\n' \
    list      "Overview of all stacks in the repo" \
    view      "Show one stack's branches without checking out" \
    pick      "Pick a stack and check out its tip" \
    checkout  "Check out a stack branch by leaf number" \
    create    "Start a brand-new stack" \
    add       "Add an empty branch to the current stack" \
    sync      "Push the whole stack additively to the remote" \
    clean     "Prune gone branches and reflow survivors" \
    restack   "Reset+cherry-pick branches onto their predecessors" \
    amend     "Amend the current branch and reflow upper branches" \
    continue  "Resume a paused reflow after resolving conflicts" \
    abort     "Abort a paused reflow and restore original SHAs" \
    pr        "Sync, list, or close GitHub PRs for the stack" \
    history   "Show or restore stack snapshots" \
    rename    "Rename every branch in the stack to a new prefix" \
    move      "Move a branch to a different position in the stack" \
    fold      "Fold one branch's commits into another" \
    drop      "Discard a branch and reflow its children onto the predecessor" \
    doctor    "Diagnose stack health"
}

# Subverbs for verbs that have them; nothing (exit 0) for any other verb.
_complete_subverbs() {
  case "${1-}" in
    pr)
      printf '%s\t%s\n' \
        sync   "Create/update PRs for the stack" \
        list   "List the stack's PRs" \
        desync "Close the stack's PRs to reorder/re-sync clean"
      ;;
    history)
      printf '%s\t%s\n' \
        show    "Show a stack snapshot" \
        restore "Restore a stack snapshot"
      ;;
    *) exit 0 ;;
  esac
}

# `<number><TAB><slug>` per branch in leaf order for the resolved stack.
# --prefix <p> overrides; otherwise detect from the current branch. Silent if
# the prefix can't be resolved or the stack is empty.
_complete_leaves() {
  local override=""
  if [[ "${1-}" == "--prefix" ]]; then
    override="${2-}"
  fi
  local prefix
  prefix=$(_try_detect_prefix "$override") || exit 0
  local branches=()
  _load_stack_branches "$prefix" branches
  (( ${#branches[@]} )) || exit 0
  local b leaf num slug
  for b in "${branches[@]}"; do
    leaf="${b##*/}"
    [[ "$leaf" =~ ^([0-9]+)- ]] || continue
    num="${BASH_REMATCH[1]}"
    slug="${leaf#${num}-}"
    printf '%s\t%s\n' "$num" "$slug"
  done
}

# Each stack prefix in the repo, one per line (trailing-empty description).
_complete_prefixes() {
  local p
  while IFS= read -r p; do
    printf '%s\t\n' "$p"
  done < <(stack_prefixes)
}

# Emit shell-specific alias/function/abbr definitions for the given shell.
# Designed to be `eval`d (bash/zsh) or sourced (fish) at shell startup.
cmd_init() {
  local shell="${1-}"
  [[ -n "$shell" ]] || die "usage: git stack init <bash|zsh|fish>"
  case "$shell" in
    bash) _emit_init_posix ;;
    zsh)  _emit_init_posix; _emit_completion_zsh ;;
    fish) _emit_init_fish; _emit_completion_fish ;;
    *) die "unsupported shell: $shell (supported: bash, zsh, fish)" ;;
  esac
}

_emit_init_posix() {
  cat <<'POSIX_EOF'
# git stack shell integration — add to your rc:
#   eval "$(git stack init bash)"   # or  init zsh
alias gstk='git stack'
alias gstkl='git stack list'
alias gstkv='git stack view'
alias gstkp='git stack pick'
alias gstkco='git stack checkout'
alias gstkcr='git stack create'
alias gstkad='git stack add'
alias gstks='git stack sync'
alias gstkcl='git stack clean'
alias gstkr='git stack restack'
alias gstkrp='git stack restack --push'
alias gstkro='git stack restack --onto'
alias gstkcon='git stack continue'
alias gstkab='git stack abort'
alias gstkam='git stack amend'
alias gstkprs='git stack pr sync'
alias gstkprl='git stack pr list'
alias gstkh='git stack history'
alias gstkhs='git stack history show'
alias gstkhr='git stack history restore'
alias gstkmv='git stack move'
alias gstkfo='git stack fold'
alias gstkdr='git stack drop'
alias gstkrn='git stack rename'
alias gstkd='git stack doctor'
POSIX_EOF
}

_emit_init_fish() {
  cat <<'FISH_EOF'
# git stack shell integration — add to your config.fish:
#   git stack init fish | source
abbr -a -g gstk git stack
abbr -a -g gstkl git stack list
abbr -a -g gstkv git stack view
abbr -a -g gstkp git stack pick
abbr -a -g gstkco git stack checkout
abbr -a -g gstkcr git stack create
abbr -a -g gstkad git stack add
abbr -a -g gstks git stack sync
abbr -a -g gstkcl git stack clean
abbr -a -g gstkr git stack restack
abbr -a -g gstkrp git stack restack --push
abbr -a -g gstkro git stack restack --onto
abbr -a -g gstkcon git stack continue
abbr -a -g gstkab git stack abort
abbr -a -g gstkam git stack amend
abbr -a -g gstkprs git stack pr sync
abbr -a -g gstkprl git stack pr list
abbr -a -g gstkh git stack history
abbr -a -g gstkhs git stack history show
abbr -a -g gstkhr git stack history restore
abbr -a -g gstkmv git stack move
abbr -a -g gstkfo git stack fold
abbr -a -g gstkdr git stack drop
abbr -a -g gstkrn git stack rename
abbr -a -g gstkd git stack doctor
FISH_EOF
}

# zsh completion. zsh's bundled `_git` dispatches `git stack` to a function
# named `_git-stack` if one exists in the $functions table — so defining the
# function (no compdef, no fpath file) is enough. All dynamic candidates come
# from `git stack __complete`; ref slots (--onto/--from) defer to native git
# completion. `value<TAB>desc` lines from __complete are reshaped into the
# `value:desc` form _describe wants so hints render.
_emit_completion_zsh() {
  cat <<'ZSH_EOF'
# git stack zsh completion (driven by `git stack __complete`).
_git-stack() {
  local -a _gs_items
  _gs_complete() {
    # $1 = __complete kind + any extra args; populate _gs_items as value:desc.
    _gs_items=()
    local _gs_line
    for _gs_line in "${(@f)$(git stack __complete "$@" 2>/dev/null)}"; do
      [[ -n $_gs_line ]] || continue
      _gs_items+=("${_gs_line%%$'\t'*}:${_gs_line#*$'\t'}")
    done
  }

  # Forward an explicit `--prefix <p>` from the line into `__complete leaves`.
  _gs_leaves() {
    local i pfx=""
    for (( i = 1; i < CURRENT; i++ )); do
      if [[ ${words[i]} == --prefix ]]; then
        pfx=${words[i+1]}
        break
      fi
    done
    if [[ -n $pfx ]]; then
      _gs_complete leaves --prefix "$pfx"
    else
      _gs_complete leaves
    fi
    _describe -t leaves 'leaf' _gs_items
  }

  _gs_refs() {
    (( $+functions[__git_branch_names] )) && __git_branch_names
  }

  # words[1]=stack, words[2]=verb. Complete the verb itself at CURRENT==2.
  if (( CURRENT == 2 )); then
    _gs_complete verbs
    _describe -t verbs 'git stack verb' _gs_items
    return
  fi

  # Option-value slots take priority over positional dispatch.
  case ${words[CURRENT-1]} in
    --prefix) _gs_complete prefixes; _describe -t prefixes 'prefix' _gs_items; return ;;
    --before|--after|--at) _gs_leaves; return ;;
    --onto|--from) _gs_refs; return ;;
  esac

  # Positional dispatch keyed on the verb.
  case ${words[2]} in
    checkout|co) _gs_leaves; return ;;
    drop) _gs_leaves; return ;;
    view) _gs_complete prefixes; _describe -t prefixes 'prefix' _gs_items; return ;;
    pr|history)
      if (( CURRENT == 3 )); then
        _gs_complete subverbs "${words[2]}"
        _describe -t subverbs 'subcommand' _gs_items
        return
      fi
      ;;
  esac
}
ZSH_EOF
}

# fish completion. Guarded by `__fish_git_using_command stack` (shipped in
# fish's git completion). Dynamic candidates come from `git stack __complete`;
# fish parses `value\tdesc` from `-a '(...)'` into completion+description.
# `--onto/--from` defer to fish's native git ref completion. NOTE: `--prefix`
# is NOT forwarded into `leaves` here — fish's `complete` can't easily scrape a
# prior option value, so leaf completion falls back to current-branch detection
# (acceptable for v1). NOTE: `git stack pr sync <tab>` re-offers sync/list since
# they're also top-level verbs; minor, not fought for v1.
_emit_completion_fish() {
  cat <<'FISH_COMP_EOF'
# git stack fish completion (driven by `git stack __complete`).
# Suppress fish's filename fallback. fish's shipped git completion discovers
# `git-stack` on $PATH and delegates `git stack <args>` to `complete -C
# "git-stack <args>"` (see fish's git.fish __fish_git_complete_custom_command).
# With no completions on the `git-stack` command, that delegated call defaults
# to filename completion — which is why `git stack <tab>` (and pick/checkout)
# also list cwd files. Declaring no-files on `git-stack` kills it; -F restores
# files after `--` so `amend -- <pathspec>` still completes paths. (Our `-c git`
# entries below can't suppress this — the files come from a separate completion
# registered against the `git-stack` command name, not `git`.)
complete -c git-stack -f
complete -c git-stack -n 'contains -- -- (commandline -xpc)' -F
# Top-level verbs: only when no verb has been typed yet.
complete -c git -n '__fish_git_using_command stack; and not __fish_seen_subcommand_from list view pick checkout co create add sync clean restack amend continue abort pr history rename move mv fold drop doctor' -a '(git stack __complete verbs)'
# Sub-verbs.
complete -c git -n '__fish_git_using_command stack; and __fish_seen_subcommand_from pr' -a '(git stack __complete subverbs pr)'
complete -c git -n '__fish_git_using_command stack; and __fish_seen_subcommand_from history' -a '(git stack __complete subverbs history)'
# checkout → leaves; view → prefixes.
complete -c git -n '__fish_git_using_command stack; and __fish_seen_subcommand_from checkout co' -a '(git stack __complete leaves)'
complete -c git -n '__fish_git_using_command stack; and __fish_seen_subcommand_from drop' -a '(git stack __complete leaves)'
complete -c git -n '__fish_git_using_command stack; and __fish_seen_subcommand_from view' -a '(git stack __complete prefixes)'
# Option-value slots (-x binds the candidates to the option's argument).
complete -c git -n '__fish_git_using_command stack' -l prefix -x -a '(git stack __complete prefixes)'
complete -c git -n '__fish_git_using_command stack; and __fish_seen_subcommand_from add move mv' -l before -x -a '(git stack __complete leaves)'
complete -c git -n '__fish_git_using_command stack; and __fish_seen_subcommand_from add move mv' -l after -x -a '(git stack __complete leaves)'
complete -c git -n '__fish_git_using_command stack; and __fish_seen_subcommand_from add move mv' -l at -x -a '(git stack __complete leaves)'
complete -c git -n '__fish_git_using_command stack' -l onto -x -a '(__fish_git_branches)'
complete -c git -n '__fish_git_using_command stack' -l from -x -a '(__fish_git_branches)'
FISH_COMP_EOF
}

# ---------- dispatch ----------

# Subcommand exit codes:
#   0  success
#   1  generic error (die)
#   2  cherry-pick conflict — state file preserved; resume with `continue`
#   3  push failures during the run — state cleared; rerun pushes manually
main() {
  # Pre-scan args for color preference so help output respects it too.
  local arg
  for arg in "$@"; do
    case "$arg" in
      --color)    USE_COLOR_PREF="always" ;;
      --no-color) USE_COLOR_PREF="never" ;;
    esac
  done
  color_init
  local sub="${1-help}"
  case "$sub" in
    help|--help|-h|"") cmd_help ;;
    list)              shift; cmd_list "$@" ;;
    view)              shift; cmd_view "$@" ;;
    pick)              shift; cmd_pick "$@" ;;
    checkout|co)       shift; cmd_checkout "$@" ;;
    create)            shift; cmd_create "$@" ;;
    add)               shift; cmd_add "$@" ;;
    sync)              shift; cmd_sync "$@" ;;
    clean)             shift; cmd_clean "$@" ;;
    prefix)            shift; cmd_prefix "$@" ;;
    restack)           shift; cmd_restack "$@" ;;
    amend)             shift; cmd_amend "$@" ;;
    continue)          shift; cmd_continue "$@" ;;
    abort)             shift; cmd_abort "$@" ;;
    pr)                shift; cmd_pr "$@" ;;
    history)           shift; cmd_history "$@" ;;
    rename)            shift; cmd_rename "$@" ;;
    move|mv)           shift; cmd_move "$@" ;;
    fold)              shift; cmd_fold "$@" ;;
    drop)              shift; cmd_drop "$@" ;;
    doctor)            shift; cmd_doctor "$@" ;;
    init)              shift; cmd_init "$@" ;;
    default-branch)    shift; cmd_default_branch "$@" ;;
    # Hidden plumbing for shell completion — intentionally undocumented.
    __complete)        shift; cmd___complete "$@" ;;
    # Removed verbs — point at the renamed command.
    new)               die "'git stack new' was split: use 'git stack create <prefix> <slug>' to start a stack, or 'git stack add <slug>' to add to the current one" ;;
    close)             die "'git stack close' was renamed to 'git stack clean'" ;;
    push)              die "'git stack push' was renamed to 'git stack sync' (whole-stack additive push)" ;;
    status)            die "'git stack status' was folded into 'git stack view'" ;;
    *) die "unknown subcommand: $sub (try 'git stack help')" ;;
  esac
}

# Only run main when executed directly, not when sourced (e.g. by unit tests
# that exercise individual functions). Bash 3.2 compatible.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
